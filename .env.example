# Copy this file to .env and fill in the values.
# All values are optional - the app runs with sensible defaults.

# --- Server ---
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000

# --- Sessions ---
# Generate a long random string for production: `openssl rand -base64 48`
SESSION_SECRET=change-me-to-a-long-random-string
SESSION_COOKIE_NAME=papersub.sid

# Render and most hosted reverse proxies need this so secure cookies survive login.
# Use TRUST_PROXY=1 in production on Render.
TRUST_PROXY=0

# Defaults to true when NODE_ENV=production and false otherwise.
# Leave blank unless you need to override it.
SESSION_COOKIE_SECURE=

# --- JWT (for API auth) ---
# Generate with: `openssl rand -base64 48`
JWT_SECRET=change-me-jwt-secret
JWT_REFRESH_SECRET=change-me-jwt-refresh-secret

# --- Database ---
DB_PATH=./data/paper_submission.db

# Render note: attach a persistent disk and point DB_PATH/UPLOAD_DIR at it, for example:
# DB_PATH=/var/data/paper_submission.db
# UPLOAD_DIR=/var/data/uploads

# --- Uploads ---
UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=10

# --- LLM provider ---
# Options: "groq" (default), "heuristic" (offline, zero-cost), or "openrouter"
# If GROQ_API_KEY is set the app auto-selects groq even without this line.
LLM_PROVIDER=groq

# Required when LLM_PROVIDER=groq — get a free key at https://console.groq.com/keys
GROQ_API_KEY=
# Default primary model; groq.js routes per task and falls back across a chain.
GROQ_MODEL=llama-3.3-70b-versatile
# Optional per-request hard timeout in ms (default 30000).
GROQ_TIMEOUT_MS=30000

# Only required when LLM_PROVIDER=openrouter
# Free-tier models available — see https://openrouter.ai/models?q=free
OPENROUTER_API_KEY=
OPENROUTER_MODEL=moonshotai/kimi-k2.6:free

# --- Email (SMTP) ---
# Set EMAIL_ENABLED=true to send real emails (verification, password reset, notifications)
# If disabled, emails are logged to console only
EMAIL_ENABLED=false
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@papersubmission.local

# --- Logging ---
LOG_LEVEL=info

# === AI: API vs offline (heuristic) switch ===========================
# The text features (summary, keywords, titles, abstract polish, metadata
# extraction, review draft, AI-text detection) can each run on the hosted LLM
# or on the offline heuristic. AI_PREFER_API is the global default and defaults
# to ON whenever an LLM key (GROQ_API_KEY / OPENROUTER_API_KEY) is present, and
# OFF otherwise. Set it explicitly to force one mode for everything:
#   AI_PREFER_API=true    # use the API for every text feature
#   AI_PREFER_API=false   # use the offline heuristic for every text feature
AI_PREFER_API=

# Per-feature overrides — these win over AI_PREFER_API. Leave blank to inherit.
#   true  = use the hosted LLM for this feature
#   false = use the offline heuristic for this feature
AI_FEATURE_SUMMARY=
AI_FEATURE_KEYWORDS=
AI_FEATURE_TITLES=
AI_FEATURE_ABSTRACT=
AI_FEATURE_METADATA=
AI_FEATURE_REVIEW=
AI_FEATURE_AI_TEXT=

# === Embeddings: similarity features =================================
# Reviewer matching, plagiarism similarity and smart search rank text by vector
# similarity. The default is offline TF-IDF (zero cost, no key, no network). To
# switch on "real" API embeddings, set EMBEDDINGS_PROVIDER + EMBEDDINGS_API_KEY.
# Any API failure (bad key, network, etc.) falls back to TF-IDF automatically,
# so these features never break.
#
# Provider options — all OpenAI-compatible /embeddings, model IDs verified live
# June 2026 (override the model per provider with EMBEDDINGS_MODEL):
#   tfidf    (default) offline pure-JS TF-IDF — no key, no network
#   st       local sentence-transformers (run `npm i @xenova/transformers`)
#   openai   text-embedding-3-small    https://api.openai.com/v1
#   jina     jina-embeddings-v3        https://api.jina.ai/v1
#   voyage   voyage-3.5-lite           https://api.voyageai.com/v1
#   mistral  mistral-embed             https://api.mistral.ai/v1
#   gemini   gemini-embedding-001      https://generativelanguage.googleapis.com/v1beta/openai
#   nomic    nomic-embed-text-v1.5     https://api-atlas.nomic.ai/v1
#   custom   any other OpenAI-compatible endpoint (set EMBEDDINGS_BASE_URL + EMBEDDINGS_MODEL)
EMBEDDINGS_PROVIDER=tfidf
# API key for the chosen provider (not needed for tfidf / st).
EMBEDDINGS_API_KEY=
# Optional overrides — default to the chosen provider's preset above.
EMBEDDINGS_MODEL=
EMBEDDINGS_BASE_URL=
# Optional tuning.
EMBEDDINGS_TIMEOUT_MS=15000
EMBEDDINGS_MAX_BATCH=64
