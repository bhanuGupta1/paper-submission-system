# Copy this file to .env and fill in the values.
# All values are optional - the app runs with sensible defaults.

# --- Server ---
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000

# --- Sessions ---
# Generate a long random string for production: `openssl rand -base64 48`
SESSION_SECRET=change-me-to-a-long-random-string
SESSION_COOKIE_NAME=papersub.sid

# Render and most hosted reverse proxies need this so secure cookies survive login.
# Use TRUST_PROXY=1 in production on Render.
TRUST_PROXY=0

# Defaults to true when NODE_ENV=production and false otherwise.
# Leave blank unless you need to override it.
SESSION_COOKIE_SECURE=

# --- JWT (for API auth) ---
# Generate with: `openssl rand -base64 48`
JWT_SECRET=change-me-jwt-secret
JWT_REFRESH_SECRET=change-me-jwt-refresh-secret

# --- Database ---
DB_PATH=./data/paper_submission.db

# Render note: attach a persistent disk and point DB_PATH/UPLOAD_DIR at it, for example:
# DB_PATH=/var/data/paper_submission.db
# UPLOAD_DIR=/var/data/uploads

# --- Uploads ---
UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=10

# --- LLM provider ---
# Options: "heuristic" (default, fully offline, zero-cost) or "claude"
LLM_PROVIDER=heuristic

# Only required when LLM_PROVIDER=claude
# Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Email (SMTP) ---
# Set EMAIL_ENABLED=true to send real emails (verification, password reset, notifications)
# If disabled, emails are logged to console only
EMAIL_ENABLED=false
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@papersubmission.local

# --- Logging ---
LOG_LEVEL=info
