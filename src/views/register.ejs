<!DOCTYPE html>
<html lang="en">
<head><%- include('partials/head') %></head>
<body class="min-h-screen flex flex-col overflow-x-hidden" style="background:var(--surface-0);color:var(--text-primary)">
  <%- include('partials/nav') %>

  <main class="auth-canvas flex-1 relative overflow-hidden">
    <div class="mesh-bg" aria-hidden="true">
      <span class="mesh-blob mesh-blob-one"></span>
      <span class="mesh-blob mesh-blob-two"></span>
      <span class="mesh-blob mesh-blob-three"></span>
      <span class="mesh-blob mesh-blob-four"></span>
    </div>

    <div class="relative z-10 min-h-[calc(100vh-65px)] flex items-center justify-center px-6 py-12">
      <section class="glass-card gradient-border-card auth-card animate-slide-up-fade w-full max-w-[520px] p-7 sm:p-9">
        <div class="flex justify-center gap-2 mb-7" aria-hidden="true">
          <span class="progress-dot active"></span>
          <span class="progress-dot"></span>
          <span class="progress-dot"></span>
        </div>

        <div class="text-center">
          <span class="brand-mark mx-auto inline-flex h-12 w-12 items-center justify-center rounded-xl text-base font-black text-white">P</span>
          <p class="eyebrow mt-5" style="color:var(--accent-500)">Start your editorial workspace</p>
          <h1 class="font-display mt-3 text-3xl sm:text-4xl font-extrabold gradient-text">Create your account</h1>
          <p class="mt-3 text-sm" style="color:var(--text-secondary)">Set up your identity, role, and matching metadata in under a minute.</p>
        </div>

        <% if (error) { %>
          <div class="alert alert-warning mt-6" role="alert">
            <svg class="w-4 h-4 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/></svg>
            <span><%= error %></span>
          </div>
        <% } %>

        <form action="/register" method="post" class="mt-7 space-y-5">
          <div class="grid grid-cols-2 gap-3">
            <div>
              <label for="firstName" class="block text-sm font-semibold mb-2">First name</label>
              <input id="firstName" name="firstName" autocomplete="given-name" placeholder="Jane"
                class="auth-input block w-full rounded-xl border px-4 py-3 text-sm"
                style="background:rgba(255,255,255,0.55);border-color:var(--border-default);color:var(--text-primary)">
            </div>
            <div>
              <label for="lastName" class="block text-sm font-semibold mb-2">Last name</label>
              <input id="lastName" name="lastName" autocomplete="family-name" placeholder="Smith"
                class="auth-input block w-full rounded-xl border px-4 py-3 text-sm"
                style="background:rgba(255,255,255,0.55);border-color:var(--border-default);color:var(--text-primary)">
            </div>
            <div class="col-span-2">
              <label for="username" class="block text-sm font-semibold mb-2">Username</label>
              <input id="username" name="username" required minlength="3" autocomplete="username" placeholder="jsmith"
                class="auth-input block w-full rounded-xl border px-4 py-3 text-sm"
                style="background:rgba(255,255,255,0.55);border-color:var(--border-default);color:var(--text-primary)">
            </div>
            <div class="col-span-2">
              <label for="email" class="block text-sm font-semibold mb-2">Email <span class="font-normal text-xs" style="color:var(--text-tertiary)">(optional)</span></label>
              <input id="email" type="email" name="email" autocomplete="email" placeholder="you@university.edu"
                class="auth-input block w-full rounded-xl border px-4 py-3 text-sm"
                style="background:rgba(255,255,255,0.55);border-color:var(--border-default);color:var(--text-primary)">
            </div>
          </div>

          <fieldset>
            <legend class="block text-sm font-semibold mb-3">Choose role</legend>
            <div class="grid sm:grid-cols-3 gap-3">
              <label class="role-card">
                <input class="sr-only role-radio" type="radio" name="role" value="author" checked>
                <span class="role-icon">
                  <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5M18.5 2.5a2.12 2.12 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                </span>
                <span class="role-title">Author</span>
                <span class="role-copy">Submit and track papers.</span>
                <span class="role-check">&#10003;</span>
              </label>
              <label class="role-card">
                <input class="sr-only role-radio" type="radio" name="role" value="reviewer">
                <span class="role-icon">
                  <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                </span>
                <span class="role-title">Reviewer</span>
                <span class="role-copy">Score manuscripts.</span>
                <span class="role-check">&#10003;</span>
              </label>
              <label class="role-card role-card-disabled" title="Admin accounts are provisioned by platform owners.">
                <input class="sr-only role-radio" type="radio" name="role" value="admin" disabled>
                <span class="role-icon">
                  <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
                </span>
                <span class="role-title">Admin</span>
                <span class="role-copy">Provisioned access.</span>
                <span class="role-check">&#10003;</span>
              </label>
            </div>
          </fieldset>

          <div>
            <label for="password" class="block text-sm font-semibold mb-2">Password</label>
            <input id="password" type="password" name="password" required minlength="8" autocomplete="new-password" placeholder="Create a strong password"
              class="auth-input block w-full rounded-xl border px-4 py-3 text-sm"
              style="background:rgba(255,255,255,0.55);border-color:var(--border-default);color:var(--text-primary)">
            <div class="password-strength mt-3" aria-hidden="true">
              <span></span><span></span><span></span><span></span>
            </div>
          </div>

          <div>
            <label for="confirmPassword" class="block text-sm font-semibold mb-2">Confirm password</label>
            <input id="confirmPassword" type="password" name="confirmPassword" required minlength="8" autocomplete="new-password" placeholder="Repeat password"
              class="auth-input block w-full rounded-xl border px-4 py-3 text-sm"
              style="background:rgba(255,255,255,0.55);border-color:var(--border-default);color:var(--text-primary)">
          </div>

          <div>
            <label for="affiliation" class="block text-sm font-semibold mb-2">Affiliation <span class="font-normal text-xs" style="color:var(--text-tertiary)">(for COI detection)</span></label>
            <input id="affiliation" name="affiliation" placeholder="University of Auckland"
              class="auth-input block w-full rounded-xl border px-4 py-3 text-sm"
              style="background:rgba(255,255,255,0.55);border-color:var(--border-default);color:var(--text-primary)">
          </div>

          <div>
            <label for="expertise" class="block text-sm font-semibold mb-2">Expertise tags</label>
            <input id="expertise" name="expertise" placeholder="NLP, transformers, machine learning"
              class="auth-input block w-full rounded-xl border px-4 py-3 text-sm"
              style="background:rgba(255,255,255,0.55);border-color:var(--border-default);color:var(--text-primary)">
          </div>

          <button class="btn-gradient shimmer-btn w-full mt-2">
            Create account
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
          </button>
        </form>

        <% if (googleOAuthEnabled || githubOAuthEnabled) { %>
          <div class="relative my-6">
            <div class="absolute inset-0 flex items-center"><div class="w-full border-t" style="border-color:var(--border-default)"></div></div>
            <div class="relative flex justify-center text-xs"><span class="px-3 rounded-full glass-chip" style="color:var(--text-tertiary)">or sign up with</span></div>
          </div>
          <div class="grid gap-2">
            <% if (googleOAuthEnabled) { %><a href="/auth/google" class="btn btn-secondary w-full py-3 text-sm">Continue with Google</a><% } %>
            <% if (githubOAuthEnabled) { %><a href="/auth/github" class="btn btn-secondary w-full py-3 text-sm">Continue with GitHub</a><% } %>
          </div>
        <% } %>

        <p class="text-sm mt-6 text-center" style="color:var(--text-secondary)">
          Already have an account? <a href="/login" class="font-semibold link-line" style="color:var(--brand-500)">Sign in</a>
        </p>
      </section>
    </div>
  </main>

  <script>
    (function() {
      const input = document.getElementById('password');
      const meter = document.querySelector('.password-strength');
      if (!input || !meter) return;
      const colors = ['#ef4444', '#f97316', '#eab308', '#22c55e'];
      const thresholds = [6, 8, 10, 12];
      const segments = Array.from(meter.children);
      function updateStrength() {
        const score = thresholds.filter((length) => input.value.length >= length).length;
        segments.forEach((segment, index) => {
          segment.style.background = index < score ? colors[Math.max(0, score - 1)] : 'var(--surface-2)';
          segment.style.transform = index < score ? 'scaleY(1)' : 'scaleY(0.6)';
        });
      }
      input.addEventListener('input', updateStrength);
      updateStrength();
    })();
  </script>
  <%- include('partials/footer') %>
</body>
</html>
