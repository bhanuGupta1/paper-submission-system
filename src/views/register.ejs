<!DOCTYPE html>
<html lang="en">
<head><%- include('partials/head') %></head>
<body class="min-h-screen bg-slate-50 text-slate-900 flex flex-col">
  <%- include('partials/nav') %>
  <main class="flex-1">
    <div class="max-w-6xl mx-auto px-6 py-12 grid lg:grid-cols-[0.5fr_0.5fr] gap-8 items-start">
      <section class="pt-4">
        <p class="eyebrow text-indigo-700">Join the workflow</p>
        <h1 class="font-display text-5xl font-bold mt-2 leading-tight">Create your research operations account.</h1>
        <p class="text-slate-600 mt-4 leading-relaxed">Choose a role, add affiliation metadata for conflict checks, and start using the platform as an author, reviewer, editor, or reader.</p>
        <div class="grid sm:grid-cols-2 gap-3 mt-6">
          <div class="metric-card"><div class="metric-label">COI ready</div><p class="text-sm text-slate-600 mt-2">Affiliations feed reviewer conflict detection.</p></div>
          <div class="metric-card"><div class="metric-label">Matching ready</div><p class="text-sm text-slate-600 mt-2">Expertise tags improve reviewer recommendations.</p></div>
        </div>
      </section>
      <section class="card glass-auth p-8">
        <h2 class="font-display text-3xl font-bold">Create account</h2>
        <p class="text-sm text-slate-600 mt-1">It takes about a minute.</p>
        <% if (error) { %>
          <div class="mt-4 bg-amber-50 border border-amber-200 text-amber-800 text-sm p-3 rounded-md"><%= error %></div>
        <% } %>
        <form action="/register" method="post" class="mt-6 space-y-4">
          <div>
            <label class="block text-sm font-semibold text-slate-700">Username</label>
            <input name="username" required minlength="3" class="mt-1 block w-full rounded-md border border-slate-300 px-3 py-2.5 focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 focus:outline-none">
          </div>
          <div>
            <label class="block text-sm font-semibold text-slate-700">Email <span class="text-slate-400 font-normal">(optional)</span></label>
            <input type="email" name="email" class="mt-1 block w-full rounded-md border border-slate-300 px-3 py-2.5 focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 focus:outline-none">
          </div>
          <div>
            <label class="block text-sm font-semibold text-slate-700">Password</label>
            <input type="password" name="password" required minlength="8" class="mt-1 block w-full rounded-md border border-slate-300 px-3 py-2.5 focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 focus:outline-none">
          </div>
          <div>
            <label class="block text-sm font-semibold text-slate-700">Role</label>
            <select name="role" required class="mt-1 block w-full rounded-md border border-slate-300 px-3 py-2.5 bg-white focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 focus:outline-none">
              <option value="author">Author</option>
              <option value="reviewer">Reviewer</option>
              <option value="editor">Editor</option>
              <option value="reader">Reader</option>
            </select>
          </div>
          <div>
            <label class="block text-sm font-semibold text-slate-700">Affiliation <span class="text-slate-400 font-normal">(used for COI detection)</span></label>
            <input name="affiliation" placeholder="University of Auckland" class="mt-1 block w-full rounded-md border border-slate-300 px-3 py-2.5 focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 focus:outline-none">
          </div>
          <div>
            <label class="block text-sm font-semibold text-slate-700">Expertise tags <span class="text-slate-400 font-normal">(reviewers only)</span></label>
            <input name="expertise" placeholder="NLP, transformers, machine learning" class="mt-1 block w-full rounded-md border border-slate-300 px-3 py-2.5 focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 focus:outline-none">
          </div>
          <button class="w-full bg-slate-950 hover:bg-slate-800 text-white py-2.5 rounded-md font-semibold transition">Create account</button>
        </form>
      </section>
    </div>
  </main>
  <%- include('partials/footer') %>
</body>
</html>
