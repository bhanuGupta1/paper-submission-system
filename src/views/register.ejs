<!DOCTYPE html>
<html lang="en">
<head><%- include('partials/head') %></head>
<body class="min-h-screen bg-slate-50 text-slate-900 flex flex-col">
  <%- include('partials/nav') %>
  <main class="flex-1">
    <div class="max-w-6xl mx-auto px-6 py-12 grid lg:grid-cols-[0.5fr_0.5fr] gap-10 items-start">
      <section class="pt-4">
        <p class="eyebrow text-indigo-700">Join the workflow</p>
        <h1 class="font-display text-5xl font-bold mt-2 leading-tight">Create your research operations account.</h1>
        <p class="mt-4 leading-relaxed" style="color: var(--text-secondary)">Choose a role, add affiliation metadata for conflict checks, and start using the platform as an author, reviewer, editor, or reader.</p>
        <div class="grid sm:grid-cols-2 gap-3 mt-6">
          <div class="metric-card">
            <div class="metric-label">COI ready</div>
            <p class="text-sm mt-2" style="color: var(--text-secondary)">Affiliations feed reviewer conflict detection.</p>
          </div>
          <div class="metric-card">
            <div class="metric-label">Matching ready</div>
            <p class="text-sm mt-2" style="color: var(--text-secondary)">Expertise tags improve reviewer recommendations.</p>
          </div>
        </div>
      </section>
      <section class="glass-auth p-8">
        <h2 class="font-display text-2xl font-bold">Create account</h2>
        <p class="text-sm mt-1" style="color: var(--text-secondary)">It takes about a minute.</p>
        <% if (error) { %>
          <div class="alert alert-warning mt-4"><%= error %></div>
        <% } %>
        <form action="/register" method="post" class="mt-6 space-y-4">
          <div>
            <label class="block text-sm font-semibold mb-1" style="color: var(--text-secondary)">Username</label>
            <input name="username" required minlength="3" class="block w-full rounded-md border border-slate-300 px-3 py-2.5">
          </div>
          <div>
            <label class="block text-sm font-semibold mb-1" style="color: var(--text-secondary)">
              Email <span class="font-normal" style="color: var(--text-tertiary)">(optional)</span>
            </label>
            <input type="email" name="email" class="block w-full rounded-md border border-slate-300 px-3 py-2.5">
          </div>
          <div>
            <label class="block text-sm font-semibold mb-1" style="color: var(--text-secondary)">Password</label>
            <input type="password" name="password" required minlength="8" class="block w-full rounded-md border border-slate-300 px-3 py-2.5">
          </div>
          <div>
            <label class="block text-sm font-semibold mb-1" style="color: var(--text-secondary)">Confirm password</label>
            <input type="password" name="confirmPassword" required minlength="8" class="block w-full rounded-md border border-slate-300 px-3 py-2.5">
          </div>
          <div>
            <label class="block text-sm font-semibold mb-1" style="color: var(--text-secondary)">Role</label>
            <select name="role" required class="block w-full rounded-md border border-slate-300 px-3 py-2.5 bg-white">
              <option value="author">Author</option>
              <option value="reviewer">Reviewer</option>
              <option value="reader">Reader</option>
            </select>
            <p class="text-xs mt-1" style="color: var(--text-tertiary)">Editor and admin accounts are provisioned by the platform owner.</p>
          </div>
          <div>
            <label class="block text-sm font-semibold mb-1" style="color: var(--text-secondary)">
              Affiliation <span class="font-normal" style="color: var(--text-tertiary)">(used for COI detection)</span>
            </label>
            <input name="affiliation" placeholder="University of Auckland" class="block w-full rounded-md border border-slate-300 px-3 py-2.5">
          </div>
          <div>
            <label class="block text-sm font-semibold mb-1" style="color: var(--text-secondary)">
              Expertise tags <span class="font-normal" style="color: var(--text-tertiary)">(reviewers only)</span>
            </label>
            <input name="expertise" placeholder="NLP, transformers, machine learning" class="block w-full rounded-md border border-slate-300 px-3 py-2.5">
          </div>
          <button class="btn btn-primary w-full py-2.5">Create account</button>
        </form>
      </section>
    </div>
  </main>
  <%- include('partials/footer') %>
</body>
</html>
