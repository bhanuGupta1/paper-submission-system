<!DOCTYPE html>
<html lang="en">
<head><%- include('../partials/head') %></head>
<body class="min-h-screen flex flex-col overflow-x-hidden" style="background:var(--surface-0);color:var(--text-primary)">
  <%- include('../partials/nav') %>
  <main class="auth-canvas flex-1 relative overflow-hidden">
    <div class="mesh-bg" aria-hidden="true">
      <span class="mesh-blob mesh-blob-one"></span>
      <span class="mesh-blob mesh-blob-two"></span>
    </div>
    <div class="relative z-10 min-h-[calc(100vh-65px)] flex items-center justify-center px-6 py-12">
      <section class="glass-card gradient-border-card auth-card animate-slide-up-fade w-full max-w-[480px] p-8 sm:p-9 text-center">
        <div class="mx-auto w-14 h-14 rounded-full flex items-center justify-center mb-6" style="background:rgba(220,38,38,0.1)">
          <svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="color:#dc2626"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        </div>
        <h1 class="font-display text-2xl font-extrabold" style="color:var(--text-primary)">Deletion request received</h1>
        <p class="mt-4 text-sm leading-7" style="color:var(--text-secondary)">
          Your account has been deactivated immediately. Your data will be permanently deleted within <strong>30 days</strong> in accordance with our privacy policy.
        </p>
        <p class="mt-3 text-sm" style="color:var(--text-secondary)">
          If this was a mistake, contact your administrator within the 30-day window to restore your account.
        </p>
        <a href="/" class="btn-gradient shimmer-btn mt-8 w-full">Return to home</a>
      </section>
    </div>
  </main>
  <%- include('../partials/footer') %>
</body>
</html>
