<!DOCTYPE html>
<html lang="en">
<head><%- include('../partials/head') %></head>
<body class="min-h-screen bg-slate-50 text-slate-900 flex flex-col">
  <%- include('../partials/nav') %>
  <main class="flex-1 flex items-center justify-center px-6 py-16">
    <div class="w-full max-w-md">
      <div class="card p-8">
        <h1 class="font-display text-3xl font-bold">Set new password</h1>
        <p class="text-slate-600 mt-2 text-sm">Choose a strong password with at least 8 characters including a letter and number.</p>

        <% if (error) { %>
          <div class="mt-4 bg-red-50 border border-red-200 text-red-800 text-sm p-3 rounded-md" role="alert"><%= error %></div>
        <% } %>

        <form action="/auth/reset-password" method="post" class="mt-6 space-y-4" id="resetForm">
          <input type="hidden" name="token" value="<%= token %>">
          <div>
            <label for="password" class="block text-sm font-semibold text-slate-700">New password</label>
            <input id="password" type="password" name="password" required minlength="8" autocomplete="new-password"
              class="mt-1 block w-full rounded-md border border-slate-300 px-3 py-2.5 focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 focus:outline-none">
          </div>
          <div>
            <label for="confirmPassword" class="block text-sm font-semibold text-slate-700">Confirm new password</label>
            <input id="confirmPassword" type="password" name="confirmPassword" required minlength="8" autocomplete="new-password"
              class="mt-1 block w-full rounded-md border border-slate-300 px-3 py-2.5 focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 focus:outline-none">
            <p id="matchMsg" class="text-xs mt-1 hidden"></p>
          </div>
          <button type="submit" class="w-full bg-indigo-600 hover:bg-indigo-700 text-white py-2.5 rounded-md font-semibold transition">
            Update password
          </button>
        </form>
      </div>
    </div>
  </main>
  <%- include('../partials/footer') %>
  <script>
    const pw = document.getElementById('password');
    const cpw = document.getElementById('confirmPassword');
    const msg = document.getElementById('matchMsg');
    cpw.addEventListener('input', () => {
      if (!cpw.value) { msg.classList.add('hidden'); return; }
      msg.classList.remove('hidden');
      if (pw.value === cpw.value) { msg.textContent = '✓ Passwords match'; msg.className = 'text-xs mt-1 text-emerald-600'; }
      else { msg.textContent = '✗ Passwords do not match'; msg.className = 'text-xs mt-1 text-red-600'; }
    });
  </script>
</body>
</html>
