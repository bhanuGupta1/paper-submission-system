<!DOCTYPE html>
<html lang="en">
<head><%- include('../partials/head') %></head>
<body class="min-h-screen flex flex-col" style="background:var(--surface-0);color:var(--text-primary)">
  <%- include('../partials/nav') %>
  <main class="flex-1 flex items-center justify-center px-6 py-16">
    <div class="w-full max-w-md">
      <div class="card p-8">
        <h1 class="font-display text-3xl font-bold">Reset your password</h1>
        <p class="text-slate-600 mt-2 text-sm">Enter your email address and we'll send you a reset link.</p>

        <% if (error) { %>
          <div class="mt-4 bg-red-50 border border-red-200 text-red-800 text-sm p-3 rounded-md" role="alert"><%= error %></div>
        <% } %>
        <% if (success) { %>
          <div class="mt-4 bg-emerald-50 border border-emerald-200 text-emerald-800 text-sm p-3 rounded-md" role="alert"><%= success %></div>
        <% } %>

        <form action="/auth/forgot-password" method="post" class="mt-6 space-y-4">
          <div>
            <label for="email" class="block text-sm font-semibold text-slate-700">Email address</label>
            <input id="email" type="email" name="email" required autocomplete="email"
              class="mt-1 block w-full rounded-md border border-slate-300 px-3 py-2.5 focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 focus:outline-none">
          </div>
          <button type="submit" class="w-full bg-indigo-600 hover:bg-indigo-700 text-white py-2.5 rounded-md font-semibold transition">
            Send reset link
          </button>
        </form>

        <p class="text-sm mt-5 text-slate-600 text-center">
          Remembered it? <a href="/login" class="text-indigo-600 hover:text-indigo-500 font-semibold">Sign in</a>
        </p>
      </div>
    </div>
  </main>
  <%- include('../partials/footer') %>
</body>
</html>
