<!DOCTYPE html>
<html lang="en">
<head><%- include('../partials/head') %></head>
<body class="min-h-screen flex flex-col overflow-x-hidden" style="background:var(--surface-0);color:var(--text-primary)">
  <%- include('../partials/nav') %>

  <main class="auth-canvas flex-1 relative overflow-hidden">
    <div class="page-photo-bg" style="background-image:url('https://images.unsplash.com/photo-1507842217343-583bb7270b66?auto=format&fit=crop&w=1920&q=80')" aria-hidden="true"></div>
    <div class="mesh-bg" aria-hidden="true">
      <span class="mesh-blob mesh-blob-one"></span>
      <span class="mesh-blob mesh-blob-two"></span>
      <span class="mesh-blob mesh-blob-three"></span>
    </div>

    <div class="relative z-10 min-h-[calc(100vh-65px)] flex items-center justify-center px-6 py-12">
      <section class="glass-card gradient-border-card auth-card animate-slide-up-fade w-full max-w-[460px] p-7 sm:p-9">
        <div class="text-center">
          <span class="brand-mark mx-auto inline-flex h-12 w-12 items-center justify-center rounded-xl text-base font-black text-white">P</span>
          <p class="eyebrow mt-5" style="color:var(--accent-500)">Account recovery</p>
          <h1 class="font-display mt-3 text-3xl font-extrabold gradient-text">Reset your password</h1>
          <p class="mt-3 text-sm" style="color:var(--text-secondary)">Enter your email address and we'll send you a reset link.</p>
        </div>

        <% if (error) { %>
          <div class="alert alert-warning mt-6" role="alert">
            <svg class="w-4 h-4 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/></svg>
            <span><%= error %></span>
          </div>
        <% } %>
        <% if (success) { %>
          <div class="alert alert-success mt-6" role="alert">
            <svg class="w-4 h-4 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            <span><%= success %></span>
          </div>
        <% } %>

        <form action="/auth/forgot-password" method="post" class="mt-7 space-y-5">
          <div>
            <label for="email" class="block text-sm font-semibold mb-2">Email address</label>
            <input id="email" type="email" name="email" required autocomplete="email" placeholder="you@university.edu"
              class="auth-input block w-full rounded-xl border px-4 py-3 text-sm"
              style="background:rgba(255,255,255,0.55);border-color:var(--border-default);color:var(--text-primary)">
          </div>
          <button type="submit" class="btn-gradient shimmer-btn w-full mt-2">
            Send reset link
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
          </button>
        </form>

        <p class="text-sm mt-6 text-center" style="color:var(--text-secondary)">
          Remembered it? <a href="/login" class="font-semibold link-line" style="color:var(--brand-500)">Sign in</a>
        </p>
      </section>
    </div>
  </main>
  <%- include('../partials/footer') %>
</body>
</html>
