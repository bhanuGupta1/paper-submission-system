<!DOCTYPE html>
<html lang="en">
<head><%- include('../partials/head') %></head>
<body class="min-h-screen flex flex-col" style="background:var(--surface-0);color:var(--text-primary)">
  <%- include('../partials/nav') %>
  <main class="flex-1 relative overflow-hidden">
    <div class="page-photo-bg" style="background-image:url('https://images.unsplash.com/photo-1521587760476-6c12a4b040da?auto=format&fit=crop&w=1920&q=80')" aria-hidden="true"></div>
    <div class="max-w-7xl mx-auto px-6 py-8 relative z-10">

      <!-- Hero -->
      <div class="dashboard-hero mb-8">
        <div>
          <p class="eyebrow text-indigo-200">Platform command center</p>
          <h1 class="font-display text-4xl font-bold text-white mt-2">Admin dashboard</h1>
          <p class="text-sm mt-2 max-w-2xl" style="color:rgba(148,163,184,0.9)">Monitor review throughput, integrity flags, AI usage, and manuscripts that need editorial attention.</p>
        </div>
        <div class="flex items-center gap-2 shrink-0">
          <a href="/admin/users" class="btn btn-sm" style="background:rgba(255,255,255,0.12);border-color:rgba(255,255,255,0.15);color:white">Users</a>
          <a href="/admin/audit-log" class="btn btn-sm" style="background:rgba(255,255,255,0.12);border-color:rgba(255,255,255,0.15);color:white">Audit log</a>
          <a href="/admin/backup" class="btn btn-sm" style="background:rgba(255,255,255,0.12);border-color:rgba(255,255,255,0.15);color:white">Backups</a>
          <a href="/admin/lms" class="btn btn-sm" style="background:rgba(255,255,255,0.12);border-color:rgba(255,255,255,0.15);color:white">LMS</a>
          <form method="post" action="/admin/digest" onsubmit="return confirm('Send weekly digest email to all active editors now?')">
            <button type="submit" class="btn btn-sm" style="background:rgba(255,255,255,0.12);border-color:rgba(255,255,255,0.15);color:white">Send digest</button>
          </form>
          <a href="/admin/export.xlsx" class="btn btn-sm" style="background:white;color:#0f172a">
            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
            Export XLSX
          </a>
        </div>
      </div>

      <!-- KPI row -->
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
        <article class="stat-glass-card glass-card p-5">
          <div class="stat-num text-3xl gradient-text"><%= papers.length %></div>
          <div class="metric-label">Total papers</div>
          <div class="sparkline mt-3" aria-hidden="true"><span style="height:40%"></span><span style="height:60%"></span><span style="height:50%"></span><span style="height:80%"></span><span style="height:70%"></span><span style="height:90%"></span></div>
        </article>
        <article class="stat-glass-card glass-card p-5">
          <div class="stat-num text-3xl gradient-text"><%= ops.reviewFunnel.assignments %></div>
          <div class="metric-label">Assignments</div>
          <div class="sparkline violet mt-3" aria-hidden="true"><span style="height:50%"></span><span style="height:65%"></span><span style="height:55%"></span><span style="height:75%"></span><span style="height:68%"></span><span style="height:80%"></span></div>
        </article>
        <article class="stat-glass-card glass-card p-5">
          <div class="stat-num text-3xl gradient-text"><%= ops.reviewFunnel.completionRate %>%</div>
          <div class="metric-label">Review completion</div>
          <div class="sparkline green mt-3" aria-hidden="true"><span style="height:30%"></span><span style="height:45%"></span><span style="height:60%"></span><span style="height:75%"></span><span style="height:85%"></span><span style="height:95%"></span></div>
        </article>
        <article class="stat-glass-card glass-card p-5">
          <div class="stat-num text-3xl gradient-text"><%= aiUsage.reduce((a, r) => a + r.n, 0) %></div>
          <div class="metric-label">AI assists</div>
          <div class="sparkline amber mt-3" aria-hidden="true"><span style="height:55%"></span><span style="height:70%"></span><span style="height:62%"></span><span style="height:85%"></span><span style="height:75%"></span><span style="height:90%"></span></div>
        </article>
      </div>

      <!-- Pipeline + Integrity row -->
      <div class="grid lg:grid-cols-[1.3fr_0.7fr] gap-5 mb-6">
        <!-- Submission pipeline -->
        <section class="glass-card p-6">
          <div class="flex items-center justify-between mb-5">
            <div>
              <h2 class="font-display text-lg font-bold" style="color:var(--text-primary)">Submission pipeline</h2>
              <p class="text-xs mt-0.5" style="color:var(--text-tertiary)">Status distribution across all manuscripts</p>
            </div>
            <span class="tag-pill text-xs"><%= papers.length %> total</span>
          </div>
          <% const statusColors = { pending: 'var(--text-tertiary)', under_review: 'var(--brand-500)', accepted: 'var(--success-600)', rejected: 'var(--error-600)', revisions: '#f59e0b' }; %>
          <div class="space-y-3.5">
            <% ops.statusBreakdown.forEach(item => { %>
              <div>
                <div class="flex justify-between items-center mb-1.5">
                  <div class="flex items-center gap-2">
                    <span class="w-2 h-2 rounded-full shrink-0" style="background:<%= statusColors[item.status] || 'var(--brand-500)' %>"></span>
                    <span class="text-sm font-medium capitalize" style="color:var(--text-primary)"><%= item.status.replace('_', ' ') %></span>
                  </div>
                  <span class="text-sm font-semibold" style="color:var(--text-secondary)"><%= item.count %> <span class="font-normal text-xs" style="color:var(--text-tertiary)">(<%= item.percent %>%)</span></span>
                </div>
                <div class="progress-bar">
                  <div class="progress-fill" style="width:<%= item.percent %>%;background:<%= statusColors[item.status] || 'var(--brand-500)' %>"></div>
                </div>
              </div>
            <% }) %>
            <% if (ops.statusBreakdown.length === 0) { %>
              <p class="text-sm text-center py-4" style="color:var(--text-tertiary)">No submissions yet.</p>
            <% } %>
          </div>

          <!-- Avg scores -->
          <% if (ops.reviewFunnel.averageScores) { %>
          <div class="mt-5 pt-5" style="border-top:1px solid var(--border-default)">
            <p class="text-xs font-semibold uppercase tracking-wider mb-3" style="color:var(--text-tertiary)">Average review scores</p>
            <div class="grid grid-cols-3 gap-3">
              <div class="text-center p-2 rounded-lg" style="background:var(--surface-1)">
                <div class="font-bold text-lg" style="color:var(--brand-600)"><%= ops.reviewFunnel.averageScores.novelty %></div>
                <div class="text-xs" style="color:var(--text-tertiary)">Novelty</div>
              </div>
              <div class="text-center p-2 rounded-lg" style="background:var(--surface-1)">
                <div class="font-bold text-lg" style="color:var(--accent-600)"><%= ops.reviewFunnel.averageScores.clarity %></div>
                <div class="text-xs" style="color:var(--text-tertiary)">Clarity</div>
              </div>
              <div class="text-center p-2 rounded-lg" style="background:var(--surface-1)">
                <div class="font-bold text-lg" style="color:#7c3aed"><%= ops.reviewFunnel.averageScores.significance %></div>
                <div class="text-xs" style="color:var(--text-tertiary)">Significance</div>
              </div>
            </div>
          </div>
          <% } %>
        </section>

        <!-- Integrity snapshot -->
        <section class="glass-card p-6">
          <h2 class="font-display text-lg font-bold mb-1" style="color:var(--text-primary)">Integrity snapshot</h2>
          <p class="text-xs mb-5" style="color:var(--text-tertiary)">Triage signals — never automated decisions</p>

          <div class="grid grid-cols-2 gap-3">
            <div class="integrity-card-danger">
              <div class="stat-num text-3xl" style="color:var(--error-700)"><%= ops.integritySnapshot.highSimilarity %></div>
              <div class="metric-label" style="color:var(--error-700)">High similarity</div>
            </div>
            <div class="integrity-card-warning">
              <div class="stat-num text-3xl" style="color:var(--warning-700)"><%= ops.integritySnapshot.highAiLikelihood %></div>
              <div class="metric-label" style="color:var(--warning-700)">High AI signal</div>
            </div>
            <div class="integrity-card-neutral">
              <div class="stat-num text-3xl" style="color:var(--text-primary)"><%= ops.integritySnapshot.avgSimilarity %>%</div>
              <div class="metric-label">Avg similarity</div>
            </div>
            <div class="integrity-card-neutral">
              <div class="stat-num text-3xl" style="color:var(--text-primary)"><%= ops.integritySnapshot.avgAiLikelihood %>%</div>
              <div class="metric-label">Avg AI signal</div>
            </div>
          </div>

          <div class="mt-5 pt-4" style="border-top:1px solid var(--border-default)">
            <p class="text-xs" style="color:var(--text-tertiary)">
              Similarity &gt;70% or AI signal &gt;60% marks a paper for editorial review, not automatic action.
            </p>
          </div>
        </section>
      </div>

      <!-- At-risk queue + submission table -->
      <div class="grid lg:grid-cols-[0.38fr_0.62fr] gap-5 mb-6">
        <!-- At-risk queue -->
        <section class="glass-card p-5">
          <div class="flex items-center justify-between mb-4">
            <div>
              <h2 class="font-display text-lg font-bold" style="color:var(--text-primary)">At-risk queue</h2>
              <p class="text-xs mt-0.5" style="color:var(--text-tertiary)">Missing assignments &amp; integrity flags</p>
            </div>
            <% if (ops.atRiskPapers.length > 0) { %>
              <span class="tag-pill" style="background:var(--error-50);border-color:var(--error-200);color:var(--error-700)"><%= ops.atRiskPapers.length %> at risk</span>
            <% } %>
          </div>
          <% if (ops.atRiskPapers.length === 0) { %>
            <div class="empty-state py-8">
              <div class="empty-state-icon" style="background:var(--success-50);border-color:var(--success-200)">✅</div>
              <p class="text-sm font-medium" style="color:var(--text-primary)">All clear</p>
              <p class="text-xs mt-1" style="color:var(--text-tertiary)">No manuscripts need urgent attention.</p>
            </div>
          <% } else { %>
            <div class="space-y-3">
              <% ops.atRiskPapers.forEach(p => { %>
                <div class="rounded-lg p-3" style="background:var(--surface-1);border:1px solid var(--border-default)">
                  <div class="flex items-start justify-between gap-2">
                    <div class="min-w-0 flex-1">
                      <div class="font-semibold text-sm truncate" style="color:var(--text-primary)"><%= p.title %></div>
                      <div class="text-xs mt-1" style="color:var(--text-tertiary)">@<%= p.author_username || 'Unknown' %> · <%= p.assignment_count %> assigned · <%= p.completed_reviews || 0 %> done</div>
                    </div>
                    <%- include('../partials/status', { status: p.review_status }) %>
                  </div>
                  <div class="mt-2 flex gap-2">
                    <span class="score-chip text-xs">Sim <strong><%= p.similarity_score != null ? (p.similarity_score * 100).toFixed(0) + '%' : '—' %></strong></span>
                    <span class="score-chip text-xs">AI <strong><%= p.ai_text_likelihood != null ? (p.ai_text_likelihood * 100).toFixed(0) + '%' : '—' %></strong></span>
                  </div>
                </div>
              <% }) %>
            </div>
          <% } %>
        </section>

        <!-- Submission table -->
        <section class="card overflow-hidden">
          <div class="p-5" style="border-bottom:1px solid var(--border-default)">
            <h2 class="font-display text-lg font-bold" style="color:var(--text-primary)">Manuscript inventory</h2>
            <p class="text-xs mt-0.5" style="color:var(--text-tertiary)">Fast audit view of all submissions</p>
          </div>
          <div class="overflow-x-auto">
            <table class="w-full text-sm">
              <thead style="background:var(--surface-1);border-bottom:1px solid var(--border-default)">
                <tr>
                  <th class="text-left px-4 py-2.5 text-xs font-semibold uppercase tracking-wide" style="color:var(--text-tertiary)">ID</th>
                  <th class="text-left px-4 py-2.5 text-xs font-semibold uppercase tracking-wide" style="color:var(--text-tertiary)">Title</th>
                  <th class="text-left px-4 py-2.5 text-xs font-semibold uppercase tracking-wide" style="color:var(--text-tertiary)">Author</th>
                  <th class="text-left px-4 py-2.5 text-xs font-semibold uppercase tracking-wide" style="color:var(--text-tertiary)">Status</th>
                  <th class="text-right px-4 py-2.5 text-xs font-semibold uppercase tracking-wide" style="color:var(--text-tertiary)">Sim</th>
                  <th class="text-right px-4 py-2.5 text-xs font-semibold uppercase tracking-wide" style="color:var(--text-tertiary)">AI</th>
                </tr>
              </thead>
              <tbody>
                <% papers.forEach(p => { %>
                  <tr style="border-top:1px solid var(--border-subtle)" class="hover:bg-slate-50 transition-colors">
                    <td class="px-4 py-2.5 text-xs font-mono" style="color:var(--text-tertiary)">#<%= p.id %></td>
                    <td class="px-4 py-2.5">
                      <span class="font-medium text-sm truncate block max-w-[180px]" style="color:var(--text-primary)" title="<%= p.title %>"><%= p.title %></span>
                    </td>
                    <td class="px-4 py-2.5 text-sm" style="color:var(--text-secondary)">@<%= p.author_username %></td>
                    <td class="px-4 py-2.5"><%- include('../partials/status', { status: p.review_status }) %></td>
                    <td class="px-4 py-2.5 text-right text-xs font-mono" style="color:<%= p.similarity_score > 0.7 ? 'var(--error-600)' : 'var(--text-secondary)' %>">
                      <%= p.similarity_score != null ? (p.similarity_score * 100).toFixed(0) + '%' : '—' %>
                    </td>
                    <td class="px-4 py-2.5 text-right text-xs font-mono" style="color:<%= p.ai_text_likelihood > 0.6 ? 'var(--warning-600)' : 'var(--text-secondary)' %>">
                      <%= p.ai_text_likelihood != null ? (p.ai_text_likelihood * 100).toFixed(0) + '%' : '—' %>
                    </td>
                  </tr>
                <% }) %>
                <% if (papers.length === 0) { %>
                  <tr><td colspan="6" class="px-4 py-10 text-center text-sm" style="color:var(--text-tertiary)">No submissions yet.</td></tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </section>
      </div>

      <!-- AI audit table -->
      <section class="card overflow-hidden">
        <div class="p-5 flex items-center justify-between" style="border-bottom:1px solid var(--border-default)">
          <div>
            <h2 class="font-display text-lg font-bold" style="color:var(--text-primary)">AI usage audit log</h2>
            <p class="text-xs mt-0.5" style="color:var(--text-tertiary)">Every AI call categorised by action and provider</p>
          </div>
          <div class="flex items-center gap-2">
            <span class="w-2 h-2 rounded-full bg-emerald-400"></span>
            <span class="text-xs font-medium" style="color:var(--text-tertiary)">Fully logged</span>
          </div>
        </div>
        <table class="w-full text-sm">
          <thead style="background:var(--surface-1);border-bottom:1px solid var(--border-default)">
            <tr>
              <th class="text-left px-4 py-2.5 text-xs font-semibold uppercase tracking-wide" style="color:var(--text-tertiary)">Action</th>
              <th class="text-left px-4 py-2.5 text-xs font-semibold uppercase tracking-wide" style="color:var(--text-tertiary)">Provider</th>
              <th class="text-right px-4 py-2.5 text-xs font-semibold uppercase tracking-wide" style="color:var(--text-tertiary)">Calls</th>
              <th class="text-right px-4 py-2.5 text-xs font-semibold uppercase tracking-wide" style="color:var(--text-tertiary)">Share</th>
            </tr>
          </thead>
          <tbody>
            <% const totalAi = aiUsage.reduce((a, r) => a + r.n, 0); %>
            <% aiUsage.forEach(r => { %>
              <tr style="border-top:1px solid var(--border-subtle)">
                <td class="px-4 py-2.5">
                  <code class="px-2 py-0.5 rounded text-xs font-mono" style="background:var(--surface-2);color:var(--text-primary)"><%= r.action %></code>
                </td>
                <td class="px-4 py-2.5">
                  <span class="px-2 py-0.5 rounded text-xs font-mono" style="background:rgba(99,102,241,0.1);color:var(--brand-600)"><%= r.provider %></span>
                </td>
                <td class="px-4 py-2.5 text-right font-bold" style="color:var(--text-primary)"><%= r.n %></td>
                <td class="px-4 py-2.5 text-right">
                  <div class="flex items-center justify-end gap-2">
                    <div class="w-16 progress-bar">
                      <div class="progress-fill" style="width:<%= totalAi > 0 ? Math.round(r.n / totalAi * 100) : 0 %>%"></div>
                    </div>
                    <span class="text-xs w-8 text-right" style="color:var(--text-tertiary)"><%= totalAi > 0 ? Math.round(r.n / totalAi * 100) : 0 %>%</span>
                  </div>
                </td>
              </tr>
            <% }) %>
            <% if (aiUsage.length === 0) { %>
              <tr><td colspan="4" class="px-4 py-10 text-center text-sm" style="color:var(--text-tertiary)">No AI activity has been logged yet.</td></tr>
            <% } %>
          </tbody>
        </table>
      </section>
    </div>
  </main>
  <%- include('../partials/footer') %>
</body>
</html>
