<!DOCTYPE html>
<html lang="en">
<head><%- include('../partials/head') %></head>
<body class="min-h-screen bg-slate-50 text-slate-900 flex flex-col">
  <%- include('../partials/nav') %>
  <main class="flex-1">
    <div class="max-w-7xl mx-auto px-6 py-8">
      <div class="dashboard-hero mb-8">
        <div>
          <p class="eyebrow text-indigo-200">Platform command center</p>
          <h1 class="font-display text-4xl font-bold text-white mt-2">Admin dashboard</h1>
          <p class="text-sm text-slate-300 mt-2 max-w-2xl">Monitor review throughput, integrity flags, AI usage, and manuscripts that need editorial attention.</p>
        </div>
        <a href="/admin/export.xlsx" class="inline-flex items-center justify-center bg-white text-slate-950 hover:bg-indigo-50 px-4 py-2 rounded-md text-sm font-semibold transition">Export XLSX</a>
      </div>

      <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 mb-8">
        <div class="metric-card">
          <div class="stat-num text-3xl"><%= papers.length %></div>
          <div class="metric-label">Papers</div>
        </div>
        <div class="metric-card">
          <div class="stat-num text-3xl text-indigo-600"><%= ops.reviewFunnel.assignments %></div>
          <div class="metric-label">Review assignments</div>
        </div>
        <div class="metric-card">
          <div class="stat-num text-3xl text-emerald-600"><%= ops.reviewFunnel.completionRate %>%</div>
          <div class="metric-label">Completion rate</div>
        </div>
        <div class="metric-card">
          <div class="stat-num text-3xl text-amber-600"><%= aiUsage.reduce((a, r) => a + r.n, 0) %></div>
          <div class="metric-label">AI assists</div>
        </div>
      </div>

      <div class="grid lg:grid-cols-[1.2fr_0.8fr] gap-5 mb-8">
        <section class="card p-5">
          <div class="flex items-center justify-between mb-4">
            <div>
              <h2 class="font-display text-xl font-semibold">Submission pipeline</h2>
              <p class="text-xs text-slate-500 mt-1">Status distribution across all manuscripts.</p>
            </div>
            <span class="text-xs font-semibold text-slate-500"><%= papers.length %> total</span>
          </div>
          <div class="space-y-3">
            <% ops.statusBreakdown.forEach(item => { %>
              <div>
                <div class="flex justify-between text-sm mb-1">
                  <span class="capitalize text-slate-700"><%= item.status.replace('_', ' ') %></span>
                  <span class="font-semibold"><%= item.count %> / <%= item.percent %>%</span>
                </div>
                <div class="h-2 rounded-full bg-slate-100 overflow-hidden">
                  <div class="h-full rounded-full bg-indigo-600" style="width: <%= item.percent %>%"></div>
                </div>
              </div>
            <% }) %>
          </div>
        </section>

        <section class="card p-5">
          <h2 class="font-display text-xl font-semibold">Integrity snapshot</h2>
          <p class="text-xs text-slate-500 mt-1 mb-4">Flags are triage signals, not automated decisions.</p>
          <div class="grid grid-cols-2 gap-3">
            <div class="rounded-md border border-rose-100 bg-rose-50 p-4">
              <div class="stat-num text-3xl text-rose-700"><%= ops.integritySnapshot.highSimilarity %></div>
              <div class="metric-label text-rose-900">High similarity</div>
            </div>
            <div class="rounded-md border border-amber-100 bg-amber-50 p-4">
              <div class="stat-num text-3xl text-amber-700"><%= ops.integritySnapshot.highAiLikelihood %></div>
              <div class="metric-label text-amber-900">AI likelihood</div>
            </div>
            <div class="rounded-md border border-slate-200 bg-white p-4">
              <div class="stat-num text-3xl"><%= ops.integritySnapshot.avgSimilarity %>%</div>
              <div class="metric-label">Avg similarity</div>
            </div>
            <div class="rounded-md border border-slate-200 bg-white p-4">
              <div class="stat-num text-3xl"><%= ops.integritySnapshot.avgAiLikelihood %>%</div>
              <div class="metric-label">Avg AI signal</div>
            </div>
          </div>
        </section>
      </div>

      <div class="grid lg:grid-cols-[0.9fr_1.1fr] gap-5 mb-8">
        <section class="card p-5">
          <h2 class="font-display text-xl font-semibold">At-risk queue</h2>
          <p class="text-xs text-slate-500 mt-1 mb-4">Open manuscripts sorted by missing assignments and integrity flags.</p>
          <% if (ops.atRiskPapers.length === 0) { %>
            <p class="text-sm text-slate-500">No active risks right now.</p>
          <% } %>
          <div class="space-y-3">
            <% ops.atRiskPapers.forEach(p => { %>
              <div class="rounded-md border border-slate-200 bg-slate-50 p-3">
                <div class="flex items-start justify-between gap-3">
                  <div>
                    <div class="font-semibold text-sm"><%= p.title %></div>
                    <div class="text-xs text-slate-500 mt-1">by <%= p.author_username || 'Unknown' %> - <%= p.assignment_count %> assigned - <%= p.completed_reviews || 0 %> complete</div>
                  </div>
                  <%- include('../partials/status', { status: p.review_status }) %>
                </div>
                <div class="mt-2 text-xs text-slate-500">Similarity <%= (p.similarity_score * 100).toFixed(0) %>% - AI signal <%= (p.ai_text_likelihood * 100).toFixed(0) %>%</div>
              </div>
            <% }) %>
          </div>
        </section>

        <section class="card overflow-hidden">
          <div class="p-5 border-b border-slate-200">
            <h2 class="font-display text-xl font-semibold">All submissions</h2>
            <p class="text-xs text-slate-500 mt-1">Fast audit view of the manuscript inventory.</p>
          </div>
          <div class="overflow-x-auto">
            <table class="w-full text-sm">
              <thead class="bg-slate-50 border-b border-slate-200">
                <tr>
                  <th class="text-left px-3 py-2 font-medium text-slate-600">ID</th>
                  <th class="text-left px-3 py-2 font-medium text-slate-600">Title</th>
                  <th class="text-left px-3 py-2 font-medium text-slate-600">Author</th>
                  <th class="text-left px-3 py-2 font-medium text-slate-600">Status</th>
                  <th class="text-right px-3 py-2 font-medium text-slate-600">Sim</th>
                  <th class="text-right px-3 py-2 font-medium text-slate-600">AI</th>
                </tr>
              </thead>
              <tbody>
                <% papers.forEach(p => { %>
                  <tr class="border-t border-slate-100 hover:bg-slate-50">
                    <td class="px-3 py-2 text-slate-500"><%= p.id %></td>
                    <td class="px-3 py-2 font-medium"><%= p.title %></td>
                    <td class="px-3 py-2"><%= p.author_username %></td>
                    <td class="px-3 py-2"><%- include('../partials/status', { status: p.review_status }) %></td>
                    <td class="px-3 py-2 text-right"><%= (p.similarity_score * 100).toFixed(0) %>%</td>
                    <td class="px-3 py-2 text-right"><%= (p.ai_text_likelihood * 100).toFixed(0) %>%</td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </section>
      </div>

      <section class="card overflow-hidden">
        <div class="p-5 border-b border-slate-200 flex items-center justify-between">
          <div>
            <h2 class="font-display text-xl font-semibold">AI usage by action</h2>
            <p class="text-xs text-slate-500 mt-1">Provider-level transparency for every assistive workflow.</p>
          </div>
          <div class="text-xs text-slate-500">Scores avg: novelty <%= ops.reviewFunnel.averageScores.novelty %>, clarity <%= ops.reviewFunnel.averageScores.clarity %>, significance <%= ops.reviewFunnel.averageScores.significance %></div>
        </div>
        <table class="w-full text-sm">
          <thead class="bg-slate-50 border-b border-slate-200">
            <tr>
              <th class="text-left px-3 py-2 font-medium text-slate-600">Action</th>
              <th class="text-left px-3 py-2 font-medium text-slate-600">Provider</th>
              <th class="text-right px-3 py-2 font-medium text-slate-600">Calls</th>
            </tr>
          </thead>
          <tbody>
            <% aiUsage.forEach(r => { %>
              <tr class="border-t border-slate-100">
                <td class="px-3 py-2"><code class="bg-slate-100 px-1.5 py-0.5 rounded text-xs"><%= r.action %></code></td>
                <td class="px-3 py-2"><code class="bg-slate-100 px-1.5 py-0.5 rounded text-xs"><%= r.provider %></code></td>
                <td class="px-3 py-2 text-right font-semibold"><%= r.n %></td>
              </tr>
            <% }) %>
            <% if (aiUsage.length === 0) { %>
              <tr><td colspan="3" class="px-3 py-8 text-center text-sm text-slate-500">No AI activity has been logged yet.</td></tr>
            <% } %>
          </tbody>
        </table>
      </section>
    </div>
  </main>
  <%- include('../partials/footer') %>
</body>
</html>
