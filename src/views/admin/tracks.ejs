<!DOCTYPE html>
<html lang="en">
<head><%- include('../partials/head') %></head>
<body class="min-h-screen flex flex-col" style="background:var(--surface-0);color:var(--text-primary)">
  <%- include('../partials/nav') %>
  <main class="flex-1">
    <div class="max-w-5xl mx-auto px-6 py-10">
      <div class="flex items-center justify-between mb-8">
        <div>
          <a href="/admin" class="text-indigo-600 hover:text-indigo-500 text-sm">← Admin dashboard</a>
          <h1 class="font-display text-3xl font-bold mt-1">Conference Tracks</h1>
        </div>
        <button id="openNewTrackBtn"
          class="bg-indigo-600 hover:bg-indigo-700 text-white px-4 py-2 rounded-md text-sm font-medium">
          + New track
        </button>
      </div>

      <% if (tracks.length === 0) { %>
        <div class="glass-card p-12 text-center text-slate-500">
          <p>No tracks yet. Create one to organize submissions by topic or session.</p>
        </div>
      <% } else { %>
        <div class="space-y-4">
          <% tracks.forEach(track => { %>
          <div class="glass-card p-6">
            <div class="flex items-start justify-between gap-4">
              <div class="flex-1">
                <div class="flex items-center gap-3">
                  <h3 class="font-semibold text-lg"><%= track.name %></h3>
                  <span class="px-2 py-0.5 rounded-full text-xs font-medium <%= track.is_active ? 'bg-emerald-100 text-emerald-700' : 'bg-slate-100 text-slate-500' %>">
                    <%= track.is_active ? 'Active' : 'Inactive' %>
                  </span>
                </div>
                <% if (track.description) { %><p class="text-slate-600 text-sm mt-1"><%= track.description %></p><% } %>
                <div class="flex flex-wrap gap-4 mt-3 text-xs text-slate-500">
                  <% if (track.submission_deadline) { %>
                    <span>Submission deadline: <strong class="text-slate-700"><%= new Date(track.submission_deadline).toLocaleString() %></strong></span>
                  <% } %>
                  <% if (track.review_deadline) { %>
                    <span>Review deadline: <strong class="text-slate-700"><%= new Date(track.review_deadline).toLocaleString() %></strong></span>
                  <% } %>
                </div>
              </div>
              <div class="flex gap-2 shrink-0">
                <button data-track="<%= JSON.stringify(track) %>"
                  class="edit-track-btn text-xs text-indigo-600 hover:text-indigo-700 font-medium px-3 py-1.5 border border-indigo-200 rounded-md">Edit</button>
                <form method="post" action="/admin/tracks/<%= track.id %>/delete" onsubmit="return confirm('Delete this track? Papers assigned to it will be untracked.')">
                  <button type="submit" class="text-xs text-red-600 hover:text-red-700 font-medium px-3 py-1.5 border border-red-200 rounded-md">Delete</button>
                </form>
              </div>
            </div>
          </div>
          <% }) %>
        </div>
      <% } %>
    </div>
  </main>

  <!-- New track modal -->
  <div id="newTrackModal" class="hidden fixed inset-0 bg-black/50 z-50 flex items-center justify-center p-4"
    role="dialog" aria-modal="true" aria-labelledby="newTrackModalTitle">
    <div class="bg-white rounded-xl shadow-xl w-full max-w-lg p-6">
      <h2 id="newTrackModalTitle" class="font-semibold text-lg mb-4">New track</h2>
      <form method="post" action="/admin/tracks" class="space-y-4">
        <div>
          <label for="newTrackName" class="block text-sm font-medium text-slate-700 mb-1">Track name <span class="text-red-500" aria-hidden="true">*</span></label>
          <input id="newTrackName" name="name" required class="w-full border border-slate-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:border-indigo-500">
        </div>
        <div>
          <label for="newTrackDesc" class="block text-sm font-medium text-slate-700 mb-1">Description</label>
          <textarea id="newTrackDesc" name="description" rows="2" class="w-full border border-slate-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:border-indigo-500"></textarea>
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label for="newTrackSubDl" class="block text-sm font-medium text-slate-700 mb-1">Submission deadline</label>
            <input type="datetime-local" id="newTrackSubDl" name="submissionDeadline" class="w-full border border-slate-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:border-indigo-500">
          </div>
          <div>
            <label for="newTrackRevDl" class="block text-sm font-medium text-slate-700 mb-1">Review deadline</label>
            <input type="datetime-local" id="newTrackRevDl" name="reviewDeadline" class="w-full border border-slate-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:border-indigo-500">
          </div>
        </div>
        <div class="flex gap-3 pt-2">
          <button type="submit" class="bg-indigo-600 text-white px-5 py-2 rounded-md text-sm font-medium hover:bg-indigo-700">Create</button>
          <button type="button" id="closeNewTrackBtn"
            class="px-5 py-2 border border-slate-300 rounded-md text-sm text-slate-700 hover:bg-slate-50">Cancel</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Edit track modal -->
  <div id="editTrackModal" class="hidden fixed inset-0 bg-black/50 z-50 flex items-center justify-center p-4"
    role="dialog" aria-modal="true" aria-labelledby="editTrackModalTitle">
    <div class="bg-white rounded-xl shadow-xl w-full max-w-lg p-6">
      <h2 id="editTrackModalTitle" class="font-semibold text-lg mb-4">Edit track</h2>
      <form method="post" id="editTrackForm" class="space-y-4">
        <div>
          <label for="editName" class="block text-sm font-medium text-slate-700 mb-1">Track name <span class="text-red-500" aria-hidden="true">*</span></label>
          <input name="name" id="editName" required class="w-full border border-slate-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:border-indigo-500">
        </div>
        <div>
          <label for="editDesc" class="block text-sm font-medium text-slate-700 mb-1">Description</label>
          <textarea name="description" id="editDesc" rows="2" class="w-full border border-slate-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:border-indigo-500"></textarea>
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label for="editSubDl" class="block text-sm font-medium text-slate-700 mb-1">Submission deadline</label>
            <input type="datetime-local" name="submissionDeadline" id="editSubDl" class="w-full border border-slate-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:border-indigo-500">
          </div>
          <div>
            <label for="editRevDl" class="block text-sm font-medium text-slate-700 mb-1">Review deadline</label>
            <input type="datetime-local" name="reviewDeadline" id="editRevDl" class="w-full border border-slate-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:border-indigo-500">
          </div>
        </div>
        <div class="flex items-center gap-2">
          <input type="checkbox" name="isActive" id="editActive" value="1" class="rounded">
          <label for="editActive" class="text-sm text-slate-700">Track is active (accepts submissions)</label>
        </div>
        <div class="flex gap-3 pt-2">
          <button type="submit" class="bg-indigo-600 text-white px-5 py-2 rounded-md text-sm font-medium hover:bg-indigo-700">Save changes</button>
          <button type="button" id="closeEditTrackBtn"
            class="px-5 py-2 border border-slate-300 rounded-md text-sm text-slate-700 hover:bg-slate-50">Cancel</button>
        </div>
      </form>
    </div>
  </div>

  <%- include('../partials/footer') %>
  <script>
    let newCleanup = null, editCleanup = null;

    function openModal(modal, trigger) {
      modal.classList.remove('hidden');
      return window.trapFocus(modal, trigger);
    }
    function closeModal(modal, cleanup) {
      modal.classList.add('hidden');
      if (cleanup) cleanup();
    }
    function bindEsc(modal, closeFn) {
      modal.addEventListener('keydown', function esc(e) {
        if (e.key === 'Escape') { closeFn(); modal.removeEventListener('keydown', esc); }
      });
    }

    document.getElementById('openNewTrackBtn').addEventListener('click', function() {
      const modal = document.getElementById('newTrackModal');
      newCleanup = openModal(modal, this);
      bindEsc(modal, () => { newCleanup = null; closeModal(modal, newCleanup); document.getElementById('openNewTrackBtn').focus(); });
    });
    document.getElementById('closeNewTrackBtn').addEventListener('click', function() {
      closeModal(document.getElementById('newTrackModal'), newCleanup);
      newCleanup = null;
    });

    function openEditModal(track, trigger) {
      document.getElementById('editTrackForm').action = `/admin/tracks/${track.id}`;
      document.getElementById('editName').value = track.name || '';
      document.getElementById('editDesc').value = track.description || '';
      document.getElementById('editSubDl').value = track.submission_deadline ? track.submission_deadline.slice(0, 16) : '';
      document.getElementById('editRevDl').value = track.review_deadline ? track.review_deadline.slice(0, 16) : '';
      document.getElementById('editActive').checked = !!track.is_active;
      const modal = document.getElementById('editTrackModal');
      editCleanup = openModal(modal, trigger);
      bindEsc(modal, () => { closeModal(modal, editCleanup); editCleanup = null; });
    }
    document.getElementById('closeEditTrackBtn').addEventListener('click', function() {
      closeModal(document.getElementById('editTrackModal'), editCleanup);
      editCleanup = null;
    });

    document.querySelectorAll('.edit-track-btn').forEach(btn => {
      btn.addEventListener('click', () => openEditModal(JSON.parse(btn.dataset.track), btn));
    });
  </script>
</body>
</html>
