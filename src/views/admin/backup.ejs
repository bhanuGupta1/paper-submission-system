<!DOCTYPE html>
<html lang="en">
<head><%- include('../partials/head') %></head>
<body class="min-h-screen flex flex-col" style="background:var(--surface-0);color:var(--text-primary)">
  <%- include('../partials/nav') %>
  <main class="flex-1">
    <div class="max-w-4xl mx-auto px-6 py-10">

      <div class="flex items-center justify-between mb-8">
        <div>
          <a href="/admin" class="text-sm" style="color:var(--brand-500)">← Admin dashboard</a>
          <h1 class="font-display text-3xl font-extrabold mt-1 gradient-text">Database backups</h1>
          <p class="text-sm mt-1" style="color:var(--text-tertiary)">SQLite backups run daily at 02:00. Max 14 retained. Trigger a manual backup anytime.</p>
        </div>
        <form method="post" action="/admin/backup">
          <button class="btn-gradient shimmer-btn">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"/></svg>
            Back up now
          </button>
        </form>
      </div>

      <% if (success) { %>
        <div class="alert alert-success mb-5" role="alert">
          <svg class="w-4 h-4 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          <span><%= success %></span>
        </div>
      <% } %>
      <% if (error) { %>
        <div class="alert alert-warning mb-5" role="alert">
          <svg class="w-4 h-4 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          <span><%= error %></span>
        </div>
      <% } %>

      <div class="glass-card gradient-border-card overflow-hidden">
        <% if (backups.length === 0) { %>
          <div class="p-12 text-center" style="color:var(--text-tertiary)">
            <svg class="w-12 h-12 mx-auto mb-4 opacity-30" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 19a2 2 0 01-2-2V7a2 2 0 012-2h4l2 2h4a2 2 0 012 2v1M5 19h14a2 2 0 002-2v-5a2 2 0 00-2-2H9a2 2 0 00-2 2v5a2 2 0 01-2 2z"/></svg>
            <p class="font-semibold">No backups yet</p>
            <p class="text-sm mt-1">Click "Back up now" to create the first snapshot.</p>
          </div>
        <% } else { %>
          <table class="w-full text-sm" role="grid" aria-label="Backup files">
            <thead>
              <tr class="border-b" style="border-color:var(--border-default);background:var(--surface-1)">
                <th class="px-5 py-3 text-left font-semibold" style="color:var(--text-secondary)">Filename</th>
                <th class="px-5 py-3 text-right font-semibold" style="color:var(--text-secondary)">Size</th>
                <th class="px-5 py-3 text-right font-semibold" style="color:var(--text-secondary)">Created</th>
                <th class="px-5 py-3"></th>
              </tr>
            </thead>
            <tbody>
              <% backups.forEach((b, i) => { %>
              <tr class="border-b <%= i === 0 ? '' : '' %>" style="border-color:var(--border-default)">
                <td class="px-5 py-3 font-mono text-xs" style="color:var(--text-primary)">
                  <% if (i === 0) { %><span class="inline-flex items-center gap-1.5 mr-2"><span class="w-1.5 h-1.5 rounded-full bg-emerald-400" aria-hidden="true"></span><span class="text-xs font-semibold" style="color:var(--success-700)">Latest</span></span><% } %>
                  <%= b.name %>
                </td>
                <td class="px-5 py-3 text-right tabular-nums" style="color:var(--text-secondary)"><%= (b.size / 1024).toFixed(1) %> KB</td>
                <td class="px-5 py-3 text-right" style="color:var(--text-secondary)"><%= new Date(b.createdAt).toLocaleString() %></td>
                <td class="px-5 py-3 text-right">
                  <a href="/admin/backup/download/<%= encodeURIComponent(b.name) %>" class="text-xs font-semibold" style="color:var(--brand-500)">Download</a>
                </td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        <% } %>
      </div>

      <p class="text-xs mt-4" style="color:var(--text-tertiary)">
        Backups are stored in <code class="px-1 rounded" style="background:var(--surface-2)">data/backups/</code>.
        Keep copies off-server for disaster recovery. Older backups beyond the retention limit are pruned automatically.
      </p>

    </div>
  </main>
  <%- include('../partials/footer') %>
</body>
</html>
