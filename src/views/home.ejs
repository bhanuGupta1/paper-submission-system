<!DOCTYPE html>
<html lang="en">
<head><%- include('partials/head') %></head>
<body class="min-h-screen flex flex-col overflow-x-hidden" style="background:var(--surface-0);color:var(--text-primary)">
  <%- include('partials/nav') %>

  <main class="flex-1">
    <section class="home-hero relative min-h-screen flex items-center justify-center overflow-hidden">
      <!-- Architectural photo-simulation background layers -->
      <div class="arch-bg" aria-hidden="true"></div>
      <div class="arch-rays" aria-hidden="true"></div>
      <span class="arch-shimmer arch-shimmer-a" aria-hidden="true"></span>
      <span class="arch-shimmer arch-shimmer-b" aria-hidden="true"></span>
      <div class="arch-vignette" aria-hidden="true"></div>
      <div class="absolute inset-0 pointer-events-none hero-grid"></div>

      <div class="relative z-10 max-w-6xl mx-auto px-6 py-24 text-center">
        <div class="inline-flex items-center gap-2 rounded-full px-4 py-2 glass-card text-sm font-semibold">
          <span class="pulse-dot"></span>
          <span style="color:var(--text-primary)">Now with AI-powered review matching</span>
        </div>

        <h1 class="font-display mx-auto mt-8 max-w-5xl text-[clamp(3.5rem,8vw,7.5rem)] font-extrabold leading-[0.88] gradient-text">
          Academic publishing, accelerated.
        </h1>

        <p class="mt-7 text-xl sm:text-2xl font-medium" style="color:var(--text-secondary)">
          Built for <span id="cycleWord" class="word-cycle gradient-text font-extrabold">peer review</span>
        </p>

        <p class="mt-6 max-w-2xl mx-auto text-base sm:text-lg leading-8" style="color:var(--text-secondary)">
          PaperSub.AI combines manuscript submission, reviewer matching, conflict detection, decision workflows, and public publishing in one elegant system.
        </p>

        <div class="mt-10 flex flex-wrap justify-center gap-4">
          <% if (!currentUser) { %>
            <a href="/register" class="btn-gradient shimmer-btn">
              Start free
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
            </a>
            <a href="/login" class="btn-ghost-premium">Sign in</a>
          <% } else if (currentUser.role === 'author') { %>
            <a href="/author/submit" class="btn-gradient shimmer-btn">Submit a paper</a>
            <a href="/author" class="btn-ghost-premium">My papers</a>
          <% } else if (currentUser.role === 'reviewer') { %>
            <a href="/reviewer" class="btn-gradient shimmer-btn">My assignments</a>
            <a href="/reader" class="btn-ghost-premium">Browse papers</a>
          <% } else if (currentUser.role === 'editor' || currentUser.role === 'admin') { %>
            <a href="/editor" class="btn-gradient shimmer-btn">Editorial desk</a>
            <a href="/reader" class="btn-ghost-premium">Browse papers</a>
          <% } else { %>
            <a href="/reader" class="btn-gradient shimmer-btn">Browse published work</a>
          <% } %>
        </div>

        <div class="stats-glass mx-auto mt-12 grid max-w-3xl grid-cols-1 sm:grid-cols-3 gap-3 p-3">
          <div class="px-6 py-4">
            <div class="font-display text-3xl font-extrabold gradient-text">2,400+</div>
            <div class="mt-1 text-xs font-bold uppercase tracking-[0.14em]" style="color:var(--text-tertiary)">Papers</div>
          </div>
          <div class="px-6 py-4">
            <div class="font-display text-3xl font-extrabold gradient-text">840</div>
            <div class="mt-1 text-xs font-bold uppercase tracking-[0.14em]" style="color:var(--text-tertiary)">Reviewers</div>
          </div>
          <div class="px-6 py-4">
            <div class="font-display text-3xl font-extrabold gradient-text">99.9%</div>
            <div class="mt-1 text-xs font-bold uppercase tracking-[0.14em]" style="color:var(--text-tertiary)">Uptime</div>
          </div>
        </div>
      </div>
    </section>

    <section class="marquee-strip overflow-hidden py-5">
      <div class="marquee-track">
        <% ['Nature','Science','IEEE','ACM','Elsevier','Springer','Nature','Science','IEEE','ACM','Elsevier','Springer'].forEach(name => { %>
          <span class="marquee-badge"><%= name %></span>
        <% }) %>
      </div>
    </section>

    <section class="relative overflow-hidden px-6 py-24">
      <div class="max-w-7xl mx-auto">
        <div class="text-center mb-14">
          <p class="eyebrow" style="color:var(--brand-500)">Editorial infrastructure</p>
          <h2 class="font-display mt-3 text-4xl sm:text-5xl font-extrabold" style="color:var(--text-primary)">Everything the paper lifecycle needs.</h2>
          <p class="mt-4 max-w-2xl mx-auto" style="color:var(--text-secondary)">A polished control plane for authors, reviewers, editors, and administrators.</p>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5">
          <article class="feature-card gradient-border-card glass-card p-7">
            <div class="feature-icon"><svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v12m6-6H6"/></svg></div>
            <h3 class="font-display text-xl font-bold mt-5">Submission intake</h3>
            <p class="mt-3 text-sm leading-7" style="color:var(--text-secondary)">Authors upload manuscripts, manage metadata, and track decision timelines without losing context.</p>
          </article>
          <article class="feature-card gradient-border-card glass-card p-7">
            <div class="feature-icon"><svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg></div>
            <h3 class="font-display text-xl font-bold mt-5">Structured review</h3>
            <p class="mt-3 text-sm leading-7" style="color:var(--text-secondary)">Reviewer cockpit, rubric scoring, deadlines, and AI-drafted scaffolds stay tied to the manuscript record.</p>
          </article>
          <article class="feature-card gradient-border-card glass-card p-7">
            <div class="feature-icon"><svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg></div>
            <h3 class="font-display text-xl font-bold mt-5">AI matching</h3>
            <p class="mt-3 text-sm leading-7" style="color:var(--text-secondary)">Expertise signals and conflict checks help editors choose reviewers with better evidence.</p>
          </article>
          <article class="feature-card gradient-border-card glass-card p-7">
            <div class="feature-icon"><svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6m6 0V7a2 2 0 012-2h2a2 2 0 012 2v10m-6 0h6m0 0V9a2 2 0 012-2h2a2 2 0 012 2v8"/></svg></div>
            <h3 class="font-display text-xl font-bold mt-5">Integrity metrics</h3>
            <p class="mt-3 text-sm leading-7" style="color:var(--text-secondary)">Similarity scores, AI text likelihood, and operational analytics are visible without becoming black boxes.</p>
          </article>
          <article class="feature-card gradient-border-card glass-card p-7">
            <div class="feature-icon"><svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg></div>
            <h3 class="font-display text-xl font-bold mt-5">Audit trail</h3>
            <p class="mt-3 text-sm leading-7" style="color:var(--text-secondary)">Every review, decision, AI suggestion, and workflow action can be traced back to a responsible user.</p>
          </article>
          <article class="feature-card gradient-border-card glass-card p-7">
            <div class="feature-icon"><svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg></div>
            <h3 class="font-display text-xl font-bold mt-5">Public publishing</h3>
            <p class="mt-3 text-sm leading-7" style="color:var(--text-secondary)">Accepted papers flow into a clean reader experience with downloads and role-aware access boundaries.</p>
          </article>
        </div>
      </div>
    </section>

  </main>

  <script>
    (function() {
      const node = document.getElementById('cycleWord');
      if (!node) return;
      const words = ['peer review', 'collaboration', 'publishing'];
      let index = 0;
      setInterval(function() {
        node.classList.remove('word-cycle');
        node.classList.add('word-cycle-out');
        setTimeout(function() {
          index = (index + 1) % words.length;
          node.textContent = words[index];
          node.classList.remove('word-cycle-out');
          node.classList.add('word-cycle');
        }, 220);
      }, 2500);
    })();
  </script>
  <%- include('partials/footer') %>
</body>
</html>
