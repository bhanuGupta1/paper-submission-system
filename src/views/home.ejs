<!DOCTYPE html>
<html lang="en">
<head><%- include('partials/head') %></head>
<body class="min-h-screen bg-slate-50 text-slate-900 flex flex-col">
  <%- include('partials/nav') %>
  <main class="flex-1">
    <section class="hero-grad text-white">
      <div class="max-w-7xl mx-auto px-6 py-20 md:py-28">
        <div class="max-w-3xl">
          <span class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-white/10 text-indigo-100 border border-white/15 text-xs font-semibold">
            <span class="h-1.5 w-1.5 rounded-full bg-emerald-300"></span>
            Research operations, peer review, and AI governance in one product
          </span>
          <h1 class="font-display text-5xl md:text-7xl font-bold tracking-tight mt-6 leading-[0.98]">
            PaperSub.AI
          </h1>
          <p class="mt-5 text-xl text-slate-200 max-w-2xl leading-relaxed">
            A polished academic submission platform with reviewer matching, conflict-of-interest intelligence, integrity screening, AI-assisted reviews, audit trails, and public publishing.
          </p>
          <div class="mt-8 flex flex-wrap gap-3">
            <a href="/reader" class="bg-white text-slate-950 hover:bg-indigo-50 px-5 py-2.5 rounded-md font-semibold shadow-sm transition">Browse articles</a>
            <% if (!currentUser) { %>
              <a href="/register" class="bg-indigo-500 hover:bg-indigo-400 text-white px-5 py-2.5 rounded-md font-semibold shadow-sm transition">Create account</a>
              <a href="/login" class="bg-white/10 border border-white/20 hover:bg-white/15 text-white px-5 py-2.5 rounded-md font-semibold transition">Sign in</a>
            <% } else if (currentUser.role === 'author') { %>
              <a href="/author/submit" class="bg-indigo-500 hover:bg-indigo-400 text-white px-5 py-2.5 rounded-md font-semibold shadow-sm transition">Submit a paper</a>
            <% } %>
          </div>
        </div>

        <div class="grid md:grid-cols-4 gap-3 mt-14 max-w-5xl">
          <div class="bg-white/10 border border-white/15 rounded-md p-4 backdrop-blur">
            <div class="stat-num text-3xl text-cyan-200">5</div>
            <div class="text-xs uppercase tracking-wider text-slate-300 mt-1">Role dashboards</div>
          </div>
          <div class="bg-white/10 border border-white/15 rounded-md p-4 backdrop-blur">
            <div class="stat-num text-3xl text-emerald-200">COI</div>
            <div class="text-xs uppercase tracking-wider text-slate-300 mt-1">Conflict signals</div>
          </div>
          <div class="bg-white/10 border border-white/15 rounded-md p-4 backdrop-blur">
            <div class="stat-num text-3xl text-indigo-200">AI</div>
            <div class="text-xs uppercase tracking-wider text-slate-300 mt-1">Audited assists</div>
          </div>
          <div class="bg-white/10 border border-white/15 rounded-md p-4 backdrop-blur">
            <div class="stat-num text-3xl text-amber-200">0</div>
            <div class="text-xs uppercase tracking-wider text-slate-300 mt-1">API keys required</div>
          </div>
        </div>
      </div>
    </section>

    <section class="feature-band">
      <div class="max-w-7xl mx-auto px-6 py-16">
        <div class="grid lg:grid-cols-[0.9fr_1.1fr] gap-10 items-start">
          <div>
            <p class="eyebrow text-indigo-700">End-to-end workflow</p>
            <h2 class="font-display text-4xl font-bold mt-2">A complete editorial system, not a demo shell.</h2>
            <p class="text-slate-600 mt-4 leading-relaxed">The platform covers the full manuscript lifecycle: submission, enrichment, reviewer matching, review drafting, editorial decisions, notifications, exports, and public reader access.</p>
          </div>
          <div class="grid md:grid-cols-2 gap-5">
            <div class="process-step">
              <h3 class="font-semibold">Submit</h3>
              <p class="text-sm text-slate-600 mt-1">Authors upload manuscripts and use local AI assists for titles, keywords, and abstract polish.</p>
            </div>
            <div class="process-step">
              <h3 class="font-semibold">Screen</h3>
              <p class="text-sm text-slate-600 mt-1">The system records similarity and AI-text signals as transparent triage markers.</p>
            </div>
            <div class="process-step">
              <h3 class="font-semibold">Match</h3>
              <p class="text-sm text-slate-600 mt-1">Editors get ranked reviewers with conflict-of-interest warnings before assignment.</p>
            </div>
            <div class="process-step">
              <h3 class="font-semibold">Publish</h3>
              <p class="text-sm text-slate-600 mt-1">Accepted papers flow into a clean public feed with secure access boundaries.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="max-w-7xl mx-auto px-6 py-16">
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-4">
        <div class="card p-6">
          <div class="h-10 w-10 rounded-md bg-indigo-100 text-indigo-700 flex items-center justify-center font-bold">A</div>
          <h3 class="font-display font-semibold mt-4 text-lg">Author workspace</h3>
          <p class="text-sm text-slate-600 mt-2 leading-relaxed">Submission tracking, integrity signals, decision history, and manuscript downloads.</p>
        </div>
        <div class="card p-6">
          <div class="h-10 w-10 rounded-md bg-cyan-100 text-cyan-700 flex items-center justify-center font-bold">R</div>
          <h3 class="font-display font-semibold mt-4 text-lg">Reviewer cockpit</h3>
          <p class="text-sm text-slate-600 mt-2 leading-relaxed">Assignments, completion metrics, structured scoring, and AI draft insertion.</p>
        </div>
        <div class="card p-6">
          <div class="h-10 w-10 rounded-md bg-amber-100 text-amber-700 flex items-center justify-center font-bold">E</div>
          <h3 class="font-display font-semibold mt-4 text-lg">Editor intelligence</h3>
          <p class="text-sm text-slate-600 mt-2 leading-relaxed">Reviewer recommendations, COI badges, manual overrides, and final decisions.</p>
        </div>
        <div class="card p-6">
          <div class="h-10 w-10 rounded-md bg-emerald-100 text-emerald-700 flex items-center justify-center font-bold">O</div>
          <h3 class="font-display font-semibold mt-4 text-lg">Operations layer</h3>
          <p class="text-sm text-slate-600 mt-2 leading-relaxed">Admin analytics, exports, health checks, and auditable AI usage records.</p>
        </div>
      </div>
    </section>
  </main>
  <%- include('partials/footer') %>
</body>
</html>
