<!DOCTYPE html>
<html lang="en">
<head><%- include('partials/head') %></head>
<body class="min-h-screen bg-slate-50 text-slate-900 flex flex-col">
  <%- include('partials/nav') %>
  <main class="flex-1">

    <!-- ── Hero ──────────────────────────────────────────────────────────── -->
    <section class="hero-grad text-white relative overflow-hidden">
      <!-- Background grid overlay -->
      <div class="absolute inset-0 pointer-events-none" style="background-image:url(\"data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' stroke='%23ffffff' stroke-opacity='0.04' stroke-width='1'%3E%3Cpath d='M0 30h60M30 0v60'/%3E%3C/g%3E%3C/svg%3E\")"></div>

      <div class="max-w-7xl mx-auto px-6 pt-20 pb-24 md:pt-28 md:pb-32 relative">
        <div class="max-w-4xl">
          <!-- Badge -->
          <span class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-white/10 text-indigo-100 border border-white/15 text-xs font-semibold backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-emerald-400 shadow-lg shadow-emerald-400/50" style="animation: badge-pulse 2s ease-in-out infinite"></span>
            Peer-review infrastructure with auditable AI governance
          </span>

          <!-- Headline -->
          <h1 class="font-display font-extrabold tracking-tight mt-6" style="font-size: clamp(2.75rem, 7vw, 5.5rem); line-height: 0.96; letter-spacing: -0.04em">
            Academic publishing<br>
            <span style="background: linear-gradient(135deg, #a5b4fc 0%, #22d3ee 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">reimagined.</span>
          </h1>

          <!-- Subheadline -->
          <p class="mt-6 text-xl leading-relaxed max-w-2xl" style="color: rgba(226,232,240,0.88)">
            PaperSub.AI is a full editorial platform — submission tracking, AI-matched peer review, conflict-of-interest detection, integrity screening, and public publishing in one cohesive system.
          </p>

          <!-- CTAs -->
          <div class="mt-8 flex flex-wrap gap-3">
            <a href="/reader" class="btn btn-lg" style="background:rgba(255,255,255,0.95); color:#0f172a; box-shadow:0 4px 16px rgba(0,0,0,0.2)">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
              Browse published work
            </a>
            <% if (!currentUser) { %>
              <a href="/register" class="btn btn-lg btn-primary" style="box-shadow: 0 4px 16px rgba(99,102,241,0.4)">
                Get started free
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
              </a>
              <a href="/login" class="btn btn-lg" style="background:rgba(255,255,255,0.10); border:1px solid rgba(255,255,255,0.18); color:white; backdrop-filter:blur(8px)">Sign in</a>
            <% } else if (currentUser.role === 'author') { %>
              <a href="/author/submit" class="btn btn-lg btn-primary" style="box-shadow: 0 4px 16px rgba(99,102,241,0.4)">
                Submit a paper
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
              </a>
              <a href="/author" class="btn btn-lg" style="background:rgba(255,255,255,0.10); border:1px solid rgba(255,255,255,0.18); color:white">My papers</a>
            <% } else if (currentUser.role === 'reviewer') { %>
              <a href="/reviewer" class="btn btn-lg btn-primary">My assignments</a>
            <% } else if (currentUser.role === 'editor' || currentUser.role === 'admin') { %>
              <a href="/editor" class="btn btn-lg btn-primary">Editorial desk</a>
            <% } %>
          </div>
        </div>

        <!-- Stats row -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mt-16 max-w-3xl">
          <div class="hero-panel p-5">
            <div class="stat-num text-3xl" style="color:#a5f3fc">5</div>
            <div class="text-xs uppercase tracking-wider mt-2" style="color:rgba(148,163,184,0.9); font-weight:600; letter-spacing:0.08em">Role views</div>
          </div>
          <div class="hero-panel p-5">
            <div class="stat-num text-3xl" style="color:#a7f3d0">COI</div>
            <div class="text-xs uppercase tracking-wider mt-2" style="color:rgba(148,163,184,0.9); font-weight:600; letter-spacing:0.08em">Conflict signals</div>
          </div>
          <div class="hero-panel p-5">
            <div class="stat-num text-3xl" style="color:#c7d2fe">AI</div>
            <div class="text-xs uppercase tracking-wider mt-2" style="color:rgba(148,163,184,0.9); font-weight:600; letter-spacing:0.08em">Audited assists</div>
          </div>
          <div class="hero-panel p-5">
            <div class="stat-num text-3xl" style="color:#fde68a">0</div>
            <div class="text-xs uppercase tracking-wider mt-2" style="color:rgba(148,163,184,0.9); font-weight:600; letter-spacing:0.08em">API keys needed</div>
          </div>
        </div>
      </div>
    </section>

    <!-- ── Editorial workflow ─────────────────────────────────────────────── -->
    <section class="feature-band">
      <div class="max-w-7xl mx-auto px-6 py-20">
        <div class="text-center mb-14">
          <p class="eyebrow" style="color: var(--brand-600)">End-to-end workflow</p>
          <h2 class="font-display text-4xl font-bold mt-3">A complete editorial system, not a demo.</h2>
          <p class="mt-4 max-w-xl mx-auto" style="color:var(--text-secondary)">Every step of the manuscript lifecycle in one coherent, production-grade system.</p>
        </div>
        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-5">
          <div class="process-step relative">
            <div class="process-step-accent"></div>
            <div class="w-9 h-9 rounded-lg flex items-center justify-center text-white font-bold text-sm mb-4" style="background:linear-gradient(135deg,var(--brand-600),var(--brand-400))">1</div>
            <h3 class="font-display font-bold text-lg">Submit</h3>
            <p class="text-sm mt-2 leading-relaxed" style="color:var(--text-secondary)">Authors upload PDFs with AI-assisted title, keyword, and abstract refinement before submission enters review.</p>
          </div>
          <div class="process-step relative">
            <div class="process-step-accent"></div>
            <div class="w-9 h-9 rounded-lg flex items-center justify-center text-white font-bold text-sm mb-4" style="background:linear-gradient(135deg,var(--accent-600),var(--accent-400))">2</div>
            <h3 class="font-display font-bold text-lg">Screen</h3>
            <p class="text-sm mt-2 leading-relaxed" style="color:var(--text-secondary)">Similarity scoring and AI-text likelihood are computed as transparent triage signals, never as automated rejections.</p>
          </div>
          <div class="process-step relative">
            <div class="process-step-accent"></div>
            <div class="w-9 h-9 rounded-lg flex items-center justify-center text-white font-bold text-sm mb-4" style="background:linear-gradient(135deg,#7c3aed,#a78bfa)">3</div>
            <h3 class="font-display font-bold text-lg">Match</h3>
            <p class="text-sm mt-2 leading-relaxed" style="color:var(--text-secondary)">AI ranks reviewers by expertise match, flags conflict-of-interest pairs, and suggests assignments to editors.</p>
          </div>
          <div class="process-step relative">
            <div class="process-step-accent"></div>
            <div class="w-9 h-9 rounded-lg flex items-center justify-center text-white font-bold text-sm mb-4" style="background:linear-gradient(135deg,#059669,#34d399)">4</div>
            <h3 class="font-display font-bold text-lg">Publish</h3>
            <p class="text-sm mt-2 leading-relaxed" style="color:var(--text-secondary)">Accepted papers flow into a public reader feed with download controls and role-based access boundaries.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ── Role cards ─────────────────────────────────────────────────────── -->
    <section class="max-w-7xl mx-auto px-6 py-20">
      <div class="text-center mb-14">
        <p class="eyebrow" style="color: var(--brand-600)">Role-aware dashboards</p>
        <h2 class="font-display text-4xl font-bold mt-3">Built for everyone in the workflow.</h2>
        <p class="mt-4 max-w-xl mx-auto" style="color:var(--text-secondary)">Every participant sees exactly what they need — nothing more, nothing less.</p>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-5">
        <div class="card p-6 group transition-all duration-200 hover:shadow-lg hover:-translate-y-1">
          <div class="w-11 h-11 rounded-xl flex items-center justify-center mb-5" style="background:linear-gradient(135deg,var(--brand-50),var(--brand-100));border:1px solid var(--brand-200)">
            <svg class="w-5 h-5" style="color:var(--brand-600)" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
          </div>
          <h3 class="font-display font-bold text-base">Author workspace</h3>
          <p class="text-sm mt-2 leading-relaxed" style="color:var(--text-secondary)">Submission tracking, integrity signals, revision history, decision timeline, and manuscript downloads.</p>
          <% if (!currentUser || currentUser.role === 'author') { %>
            <a href="<%= currentUser ? '/author' : '/register' %>" class="inline-flex items-center gap-1 mt-4 text-sm font-semibold link-line" style="color:var(--brand-600)">
              <%= currentUser ? 'Go to workspace' : 'Register as author' %>
              <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
            </a>
          <% } %>
        </div>

        <div class="card p-6 group transition-all duration-200 hover:shadow-lg hover:-translate-y-1">
          <div class="w-11 h-11 rounded-xl flex items-center justify-center mb-5" style="background:linear-gradient(135deg,rgba(6,182,212,0.08),rgba(6,182,212,0.16));border:1px solid rgba(6,182,212,0.25)">
            <svg class="w-5 h-5 text-cyan-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          </div>
          <h3 class="font-display font-bold text-base">Reviewer cockpit</h3>
          <p class="text-sm mt-2 leading-relaxed" style="color:var(--text-secondary)">Deadline-aware assignment cards, structured rubric scoring, AI draft insertion, and completion records.</p>
          <% if (!currentUser || currentUser.role === 'reviewer') { %>
            <a href="<%= currentUser ? '/reviewer' : '/register' %>" class="inline-flex items-center gap-1 mt-4 text-sm font-semibold link-line text-cyan-700">
              <%= currentUser ? 'View assignments' : 'Register as reviewer' %>
              <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
            </a>
          <% } %>
        </div>

        <div class="card p-6 group transition-all duration-200 hover:shadow-lg hover:-translate-y-1">
          <div class="w-11 h-11 rounded-xl flex items-center justify-center mb-5" style="background:linear-gradient(135deg,rgba(245,158,11,0.08),rgba(245,158,11,0.16));border:1px solid rgba(245,158,11,0.25)">
            <svg class="w-5 h-5 text-amber-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
          </div>
          <h3 class="font-display font-bold text-base">Editor intelligence</h3>
          <p class="text-sm mt-2 leading-relaxed" style="color:var(--text-secondary)">Ranked reviewer suggestions, COI badges, semantic search, bulk assignment, and final decisions.</p>
        </div>

        <div class="card p-6 group transition-all duration-200 hover:shadow-lg hover:-translate-y-1">
          <div class="w-11 h-11 rounded-xl flex items-center justify-center mb-5" style="background:linear-gradient(135deg,rgba(16,185,129,0.08),rgba(16,185,129,0.16));border:1px solid rgba(16,185,129,0.25)">
            <svg class="w-5 h-5 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
          </div>
          <h3 class="font-display font-bold text-base">Operations center</h3>
          <p class="text-sm mt-2 leading-relaxed" style="color:var(--text-secondary)">Submission pipeline analytics, integrity snapshots, at-risk manuscript queue, XLSX exports, and health checks.</p>
        </div>
      </div>
    </section>

    <!-- ── AI features ────────────────────────────────────────────────────── -->
    <section class="feature-band">
      <div class="max-w-7xl mx-auto px-6 py-20">
        <div class="grid lg:grid-cols-[0.48fr_0.52fr] gap-16 items-center">
          <div>
            <p class="eyebrow" style="color:var(--brand-600)">AI-augmented, not AI-controlled</p>
            <h2 class="font-display text-4xl font-bold mt-3">AI features with full transparency.</h2>
            <p class="mt-4 leading-relaxed" style="color:var(--text-secondary)">Every AI call is logged to an auditable trail. Every suggestion has a confidence score. Every action has a human override. No black boxes.</p>
            <div class="mt-8 space-y-4">
              <div class="flex items-start gap-3">
                <div class="w-6 h-6 rounded-full flex items-center justify-center shrink-0 mt-0.5" style="background:var(--success-50);border:1px solid var(--success-200)">
                  <svg class="w-3.5 h-3.5 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                </div>
                <div>
                  <div class="font-semibold text-sm" style="color:var(--text-primary)">Abstract polishing &amp; title generation</div>
                  <div class="text-sm mt-0.5" style="color:var(--text-secondary)">Claude-powered writing assistance for authors before submission.</div>
                </div>
              </div>
              <div class="flex items-start gap-3">
                <div class="w-6 h-6 rounded-full flex items-center justify-center shrink-0 mt-0.5" style="background:var(--success-50);border:1px solid var(--success-200)">
                  <svg class="w-3.5 h-3.5 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                </div>
                <div>
                  <div class="font-semibold text-sm" style="color:var(--text-primary)">Semantic reviewer matching</div>
                  <div class="text-sm mt-0.5" style="color:var(--text-secondary)">Embeddings match paper topics to reviewer expertise profiles.</div>
                </div>
              </div>
              <div class="flex items-start gap-3">
                <div class="w-6 h-6 rounded-full flex items-center justify-center shrink-0 mt-0.5" style="background:var(--success-50);border:1px solid var(--success-200)">
                  <svg class="w-3.5 h-3.5 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                </div>
                <div>
                  <div class="font-semibold text-sm" style="color:var(--text-primary)">AI-drafted review scaffolds</div>
                  <div class="text-sm mt-0.5" style="color:var(--text-secondary)">Reviewers get structured drafts to edit — AI assists, humans decide.</div>
                </div>
              </div>
              <div class="flex items-start gap-3">
                <div class="w-6 h-6 rounded-full flex items-center justify-center shrink-0 mt-0.5" style="background:var(--success-50);border:1px solid var(--success-200)">
                  <svg class="w-3.5 h-3.5 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                </div>
                <div>
                  <div class="font-semibold text-sm" style="color:var(--text-primary)">Conflict-of-interest detection</div>
                  <div class="text-sm mt-0.5" style="color:var(--text-secondary)">Affiliation and co-authorship signals flag potential reviewer conflicts.</div>
                </div>
              </div>
            </div>
          </div>

          <!-- Feature card grid -->
          <div class="grid grid-cols-2 gap-4">
            <div class="card p-5" style="border-top:3px solid var(--brand-500)">
              <div class="text-2xl mb-2">🔍</div>
              <div class="font-bold text-sm" style="color:var(--text-primary)">Integrity screening</div>
              <div class="text-xs mt-1.5" style="color:var(--text-secondary)">Similarity &amp; AI-text scores as transparent triage signals.</div>
            </div>
            <div class="card p-5" style="border-top:3px solid var(--accent-500)">
              <div class="text-2xl mb-2">🎯</div>
              <div class="font-bold text-sm" style="color:var(--text-primary)">Smart search</div>
              <div class="text-xs mt-1.5" style="color:var(--text-secondary)">Semantic vector search across the full manuscript corpus.</div>
            </div>
            <div class="card p-5" style="border-top:3px solid #7c3aed">
              <div class="text-2xl mb-2">📊</div>
              <div class="font-bold text-sm" style="color:var(--text-primary)">Acceptance predictor</div>
              <div class="text-xs mt-1.5" style="color:var(--text-secondary)">Confidence scores to help editors weigh editorial evidence.</div>
            </div>
            <div class="card p-5" style="border-top:3px solid #059669">
              <div class="text-2xl mb-2">🔒</div>
              <div class="font-bold text-sm" style="color:var(--text-primary)">Audit trail</div>
              <div class="text-xs mt-1.5" style="color:var(--text-secondary)">Every AI call, review, and decision logged with full attribution.</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ── CTA ───────────────────────────────────────────────────────────── -->
    <section class="max-w-7xl mx-auto px-6 py-20">
      <div class="card text-center p-12 relative overflow-hidden" style="background:linear-gradient(135deg,var(--brand-950),var(--brand-900));border-color:var(--brand-800)">
        <div class="absolute inset-0 pointer-events-none opacity-30" style="background-image:url(\"data:image/svg+xml,%3Csvg width='40' height='40' viewBox='0 0 40 40' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' stroke='%23ffffff' stroke-opacity='0.08' stroke-width='1'%3E%3Cpath d='M0 20h40M20 0v40'/%3E%3C/g%3E%3C/svg%3E\")"></div>
        <div class="relative">
          <p class="eyebrow text-indigo-300">Ready to start</p>
          <h2 class="font-display text-4xl font-bold mt-3 text-white">Launch your research workflow today.</h2>
          <p class="mt-4 max-w-lg mx-auto text-indigo-200">No credit card. No API keys required. Full platform access from day one.</p>
          <div class="mt-8 flex flex-wrap gap-3 justify-center">
            <% if (!currentUser) { %>
              <a href="/register" class="btn btn-lg" style="background:white;color:#1e1b4b;box-shadow:0 4px 16px rgba(0,0,0,0.3)">
                Create free account
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
              </a>
              <a href="/reader" class="btn btn-lg" style="background:rgba(255,255,255,0.10);border:1px solid rgba(255,255,255,0.2);color:white">Browse published papers</a>
            <% } else { %>
              <a href="/<%= currentUser.role %>" class="btn btn-lg" style="background:white;color:#1e1b4b">Go to dashboard</a>
            <% } %>
          </div>
        </div>
      </div>
    </section>

  </main>
  <%- include('partials/footer') %>
</body>
</html>
