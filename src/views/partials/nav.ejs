<nav class="bg-slate-950/95 backdrop-blur border-b border-slate-800 sticky top-0 z-40">
  <div class="max-w-7xl mx-auto px-6 py-3 flex items-center justify-between">
    <a href="/" class="flex items-center gap-2 text-slate-100">
      <span class="inline-flex h-7 w-7 items-center justify-center rounded-md bg-indigo-500/20 text-indigo-300 text-sm font-bold">P</span>
      <span class="font-semibold tracking-tight text-base">PaperSub<span class="text-indigo-400">.AI</span></span>
    </a>
    <div class="flex items-center gap-1 text-sm">
      <a class="px-3 py-1.5 rounded-md text-slate-300 hover:text-white hover:bg-slate-800 transition" href="/reader">Read</a>
      <% if (currentUser) { %>
        <% if (currentUser.role === 'author') { %>
          <a class="px-3 py-1.5 rounded-md text-slate-300 hover:text-white hover:bg-slate-800 transition" href="/author">Papers</a>
          <a class="px-3 py-1.5 rounded-md text-slate-300 hover:text-white hover:bg-slate-800 transition" href="/author/submit">Submit</a>
        <% } %>
        <% if (currentUser.role === 'reviewer') { %>
          <a class="px-3 py-1.5 rounded-md text-slate-300 hover:text-white hover:bg-slate-800 transition" href="/reviewer">Reviews</a>
        <% } %>
        <% if (currentUser.role === 'editor') { %>
          <a class="px-3 py-1.5 rounded-md text-slate-300 hover:text-white hover:bg-slate-800 transition" href="/editor">Editor</a>
        <% } %>
        <% if (currentUser.role === 'admin') { %>
          <a class="px-3 py-1.5 rounded-md text-slate-300 hover:text-white hover:bg-slate-800 transition" href="/admin">Admin</a>
          <a class="px-3 py-1.5 rounded-md text-slate-300 hover:text-white hover:bg-slate-800 transition" href="/editor">Editor</a>
        <% } %>
        <a class="relative px-3 py-1.5 rounded-md text-slate-300 hover:text-white hover:bg-slate-800 transition" href="/notifications">
          Inbox
          <% if (unreadCount > 0) { %>
            <span class="absolute -top-1 -right-1 inline-flex items-center justify-center min-w-[18px] h-[18px] px-1 rounded-full bg-rose-500 text-white text-[10px] font-bold"><%= unreadCount %></span>
          <% } %>
        </a>
        <% if (currentUser.role === 'author') { %>
          <a class="px-3 py-1.5 rounded-md text-slate-300 hover:text-white hover:bg-slate-800 transition" href="/author/profile">Profile</a>
        <% } %>
        <span class="ml-2 text-xs text-slate-500 hidden sm:inline">@<%= currentUser.username %></span>
        <a class="px-3 py-1.5 rounded-md text-rose-300 hover:text-rose-200 hover:bg-rose-500/10 transition" href="/logout">Sign out</a>
      <% } else { %>
        <a class="px-3 py-1.5 rounded-md text-slate-300 hover:text-white hover:bg-slate-800 transition" href="/login">Sign in</a>
        <a class="ml-2 bg-indigo-500 hover:bg-indigo-400 text-white px-4 py-1.5 rounded-md font-medium transition" href="/register">Create account</a>
      <% } %>
    </div>
  </div>
</nav>
