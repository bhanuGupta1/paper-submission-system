<!-- Skip navigation (WCAG 2.1 AA - 2.4.1) -->
<a href="#main-content" class="skip-link">Skip to main content</a>

<!-- Global toast notification container -->
<div id="toast-container" class="fixed top-4 right-4 z-[100] flex flex-col gap-2 pointer-events-none" aria-live="polite"></div>

<!-- Session timeout warning -->
<div id="session-warning" class="hidden fixed inset-x-0 top-0 z-[90] bg-amber-500 text-white text-sm px-4 py-2 flex items-center justify-between" role="alert">
  <span>Your session will expire in <strong id="session-countdown">5:00</strong>. Please save your work.</span>
  <button onclick="extendSession()" class="ml-4 underline font-medium hover:no-underline">Extend session</button>
</div>

<nav class="nav-shell sticky top-0 z-40 backdrop-blur">
  <div class="max-w-7xl mx-auto px-6 py-3 flex flex-wrap items-center justify-between gap-3">
    <a href="/" class="flex items-center gap-3" aria-label="PaperSub.AI home">
      <span class="brand-mark inline-flex h-8 w-8 items-center justify-center rounded-md text-sm font-black text-white" aria-hidden="true">P</span>
      <span class="nav-logo-text font-semibold tracking-tight text-base">PaperSub<span class="nav-logo-accent">.AI</span></span>
    </a>
    <div class="flex flex-wrap items-center justify-end gap-1 text-sm">
      <a class="nav-link" href="/reader">Read</a>
      <a class="nav-link" href="/guidelines">Guidelines</a>
      <% if (currentUser) { %>
        <% if (currentUser.role === 'author') { %>
          <a class="nav-link" href="/author">Papers</a>
          <a class="nav-link" href="/author/submit">Submit</a>
          <a class="nav-link" href="/author/profile">Profile</a>
        <% } %>
        <% if (currentUser.role === 'reviewer') { %>
          <a class="nav-link" href="/reviewer">Reviews</a>
        <% } %>
        <% if (currentUser.role === 'editor') { %>
          <a class="nav-link" href="/editor">Editor</a>
        <% } %>
        <% if (currentUser.role === 'admin') { %>
          <a class="nav-link" href="/admin">Admin</a>
          <a class="nav-link" href="/admin/users">Users</a>
          <a class="nav-link" href="/editor">Editor</a>
        <% } %>
        <a class="nav-link relative" href="/notifications" aria-label="Inbox<%= unreadCount > 0 ? `, ${unreadCount} unread` : '' %>">
          Inbox
          <% if (unreadCount > 0) { %>
            <span class="notif-badge absolute -top-1 -right-1 inline-flex items-center justify-center min-w-[18px] h-[18px] px-1 rounded-full bg-rose-500 text-white text-[10px] font-bold" aria-hidden="true"><%= unreadCount %></span>
          <% } %>
        </a>
        <button id="darkToggle" class="dark-toggle" title="Toggle dark mode" aria-label="Toggle dark mode" role="switch" aria-checked="false">
          <span class="dark-toggle-thumb"></span>
        </button>
        <span class="nav-user-label ml-2 text-xs hidden sm:inline" aria-label="Logged in as <%= currentUser.username %>">@<%= currentUser.username %></span>
        <a class="nav-link nav-signout hover:bg-rose-500/10" href="/logout">Sign out</a>
      <% } else { %>
        <button id="darkToggle" class="dark-toggle" title="Toggle dark mode" aria-label="Toggle dark mode" role="switch" aria-checked="false">
          <span class="dark-toggle-thumb"></span>
        </button>
        <a class="nav-link" href="/login">Sign in</a>
        <a class="nav-cta ml-1 font-semibold hover:opacity-95" href="/register">Create account</a>
      <% } %>
    </div>
  </div>
</nav>

<script>
// ── Toast system ──────────────────────────────────────────────────────────────
window.showToast = function(message, type = 'info', duration = 4000) {
  const container = document.getElementById('toast-container');
  const colors = { success: 'bg-emerald-600', error: 'bg-red-600', warning: 'bg-amber-500', info: 'bg-slate-800' };
  const icons = { success: '✓', error: '✕', warning: '⚠', info: 'ℹ' };
  const toast = document.createElement('div');
  toast.className = `pointer-events-auto flex items-center gap-2 px-4 py-3 rounded-lg shadow-lg text-white text-sm font-medium max-w-sm transition-all opacity-0 translate-y-2 ${colors[type] || colors.info}`;
  toast.setAttribute('role', 'status');
  toast.innerHTML = `<span class="shrink-0">${icons[type] || icons.info}</span><span>${message}</span>`;
  container.appendChild(toast);
  requestAnimationFrame(() => { toast.style.opacity = '1'; toast.style.transform = 'translateY(0)'; });
  setTimeout(() => {
    toast.style.opacity = '0';
    toast.style.transform = 'translateY(-8px)';
    setTimeout(() => toast.remove(), 300);
  }, duration);
};

// ── Dark mode ─────────────────────────────────────────────────────────────────
(function() {
  function applyTheme(dark) {
    if (dark) {
      document.documentElement.classList.add('dark');
      localStorage.setItem('theme', 'dark');
    } else {
      document.documentElement.classList.remove('dark');
      localStorage.setItem('theme', 'light');
    }
    var btn = document.getElementById('darkToggle');
    if (btn) btn.setAttribute('aria-checked', dark ? 'true' : 'false');
  }

  // Expose globally so onclick attrs still work as fallback
  window.toggleDark = function() {
    applyTheme(!document.documentElement.classList.contains('dark'));
  };

  // Wire via addEventListener (works even when onclick attr is CSP-blocked)
  var btn = document.getElementById('darkToggle');
  if (btn) {
    btn.addEventListener('click', window.toggleDark);
    // Sync initial visual state
    btn.setAttribute('aria-checked', document.documentElement.classList.contains('dark') ? 'true' : 'false');
  }
})();

// ── Real-time notification badge polling (every 30s) ─────────────────────────
<% if (currentUser) { %>
(function() {
  const POLL_INTERVAL = 30000;
  const badge = document.querySelector('[aria-label^="Inbox"]');
  if (!badge) return;
  async function pollUnread() {
    try {
      const r = await fetch('/notifications/unread-count', { headers: { 'X-Requested-With': 'XMLHttpRequest' } });
      if (!r.ok) return;
      const data = await r.json();
      const count = data.count || 0;
      let dot = badge.querySelector('.notif-badge');
      if (count > 0) {
        if (!dot) {
          dot = document.createElement('span');
          dot.className = 'notif-badge absolute -top-1 -right-1 inline-flex items-center justify-center min-w-[18px] h-[18px] px-1 rounded-full bg-rose-500 text-white text-[10px] font-bold';
          dot.setAttribute('aria-hidden', 'true');
          badge.style.position = 'relative';
          badge.appendChild(dot);
        }
        dot.textContent = count;
        badge.setAttribute('aria-label', 'Inbox, ' + count + ' unread');
      } else if (dot) {
        dot.remove();
        badge.setAttribute('aria-label', 'Inbox');
      }
    } catch (_) {}
  }
  pollUnread();
  setInterval(pollUnread, POLL_INTERVAL);
})();
<% } %>

// ── Session timeout warning (client-side, 8h max age with 5-min warning) ─────
<% if (currentUser) { %>
(function() {
  const SESSION_MS = 8 * 60 * 60 * 1000;
  const WARNING_MS = 5 * 60 * 1000;
  const startedAt = parseInt(sessionStorage.getItem('sessionStart') || '0', 10) || Date.now();
  if (!sessionStorage.getItem('sessionStart')) sessionStorage.setItem('sessionStart', String(startedAt));
  const remaining = SESSION_MS - (Date.now() - startedAt);
  const warningAt = remaining - WARNING_MS;
  if (warningAt > 0) setTimeout(startWarning, warningAt);
  else if (remaining > 0) startWarning();

  function startWarning() {
    const warn = document.getElementById('session-warning');
    const countdown = document.getElementById('session-countdown');
    if (!warn) return;
    warn.classList.remove('hidden');
    let secs = Math.max(0, Math.floor((SESSION_MS - (Date.now() - startedAt)) / 1000));
    const iv = setInterval(() => {
      secs = Math.max(0, secs - 1);
      const m = Math.floor(secs / 60), s = secs % 60;
      countdown.textContent = `${m}:${s.toString().padStart(2, '0')}`;
      if (secs <= 0) clearInterval(iv);
    }, 1000);
  }
  window.extendSession = function() {
    sessionStorage.setItem('sessionStart', String(Date.now()));
    fetch('/health').catch(() => {});
    document.getElementById('session-warning').classList.add('hidden');
    showToast('Session extended', 'success');
  };
})();
<% } %>

// ── Accessibility utilities ───────────────────────────────────────────────────
// Auto-assign id + tabindex to <main> so the skip link has a target
(function() {
  var main = document.querySelector('main');
  if (main && !main.id) { main.id = 'main-content'; main.setAttribute('tabindex', '-1'); }
})();

// Focus trap for modals: call trapFocus(dialogEl, triggerEl) on open,
// returned cleanup fn on close.
window.trapFocus = function(el, trigger) {
  var FOCUSABLE = 'a[href],button:not([disabled]),input:not([disabled]),select:not([disabled]),textarea:not([disabled]),[tabindex]:not([tabindex="-1"]),details>summary';
  var nodes = Array.from(el.querySelectorAll(FOCUSABLE));
  if (!nodes.length) return function() {};
  nodes[0].focus();
  function handler(e) {
    if (e.key !== 'Tab') return;
    var first = nodes[0], last = nodes[nodes.length - 1];
    if (e.shiftKey) { if (document.activeElement === first) { e.preventDefault(); last.focus(); } }
    else            { if (document.activeElement === last)  { e.preventDefault(); first.focus(); } }
  }
  el.addEventListener('keydown', handler);
  return function() { el.removeEventListener('keydown', handler); if (trigger) trigger.focus(); };
};
</script>
