<%
  const _status = locals.status || '';
  const _statusMap = {
    pending: { color: 'bg-slate-100 text-slate-700 border-slate-200', label: 'Pending' },
    under_review: { color: 'bg-amber-50 text-amber-800 border-amber-200', label: 'Under review' },
    accepted: { color: 'bg-emerald-50 text-emerald-800 border-emerald-200', label: 'Accepted' },
    rejected: { color: 'bg-rose-50 text-rose-800 border-rose-200', label: 'Rejected' },
    revisions: { color: 'bg-indigo-50 text-indigo-800 border-indigo-200', label: 'Revisions' },
  };
  const _s = _statusMap[_status] || { color: 'bg-slate-100 text-slate-700 border-slate-200', label: _status };
%>
<span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium border <%= _s.color %>"><%= _s.label %></span>
