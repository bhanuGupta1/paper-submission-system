<%
  const _status = locals.status || '';
  const _statusMap = {
    pending:      { cls: 'badge-pending',   label: 'Pending' },
    under_review: { cls: 'badge-review',    label: 'Under review' },
    accepted:     { cls: 'badge-accepted',  label: 'Accepted' },
    rejected:     { cls: 'badge-rejected',  label: 'Rejected' },
    revisions:    { cls: 'badge-revisions', label: 'Revisions' },
  };
  const _s = _statusMap[_status] || { cls: 'badge-pending', label: _status || '—' };
%>
<span class="badge <%= _s.cls %>"><%= _s.label %></span>
