<!DOCTYPE html>
<html lang="en">
<head><%- include('../partials/head') %></head>
<body class="min-h-screen flex flex-col" style="background:var(--surface-0);color:var(--text-primary)">
  <%- include('../partials/nav') %>
  <main class="flex-1">

    <!-- Search hero with mesh background -->
    <section class="relative overflow-hidden" style="min-height:22rem">
      <div class="mesh-bg" aria-hidden="true">
        <span class="mesh-blob mesh-blob-one"></span>
        <span class="mesh-blob mesh-blob-two"></span>
        <span class="mesh-blob mesh-blob-three"></span>
      </div>
      <div class="absolute inset-0 pointer-events-none hero-grid"></div>

      <div class="relative z-10 max-w-4xl mx-auto px-6 py-20 text-center">
        <div class="inline-flex items-center gap-2 rounded-full px-4 py-2 glass-card text-sm font-semibold mb-6">
          <span class="pulse-dot"></span>
          <span style="color:var(--text-primary)">Open access research</span>
        </div>
        <h1 class="font-display text-5xl sm:text-6xl font-extrabold gradient-text leading-tight">Published articles</h1>
        <p class="mt-4 text-lg max-w-xl mx-auto" style="color:var(--text-secondary)">Accepted manuscripts freely available. Search across titles, abstracts, authors, and keywords.</p>

        <form method="get" action="/reader" class="max-w-2xl mx-auto mt-8">
          <div class="flex flex-col sm:flex-row gap-3">
            <div class="flex-1 relative">
              <svg class="absolute left-4 top-1/2 -translate-y-1/2 w-4 h-4 pointer-events-none" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="color:var(--text-tertiary)"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
              <input name="q" value="<%= q %>" placeholder="Search title, author, abstract, keywords…"
                class="auth-input block w-full rounded-xl border pl-11 pr-4 py-3 text-sm"
                style="background:rgba(255,255,255,0.85);border-color:rgba(255,255,255,0.3);color:#0f172a">
            </div>
            <button class="btn-gradient shimmer-btn px-7">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
              Search
            </button>
          </div>
        </form>
      </div>
    </section>

    <!-- Results -->
    <div class="max-w-7xl mx-auto px-6 py-10">
      <% if (q) { %>
        <div class="flex items-center justify-between mb-6">
          <p class="text-sm" style="color:var(--text-secondary)">
            <strong style="color:var(--text-primary)"><%= papers.length %></strong> result<%= papers.length !== 1 ? 's' : '' %> for "<strong style="color:var(--text-primary)"><%= q %></strong>"
          </p>
          <a href="/reader" class="btn btn-sm btn-ghost text-sm">Clear search</a>
        </div>
      <% } else { %>
        <div class="mb-8 flex items-end justify-between">
          <div>
            <p class="eyebrow" style="color:var(--brand-500)">Library</p>
            <h2 class="font-display text-3xl font-extrabold mt-1" style="color:var(--text-primary)">Latest published work</h2>
          </div>
          <p class="text-sm pb-1" style="color:var(--text-tertiary)"><%= papers.length %> paper<%= papers.length !== 1 ? 's' : '' %></p>
        </div>
      <% } %>

      <% if (papers.length === 0) { %>
        <div class="glass-card p-16 text-center">
          <div class="inline-flex h-16 w-16 items-center justify-center rounded-2xl mb-5" style="background:linear-gradient(135deg,rgba(99,102,241,0.15),rgba(6,182,212,0.10));border:1px solid rgba(99,102,241,0.2)">
            <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="color:var(--brand-500)"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
          </div>
          <h2 class="font-display text-3xl font-extrabold mt-3" style="color:var(--text-primary)"><%= q ? 'No matching articles.' : 'Library opening soon.' %></h2>
          <p class="mt-3 max-w-md mx-auto" style="color:var(--text-secondary)"><%= q ? 'Try a broader search term or clear your query.' : 'Accepted papers will appear here automatically.' %></p>
          <% if (q) { %><a href="/reader" class="btn-gradient shimmer-btn mt-7">Clear search</a><% } %>
        </div>
      <% } else { %>
        <div class="grid md:grid-cols-2 xl:grid-cols-3 gap-5">
          <% papers.forEach(p => { %>
            <article class="glass-card gradient-border-card p-6 flex flex-col group transition-all duration-200 hover:-translate-y-1">
              <!-- Meta row -->
              <div class="flex items-center justify-between gap-2 mb-4">
                <span class="status-pill" style="background:rgba(5,150,105,0.12);color:#059669;border:1px solid rgba(5,150,105,0.25)">Published</span>
                <span class="text-xs" style="color:var(--text-tertiary)"><%= new Date(p.submission_date).toLocaleDateString('en', {year:'numeric',month:'short',day:'numeric'}) %></span>
              </div>

              <!-- Title -->
              <h2 class="font-display text-xl font-extrabold leading-snug" style="color:var(--text-primary)"><%= p.title %></h2>
              <div class="text-xs mt-2" style="color:var(--text-tertiary)">By <%= p.authors %></div>

              <!-- Abstract excerpt -->
              <p class="text-sm mt-4 flex-1 leading-relaxed line-clamp-4" style="color:var(--text-secondary)"><%= p.abstract %></p>

              <!-- Keywords -->
              <% if (p.keywords) { %>
                <div class="mt-4 flex flex-wrap gap-1.5">
                  <% p.keywords.split(',').slice(0, 5).forEach(k => { %>
                    <span class="score-chip text-xs"><%= k.trim() %></span>
                  <% }) %>
                </div>
              <% } %>

              <!-- AI summary -->
              <% if (p.ai_summary) { %>
                <div class="mt-4 p-3 rounded-xl text-xs leading-relaxed" style="background:rgba(99,102,241,0.06);border:1px solid rgba(99,102,241,0.15);color:var(--text-secondary)">
                  <span class="font-semibold" style="color:var(--brand-500)">AI summary: </span><%= p.ai_summary %>
                </div>
              <% } %>

              <!-- Action -->
              <div class="flex items-center justify-between mt-5 pt-4" style="border-top:1px solid var(--border-default)">
                <div class="text-xs" style="color:var(--text-tertiary)">
                  <% if (p.tags) { %><span class="score-chip"><%= p.tags.split(',')[0].trim() %></span><% } %>
                </div>
                <a href="/reader/papers/<%= p.id %>/download" class="btn-gradient shimmer-btn text-xs px-4 py-2">
                  <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
                  Download
                </a>
              </div>
            </article>
          <% }) %>
        </div>
      <% } %>
    </div>

  </main>
  <%- include('../partials/footer') %>
</body>
</html>
