<!DOCTYPE html>
<html lang="en">
<head><%- include('../partials/head') %></head>
<body class="min-h-screen bg-slate-50 text-slate-900 flex flex-col">
  <%- include('../partials/nav') %>
  <main class="flex-1">
    <section class="hero-grad">
      <div class="max-w-5xl mx-auto px-6 py-12 text-center">
        <h1 class="font-display text-4xl md:text-5xl font-bold leading-tight">Published articles</h1>
        <p class="text-slate-600 mt-3 max-w-xl mx-auto">Public feed of accepted papers — no account needed.</p>
        <form method="get" action="/reader" class="max-w-xl mx-auto mt-6">
          <div class="flex gap-2">
            <input name="q" value="<%= q %>" placeholder="Search title, abstract, keywords…" class="flex-1 rounded-md border border-slate-300 bg-white px-4 py-2.5 focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 focus:outline-none">
            <button class="bg-indigo-600 hover:bg-indigo-500 text-white px-5 rounded-md font-medium transition">Search</button>
          </div>
        </form>
      </div>
    </section>

    <div class="max-w-6xl mx-auto px-6 py-10">
      <% if (papers.length === 0) { %>
        <p class="text-center text-slate-500"><%= q ? 'No matching articles found.' : 'No published articles yet.' %></p>
      <% } %>
      <div class="grid md:grid-cols-2 gap-4">
        <% papers.forEach(p => { %>
          <article class="card p-6 hover:shadow-md transition">
            <h2 class="font-display text-xl font-bold leading-snug"><%= p.title %></h2>
            <div class="text-xs text-slate-500 mt-1 mb-3">By <%= p.authors %> · Published <%= new Date(p.submission_date).toLocaleDateString() %></div>
            <p class="text-sm text-slate-700 line-clamp-4 leading-relaxed"><%= p.abstract %></p>
            <% if (p.keywords) { %>
              <div class="mt-4 flex flex-wrap gap-1.5">
                <% p.keywords.split(',').slice(0, 5).forEach(k => { %>
                  <span class="inline-block text-xs bg-slate-100 text-slate-700 px-2 py-0.5 rounded-full"><%= k.trim() %></span>
                <% }) %>
              </div>
            <% } %>
            <div class="flex items-center justify-end mt-4">
              <a href="/reader/papers/<%= p.id %>/download" class="text-sm bg-indigo-600 hover:bg-indigo-500 text-white px-3 py-1.5 rounded-md font-medium transition">Download full article</a>
            </div>
          </article>
        <% }) %>
      </div>
    </div>
  </main>
  <%- include('../partials/footer') %>
</body>
</html>
