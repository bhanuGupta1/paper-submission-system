<!DOCTYPE html>
<html lang="en">
<head><%- include('../partials/head') %></head>
<body class="min-h-screen flex flex-col" style="background:var(--surface-0);color:var(--text-primary)">
  <%- include('../partials/nav') %>
  <main class="flex-1">
    <div class="max-w-7xl mx-auto px-6 py-8">
      <a href="/editor" class="text-sm text-indigo-600 hover:text-indigo-500 link-line">Back to editor dashboard</a>
      <div class="dashboard-hero mt-4 mb-6">
        <div>
          <p class="eyebrow text-indigo-200">Audit trail</p>
          <h1 class="font-display text-4xl font-bold text-white mt-2 leading-tight"><%= paper.title %></h1>
          <p class="text-sm text-slate-300 mt-2">Complete transparency record for editorial decisions, reviews, and AI activity.</p>
        </div>
        <%- include('../partials/status', { status: paper.review_status }) %>
      </div>

      <div class="grid md:grid-cols-3 gap-3 mb-6">
        <div class="metric-card">
          <div class="metric-label">Status</div>
          <div class="mt-2"><%- include('../partials/status', { status: paper.review_status }) %></div>
        </div>
        <div class="metric-card">
          <div class="metric-label">Reviews</div>
          <div class="stat-num text-3xl mt-1"><%= reviews.length %></div>
        </div>
        <div class="metric-card">
          <div class="metric-label">AI calls logged</div>
          <div class="stat-num text-3xl mt-1"><%= aiCalls.length %></div>
        </div>
      </div>

      <div class="grid lg:grid-cols-[0.45fr_0.55fr] gap-6">
        <section class="space-y-6">
          <div class="glass-card p-5">
            <h2 class="font-display text-xl font-semibold mb-3">Decision history</h2>
            <% if (!decisions.length) { %>
              <p class="text-sm text-slate-500">No decisions recorded.</p>
            <% } else { %>
              <div class="space-y-3">
                <% decisions.forEach(d => { %>
                  <div class="rounded-md border border-slate-200 bg-slate-50 p-3">
                    <div class="text-sm"><strong><%= d.editor_username %></strong> set status from <em><%= d.from_status || '-' %></em> to <strong class="capitalize"><%= d.to_status %></strong></div>
                    <% if (d.note) { %><div class="text-sm text-slate-600 mt-1"><%= d.note %></div><% } %>
                    <div class="text-xs text-slate-500 mt-1"><%= new Date(d.created_at).toLocaleString() %></div>
                  </div>
                <% }) %>
              </div>
            <% } %>
          </div>

          <div class="glass-card p-5">
            <h2 class="font-display text-xl font-semibold mb-3">Review timeline</h2>
            <% if (!reviews.length) { %>
              <p class="text-sm text-slate-500">No reviewers assigned yet.</p>
            <% } else { %>
              <div class="space-y-3">
                <% reviews.forEach(r => { %>
                  <div class="rounded-md border border-slate-200 bg-slate-50 p-3">
                    <div class="flex items-start justify-between gap-3">
                      <div>
                        <div class="text-sm font-semibold"><%= r.reviewer_username %></div>
                        <div class="text-xs text-slate-500 mt-1">
                          Assigned <%= new Date(r.assigned_at).toLocaleString() %> -
                          <% if (r.review_date) { %>Submitted <%= new Date(r.review_date).toLocaleString() %><% } else { %><span class="text-amber-700">Pending</span><% } %>
                        </div>
                      </div>
                      <% if (r.recommendation) { %>
                        <span class="inline-block px-2 py-0.5 rounded-full text-xs font-medium bg-slate-100 text-slate-700 capitalize"><%= r.recommendation.replace('_', ' ') %></span>
                      <% } %>
                    </div>
                    <% if (r.ai_assisted) { %><div class="mt-2 text-xs text-indigo-700 bg-indigo-50 border border-indigo-200 px-2 py-0.5 rounded-full inline-block">AI-assisted</div><% } %>
                  </div>
                <% }) %>
              </div>
            <% } %>
          </div>
        </section>

        <section class="card overflow-hidden">
          <div class="p-5 border-b border-slate-200">
            <h2 class="font-display text-xl font-semibold">AI calls</h2>
            <p class="text-xs text-slate-500 mt-1">Provider, action, token, and actor traceability.</p>
          </div>
          <% if (!aiCalls.length) { %>
            <p class="text-sm text-slate-500 p-5">No AI calls recorded for this paper.</p>
          <% } else { %>
            <div class="overflow-x-auto">
              <table class="w-full text-sm">
                <thead class="bg-slate-50 border-b border-slate-200">
                  <tr>
                    <th class="text-left px-4 py-2 font-medium text-slate-600">When</th>
                    <th class="text-left px-4 py-2 font-medium text-slate-600">User</th>
                    <th class="text-left px-4 py-2 font-medium text-slate-600">Action</th>
                    <th class="text-left px-4 py-2 font-medium text-slate-600">Provider</th>
                    <th class="text-right px-4 py-2 font-medium text-slate-600">Tokens</th>
                  </tr>
                </thead>
                <tbody>
                  <% aiCalls.forEach(a => { %>
                    <tr class="border-t border-slate-100">
                      <td class="px-4 py-2 text-slate-500"><%= new Date(a.created_at).toLocaleString() %></td>
                      <td class="px-4 py-2"><%= a.username || '-' %></td>
                      <td class="px-4 py-2 text-xs"><code class="bg-slate-100 px-1.5 py-0.5 rounded"><%= a.action %></code></td>
                      <td class="px-4 py-2 text-xs"><code class="bg-slate-100 px-1.5 py-0.5 rounded"><%= a.provider %></code></td>
                      <td class="px-4 py-2 text-right text-slate-500"><%= (a.input_tokens || 0) + (a.output_tokens || 0) %></td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          <% } %>
        </section>
      </div>
    </div>
  </main>
  <%- include('../partials/footer') %>
</body>
</html>
