<!DOCTYPE html>
<html lang="en">
<head><%- include('../partials/head') %></head>
<body class="min-h-screen bg-slate-50 text-slate-900 flex flex-col">
  <%- include('../partials/nav') %>
  <main class="flex-1">
    <div class="max-w-4xl mx-auto px-6 py-8">
      <a href="/editor" class="text-sm text-indigo-600 hover:text-indigo-500 link-line">← Editor dashboard</a>
      <h1 class="font-display text-3xl font-bold mt-2 leading-tight"><%= paper.title %></h1>
      <p class="text-sm text-slate-500 mt-1">Complete audit trail for this submission.</p>

      <div class="grid md:grid-cols-3 gap-3 mt-6">
        <div class="card p-4">
          <div class="text-xs uppercase tracking-wider text-slate-500">Status</div>
          <div class="mt-2"><%- include('../partials/status', { status: paper.review_status }) %></div>
        </div>
        <div class="card p-4">
          <div class="text-xs uppercase tracking-wider text-slate-500">Reviews</div>
          <div class="stat-num text-2xl mt-1"><%= reviews.length %></div>
        </div>
        <div class="card p-4">
          <div class="text-xs uppercase tracking-wider text-slate-500">AI calls logged</div>
          <div class="stat-num text-2xl mt-1"><%= aiCalls.length %></div>
        </div>
      </div>

      <!-- Decisions -->
      <section class="mt-8">
        <h2 class="font-display text-lg font-semibold mb-3">Decision history</h2>
        <% if (!decisions.length) { %>
          <p class="text-sm text-slate-500 card p-4">No decisions recorded.</p>
        <% } else { %>
          <div class="space-y-2">
            <% decisions.forEach(d => { %>
              <div class="card p-4 flex items-start gap-3">
                <div class="h-8 w-8 rounded-full bg-emerald-100 text-emerald-700 flex items-center justify-center text-xs font-bold">D</div>
                <div class="flex-1">
                  <div class="text-sm"><strong><%= d.editor_username %></strong> set status from <em><%= d.from_status || '—' %></em> to <strong class="capitalize"><%= d.to_status %></strong></div>
                  <% if (d.note) { %><div class="text-sm text-slate-600 mt-1"><%= d.note %></div><% } %>
                  <div class="text-xs text-slate-500 mt-1"><%= new Date(d.created_at).toLocaleString() %></div>
                </div>
              </div>
            <% }) %>
          </div>
        <% } %>
      </section>

      <!-- Reviews -->
      <section class="mt-8">
        <h2 class="font-display text-lg font-semibold mb-3">Review timeline</h2>
        <% if (!reviews.length) { %>
          <p class="text-sm text-slate-500 card p-4">No reviewers assigned yet.</p>
        <% } else { %>
          <div class="space-y-2">
            <% reviews.forEach(r => { %>
              <div class="card p-4">
                <div class="flex items-start justify-between">
                  <div>
                    <div class="text-sm"><strong><%= r.reviewer_username %></strong>
                      <% if (r.ai_assisted) { %><span class="ml-2 inline-block text-xs text-indigo-700 bg-indigo-50 border border-indigo-200 px-2 py-0.5 rounded-full">AI-assisted</span><% } %>
                    </div>
                    <div class="text-xs text-slate-500 mt-1">
                      Assigned <%= new Date(r.assigned_at).toLocaleString() %>
                      · <% if (r.review_date) { %>Submitted <%= new Date(r.review_date).toLocaleString() %><% } else { %><span class="text-amber-700">Pending</span><% } %>
                    </div>
                  </div>
                  <% if (r.recommendation) { %>
                    <span class="inline-block px-2 py-0.5 rounded-full text-xs font-medium bg-slate-100 text-slate-700 capitalize"><%= r.recommendation.replace('_', ' ') %></span>
                  <% } %>
                </div>
              </div>
            <% }) %>
          </div>
        <% } %>
      </section>

      <!-- AI calls -->
      <section class="mt-8">
        <h2 class="font-display text-lg font-semibold mb-3">AI calls (transparency log)</h2>
        <% if (!aiCalls.length) { %>
          <p class="text-sm text-slate-500 card p-4">No AI calls recorded for this paper.</p>
        <% } else { %>
          <div class="card overflow-hidden">
            <table class="w-full text-sm">
              <thead class="bg-slate-50 border-b border-slate-200">
                <tr>
                  <th class="text-left px-4 py-2 font-medium text-slate-600">When</th>
                  <th class="text-left px-4 py-2 font-medium text-slate-600">User</th>
                  <th class="text-left px-4 py-2 font-medium text-slate-600">Action</th>
                  <th class="text-left px-4 py-2 font-medium text-slate-600">Provider</th>
                  <th class="text-right px-4 py-2 font-medium text-slate-600">Tokens</th>
                </tr>
              </thead>
              <tbody>
                <% aiCalls.forEach(a => { %>
                  <tr class="border-t border-slate-100">
                    <td class="px-4 py-2 text-slate-500"><%= new Date(a.created_at).toLocaleString() %></td>
                    <td class="px-4 py-2"><%= a.username || '—' %></td>
                    <td class="px-4 py-2 text-xs"><code class="bg-slate-100 px-1.5 py-0.5 rounded"><%= a.action %></code></td>
                    <td class="px-4 py-2 text-xs"><code class="bg-slate-100 px-1.5 py-0.5 rounded"><%= a.provider %></code></td>
                    <td class="px-4 py-2 text-right text-slate-500"><%= (a.input_tokens || 0) + (a.output_tokens || 0) %></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } %>
      </section>
    </div>
  </main>
  <%- include('../partials/footer') %>
</body>
</html>
