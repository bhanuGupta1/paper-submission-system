<!DOCTYPE html>
<html lang="en">
<head><%- include('../partials/head') %></head>
<body class="min-h-screen bg-slate-50 text-slate-900 flex flex-col">
  <%- include('../partials/nav') %>
  <main class="flex-1">
    <div class="max-w-7xl mx-auto px-6 py-8">
      <div class="dashboard-hero mb-6">
        <div>
          <p class="eyebrow text-indigo-200">Editorial workspace</p>
          <h1 class="font-display text-4xl font-bold text-white mt-2">Editor dashboard</h1>
          <p class="text-sm text-slate-300 mt-2 max-w-2xl">AI-ranked reviewer suggestions, conflict checks, review completion signals, and final decision controls.</p>
        </div>
        <% if (currentUser && currentUser.role === 'admin') { %>
          <a href="/admin/export.xlsx" class="inline-flex items-center justify-center bg-white text-slate-950 hover:bg-indigo-50 px-4 py-2 rounded-md text-sm font-semibold transition">Export XLSX</a>
        <% } %>
      </div>

      <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 mb-6">
        <div class="metric-card">
          <div class="stat-num text-3xl"><%= filter.total %></div>
          <div class="metric-label">Filtered papers</div>
        </div>
        <div class="metric-card">
          <div class="stat-num text-3xl text-indigo-600"><%= ops.reviewFunnel.pending %></div>
          <div class="metric-label">Pending reviews</div>
        </div>
        <div class="metric-card">
          <div class="stat-num text-3xl text-emerald-600"><%= ops.reviewFunnel.completionRate %>%</div>
          <div class="metric-label">Review completion</div>
        </div>
        <div class="metric-card">
          <div class="stat-num text-3xl text-amber-600"><%= reviewers.length %></div>
          <div class="metric-label">Reviewer pool</div>
        </div>
      </div>

      <form method="get" action="/editor" class="card p-4 mb-6 flex flex-wrap gap-3 items-center">
        <div class="flex-1 min-w-[200px]">
          <input name="q" value="<%= filter.q || '' %>" placeholder="Search title, abstract, tags..." class="block w-full rounded-md border border-slate-300 px-3 py-2 focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 focus:outline-none">
        </div>
        <select name="status" class="rounded-md border border-slate-300 px-3 py-2 bg-white focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 focus:outline-none">
          <option value="">All statuses</option>
          <% ['pending','under_review','accepted','rejected','revisions'].forEach(s => { %>
            <option value="<%= s %>" <%= filter.status === s ? 'selected' : '' %>><%= s.replace('_', ' ') %></option>
          <% }) %>
        </select>
        <button class="bg-slate-900 hover:bg-slate-800 text-white px-4 py-2 rounded-md text-sm font-medium transition">Filter</button>
        <div class="text-xs text-slate-500 ml-auto"><%= filter.total %> matching - page <%= filter.page %> of <%= filter.pageCount %></div>
      </form>

      <% if (papers.length === 0) { %>
        <div class="card p-12 text-center">
          <p class="text-slate-600">No submissions match your filters.</p>
        </div>
      <% } %>

      <% papers.forEach(p => { %>
        <div class="card p-5 mb-4">
          <div class="flex items-start justify-between gap-4">
            <div class="flex-1">
              <div class="flex items-center gap-2 mb-1 flex-wrap">
                <h2 class="font-display text-lg font-semibold"><%= p.title %></h2>
                <%- include('../partials/status', { status: p.review_status }) %>
              </div>
              <div class="text-xs text-slate-500">
                by <strong><%= p.author_username %></strong> - submitted <%= new Date(p.submission_date).toLocaleDateString() %>
                - similarity <strong class="<%= p.similarity_score > 0.5 ? 'text-rose-600' : '' %>"><%= (p.similarity_score * 100).toFixed(0) %>%</strong>
                - ai-text <strong class="<%= p.ai_text_likelihood > 0.5 ? 'text-amber-600' : '' %>"><%= (p.ai_text_likelihood * 100).toFixed(0) %>%</strong>
              </div>
              <p class="text-sm text-slate-700 mt-2 line-clamp-2 leading-relaxed"><%= p.abstract %></p>
              <div class="flex items-center gap-2 mt-3 flex-wrap text-xs">
                <% if (p.tags) { p.tags.split(',').forEach(t => { %>
                  <span class="inline-block bg-slate-100 text-slate-700 px-2 py-0.5 rounded-full"><%= t.trim() %></span>
                <% }) } %>
                <a href="/editor/papers/<%= p.id %>/audit" class="text-indigo-600 hover:text-indigo-500 link-line">Audit trail</a>
                <% if (p.file_path) { %>
                  <a href="/editor/papers/<%= p.id %>/download" class="text-indigo-600 hover:text-indigo-500 link-line">Download</a>
                <% } %>
              </div>
            </div>
          </div>

          <div class="grid md:grid-cols-2 gap-4 mt-4">
            <div class="rounded-lg border border-slate-200 bg-slate-50 p-4">
              <div class="text-xs uppercase tracking-wider font-semibold text-slate-500 mb-3">AI-suggested reviewers</div>
              <% if (p.suggestions.length === 0) { %>
                <div class="text-xs text-slate-500">No suggestions (no reviewers with expertise tags found).</div>
              <% } %>
              <% p.suggestions.forEach(s => { %>
                <div class="flex items-center justify-between text-sm py-1.5 border-t border-slate-200 first:border-t-0">
                  <div>
                    <span class="font-medium"><%= s.username %></span>
                    <span class="text-xs text-slate-500 ml-1">match <strong><%= (s.score * 100).toFixed(0) %>%</strong></span>
                    <% if (s.conflict && s.conflict.hasConflict) { %>
                      <span class="ml-2 inline-block text-[10px] bg-rose-50 text-rose-700 border border-rose-200 px-1.5 py-0.5 rounded">COI</span>
                    <% } %>
                  </div>
                  <form action="/editor/assign-reviewer" method="post" class="inline">
                    <input type="hidden" name="paperId" value="<%= p.id %>">
                    <input type="hidden" name="reviewerId" value="<%= s.id %>">
                    <button class="text-xs bg-indigo-50 hover:bg-indigo-100 text-indigo-700 border border-indigo-200 px-2 py-0.5 rounded font-medium transition">Assign</button>
                  </form>
                </div>
                <% if (s.expertise) { %>
                  <div class="text-xs text-slate-500 truncate ml-1 mb-1"><%= s.expertise %></div>
                <% } %>
              <% }) %>
            </div>

            <div class="rounded-lg border border-slate-200 bg-slate-50 p-4">
              <div class="text-xs uppercase tracking-wider font-semibold text-slate-500 mb-3">Manual override</div>
              <form action="/editor/assign-reviewer" method="post" class="flex items-center gap-2 mb-4">
                <input type="hidden" name="paperId" value="<%= p.id %>">
                <select name="reviewerId" required class="text-sm border border-slate-300 rounded-md px-2 py-1.5 bg-white flex-1 focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 focus:outline-none">
                  <option value="">Pick a reviewer</option>
                  <% (p.annotatedReviewers || []).forEach(r => { %>
                    <option value="<%= r.id %>">
                      <%= r.username %><%= r.expertise ? ' - ' + r.expertise.slice(0, 30) : '' %><%= r.conflict && r.conflict.hasConflict ? ' - COI' : '' %>
                    </option>
                  <% }) %>
                </select>
                <button class="text-xs bg-slate-700 hover:bg-slate-600 text-white px-3 py-1.5 rounded font-medium transition">Assign</button>
              </form>

              <div class="text-xs uppercase tracking-wider font-semibold text-slate-500 mb-2">Final decision</div>
              <form action="/editor/decide" method="post" class="space-y-2">
                <input type="hidden" name="paperId" value="<%= p.id %>">
                <div class="flex items-center gap-2">
                  <select name="decision" required class="text-sm border border-slate-300 rounded-md px-2 py-1.5 bg-white flex-1 focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 focus:outline-none">
                    <option value="">Decide</option>
                    <option value="accepted">Accept</option>
                    <option value="revisions">Revisions</option>
                    <option value="rejected">Reject</option>
                  </select>
                  <button class="text-xs bg-emerald-600 hover:bg-emerald-500 text-white px-3 py-1.5 rounded font-medium transition">Apply</button>
                </div>
                <input name="note" placeholder="Optional decision note for the author..." class="text-xs w-full border border-slate-300 rounded-md px-2 py-1.5 focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 focus:outline-none">
              </form>

              <form action="/editor/papers/<%= p.id %>/tags" method="post" class="mt-3 flex items-center gap-2">
                <input name="tags" value="<%= p.tags || '' %>" placeholder="tags, comma-separated" class="text-xs flex-1 border border-slate-300 rounded-md px-2 py-1.5 focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 focus:outline-none">
                <button class="text-xs bg-slate-100 hover:bg-slate-200 text-slate-700 border border-slate-300 px-3 py-1.5 rounded font-medium transition">Save tags</button>
              </form>
            </div>
          </div>

          <% if (p.assigned.length > 0) { %>
            <div class="mt-4 pt-3 border-t border-slate-200 text-xs text-slate-600">
              <strong>Assigned:</strong>
              <% p.assigned.forEach((a, i) => { %>
                <span class="ml-1"><%= a.reviewer_username %><%= a.recommendation ? ' (' + a.recommendation.replace('_', ' ') + ')' : ' - pending' %><%= i < p.assigned.length - 1 ? ',' : '' %></span>
              <% }) %>
            </div>
          <% } %>
        </div>
      <% }) %>

      <% if (filter.pageCount > 1) { %>
        <div class="flex items-center justify-center gap-2 mt-6">
          <% if (filter.page > 1) { %>
            <a href="?page=<%= filter.page - 1 %><%= filter.status ? '&status=' + filter.status : '' %><%= filter.q ? '&q=' + filter.q : '' %>" class="px-3 py-1.5 rounded-md border border-slate-300 text-sm hover:bg-slate-100 transition">Previous</a>
          <% } %>
          <span class="text-sm text-slate-500">Page <%= filter.page %> of <%= filter.pageCount %></span>
          <% if (filter.page < filter.pageCount) { %>
            <a href="?page=<%= filter.page + 1 %><%= filter.status ? '&status=' + filter.status : '' %><%= filter.q ? '&q=' + filter.q : '' %>" class="px-3 py-1.5 rounded-md border border-slate-300 text-sm hover:bg-slate-100 transition">Next</a>
          <% } %>
        </div>
      <% } %>
    </div>
  </main>
  <%- include('../partials/footer') %>
</body>
</html>
