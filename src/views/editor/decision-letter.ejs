<!DOCTYPE html>
<html lang="en">
<head><%- include('../partials/head') %></head>
<body class="min-h-screen bg-slate-50 text-slate-900 flex flex-col">
  <%- include('../partials/nav') %>
  <main class="flex-1">
    <div class="max-w-3xl mx-auto px-6 py-10">
      <div class="mb-6">
        <a href="/editor" class="text-indigo-600 hover:text-indigo-500 text-sm">← Editor dashboard</a>
        <h1 class="font-display text-3xl font-bold mt-2">Decision Letters</h1>
        <p class="text-slate-500 mt-1 text-sm"><%= paper.title %></p>
      </div>

      <% if (letters.length === 0) { %>
        <div class="card p-12 text-center text-slate-500">
          <p>No decision letters generated yet.</p>
          <p class="text-sm mt-1">Decision letters are created when you make a decision with "Generate letter" checked.</p>
        </div>
      <% } else { %>
        <div class="space-y-6">
          <% letters.forEach(letter => { %>
          <div class="card p-6">
            <div class="flex items-start justify-between gap-4 mb-4">
              <div>
                <h3 class="font-semibold text-slate-800"><%= letter.subject %></h3>
                <p class="text-xs text-slate-500 mt-1">By <%= letter.editor_username %> · <%= new Date(letter.created_at).toLocaleString() %>
                  <% if (letter.sent_at) { %> · <span class="text-emerald-600">Sent <%= new Date(letter.sent_at).toLocaleString() %></span><% } %>
                </p>
              </div>
              <button onclick="downloadLetter(this)" data-body="<%= encodeURIComponent(letter.body) %>" data-subject="<%= encodeURIComponent(letter.subject) %>"
                class="text-xs text-indigo-600 hover:text-indigo-700 font-medium px-3 py-1.5 border border-indigo-200 rounded-md shrink-0">
                Download TXT
              </button>
            </div>
            <pre class="bg-slate-50 border border-slate-200 rounded-lg p-4 text-sm text-slate-700 whitespace-pre-wrap font-mono leading-relaxed overflow-x-auto"><%= letter.body %></pre>
          </div>
          <% }) %>
        </div>
      <% } %>
    </div>
  </main>
  <%- include('../partials/footer') %>
  <script>
    function downloadLetter(btn) {
      const body = decodeURIComponent(btn.dataset.body);
      const subject = decodeURIComponent(btn.dataset.subject);
      const blob = new Blob([body], { type: 'text/plain' });
      const a = document.createElement('a');
      a.href = URL.createObjectURL(blob);
      a.download = `${subject.replace(/[^a-z0-9]/gi, '_')}.txt`;
      a.click();
    }
  </script>
</body>
</html>
