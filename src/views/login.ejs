<!DOCTYPE html>
<html lang="en">
<head><%- include('partials/head') %></head>
<body class="min-h-screen flex flex-col overflow-x-hidden" style="background:var(--surface-0);color:var(--text-primary)">
  <%- include('partials/nav') %>

  <main class="auth-canvas flex-1 relative overflow-hidden">
    <div class="page-photo-bg" style="background-image:url('https://images.unsplash.com/photo-1507842217343-583bb7270b66?auto=format&fit=crop&w=1920&q=80')" aria-hidden="true"></div>
    <div class="mesh-bg" aria-hidden="true">
      <span class="mesh-blob mesh-blob-one"></span>
      <span class="mesh-blob mesh-blob-two"></span>
      <span class="mesh-blob mesh-blob-three"></span>
      <span class="mesh-blob mesh-blob-four"></span>
    </div>

    <div class="relative z-10 min-h-[calc(100vh-65px)] flex items-center justify-center px-6 py-12">
      <section class="glass-card gradient-border-card auth-card animate-slide-up-fade w-full max-w-[460px] p-8 sm:p-9">
        <div class="flex items-center justify-between gap-4 mb-8">
          <div class="flex items-center gap-3">
            <span class="brand-mark inline-flex h-11 w-11 items-center justify-center rounded-xl text-base font-black text-white">P</span>
            <div>
              <div class="font-display font-extrabold text-lg" style="color:var(--text-primary)">PaperSub.AI</div>
              <div class="text-xs" style="color:var(--text-tertiary)">Encrypted workspace</div>
            </div>
          </div>
          <span class="inline-flex h-9 w-9 items-center justify-center rounded-full" style="background:rgba(99,102,241,0.12);color:var(--brand-500)">
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
          </span>
        </div>

        <h2 class="font-display text-3xl font-extrabold" style="color:var(--text-primary)">Sign in</h2>
        <p class="text-sm mt-2" style="color:var(--text-secondary)">Enter your project credentials to continue.</p>

        <% if (error) { %>
          <div class="alert alert-warning mt-5" role="alert">
            <svg class="w-4 h-4 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/></svg>
            <span><%= error %></span>
          </div>
        <% } %>
        <% if (success) { %>
          <div class="alert alert-success mt-5" role="alert">
            <svg class="w-4 h-4 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            <span><%= success %></span>
          </div>
        <% } %>

        <form action="/login" method="post" class="mt-7 space-y-5" autocomplete="on">
          <div>
            <label for="username" class="block text-sm font-semibold mb-2">Username</label>
            <input id="username" name="username" required autofocus autocomplete="username" placeholder="jsmith"
              class="auth-input block w-full rounded-xl border px-4 py-3 text-sm"
              style="background:rgba(255,255,255,0.55);border-color:var(--border-default);color:var(--text-primary)">
          </div>
          <div>
            <div class="flex justify-between items-center mb-2">
              <label for="password" class="block text-sm font-semibold">Password</label>
              <a href="/auth/forgot-password" class="text-xs font-semibold link-line" style="color:var(--brand-500)">Forgot password?</a>
            </div>
            <input id="password" type="password" name="password" required autocomplete="current-password" placeholder="Enter password"
              class="auth-input block w-full rounded-xl border px-4 py-3 text-sm"
              style="background:rgba(255,255,255,0.55);border-color:var(--border-default);color:var(--text-primary)">
          </div>
          <button type="submit" class="btn-gradient shimmer-btn w-full mt-2">
            Sign in
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
          </button>
        </form>

        <% if (googleOAuthEnabled || githubOAuthEnabled || orcidOAuthEnabled) { %>
          <div class="relative my-6">
            <div class="absolute inset-0 flex items-center"><div class="w-full border-t" style="border-color:var(--border-default)"></div></div>
            <div class="relative flex justify-center text-xs"><span class="px-3 rounded-full glass-chip" style="color:var(--text-tertiary)">or continue with</span></div>
          </div>
          <div class="grid gap-2">
            <% if (googleOAuthEnabled) { %>
              <a href="/auth/google" class="btn btn-secondary w-full py-3 text-sm flex items-center justify-center gap-2.5">Continue with Google</a>
            <% } %>
            <% if (githubOAuthEnabled) { %>
              <a href="/auth/github" class="btn btn-secondary w-full py-3 text-sm flex items-center justify-center gap-2.5">Continue with GitHub</a>
            <% } %>
            <% if (orcidOAuthEnabled) { %>
              <a href="/auth/orcid" class="btn btn-secondary w-full py-3 text-sm flex items-center justify-center gap-2.5" style="border-color:rgba(166,206,57,0.4)">
                <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" style="color:#a6ce39"><circle cx="12" cy="12" r="12" fill="#a6ce39"/><text x="12" y="16.5" text-anchor="middle" font-size="10" font-weight="bold" fill="white">iD</text></svg>
                Sign in with ORCID
              </a>
            <% } %>
          </div>
        <% } %>

        <div class="mt-7 flex items-center justify-center gap-3 text-xs font-medium" style="color:var(--text-tertiary)">
          <span class="inline-flex items-center gap-1.5">
            <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 11c1.657 0 3 1.343 3 3v2H9v-2c0-1.657 1.343-3 3-3zm6 10H6a2 2 0 01-2-2v-6a2 2 0 012-2h12a2 2 0 012 2v6a2 2 0 01-2 2zM8 11V7a4 4 0 018 0v4"/></svg>
            256-bit encryption
          </span>
          <span class="h-1 w-1 rounded-full" style="background:var(--border-strong)"></span>
          <span>SOC 2 ready controls</span>
        </div>

        <p class="text-sm mt-6 text-center" style="color:var(--text-secondary)">
          New to PaperSub.AI? <a href="/register" class="font-semibold link-line" style="color:var(--brand-500)">Create account</a>
        </p>
      </section>
    </div>
  </main>
  <%- include('partials/footer') %>
</body>
</html>
