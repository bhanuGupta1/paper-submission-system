<!DOCTYPE html>
<html lang="en">
<head><%- include('partials/head') %></head>
<body class="min-h-screen bg-slate-50 text-slate-900 flex flex-col">
  <%- include('partials/nav') %>
  <main class="flex-1 flex items-center">
    <div class="w-full max-w-6xl mx-auto px-6 py-12 grid lg:grid-cols-2 gap-12 items-center">

      <!-- Left: brand story -->
      <section class="hidden lg:block">
        <p class="eyebrow" style="color:var(--brand-600)">Secure workspace</p>
        <h1 class="font-display text-5xl font-extrabold mt-3 leading-tight" style="color:var(--text-primary)">
          Welcome back to<br>
          <span style="background:linear-gradient(135deg,var(--brand-600),var(--accent-500));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text">PaperSub.AI</span>
        </h1>
        <p class="mt-4 text-lg leading-relaxed max-w-sm" style="color:var(--text-secondary)">
          Pick up where you left off — submissions, reviews, editorial decisions, and platform analytics from your role-aware dashboard.
        </p>

        <!-- Testimonial-style features -->
        <div class="mt-8 space-y-4">
          <div class="flex items-start gap-3">
            <div class="w-8 h-8 rounded-lg shrink-0 flex items-center justify-center" style="background:var(--brand-50);border:1px solid var(--brand-200)">
              <svg class="w-4 h-4" style="color:var(--brand-600)" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
            </div>
            <div>
              <div class="font-semibold text-sm" style="color:var(--text-primary)">Double-blind peer review</div>
              <div class="text-sm" style="color:var(--text-secondary)">Author and reviewer identities protected throughout the process.</div>
            </div>
          </div>
          <div class="flex items-start gap-3">
            <div class="w-8 h-8 rounded-lg shrink-0 flex items-center justify-center" style="background:rgba(6,182,212,0.1);border:1px solid rgba(6,182,212,0.2)">
              <svg class="w-4 h-4 text-cyan-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
            </div>
            <div>
              <div class="font-semibold text-sm" style="color:var(--text-primary)">AI-augmented workflow</div>
              <div class="text-sm" style="color:var(--text-secondary)">Every AI suggestion is logged, attributed, and human-overridable.</div>
            </div>
          </div>
          <div class="flex items-start gap-3">
            <div class="w-8 h-8 rounded-lg shrink-0 flex items-center justify-center" style="background:rgba(16,185,129,0.1);border:1px solid rgba(16,185,129,0.2)">
              <svg class="w-4 h-4 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
            </div>
            <div>
              <div class="font-semibold text-sm" style="color:var(--text-primary)">Real-time dashboard analytics</div>
              <div class="text-sm" style="color:var(--text-secondary)">Submission pipeline, review metrics, and integrity signals at a glance.</div>
            </div>
          </div>
        </div>
      </section>

      <!-- Right: login form -->
      <section class="glass-auth p-8 w-full max-w-md mx-auto lg:mx-0">
        <div class="flex items-center gap-3 mb-6">
          <span class="brand-mark inline-flex h-9 w-9 items-center justify-center rounded-lg text-sm font-black text-white">P</span>
          <div>
            <div class="font-bold text-base" style="color:var(--text-primary)">PaperSub.AI</div>
            <div class="text-xs" style="color:var(--text-tertiary)">Research operations platform</div>
          </div>
        </div>

        <h2 class="font-display text-2xl font-bold" style="color:var(--text-primary)">Sign in to your account</h2>
        <p class="text-sm mt-1" style="color:var(--text-secondary)">Use your project credentials.</p>

        <% if (error) { %>
          <div class="alert alert-warning mt-4" role="alert">
            <svg class="w-4 h-4 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
            <span><%= error %></span>
          </div>
        <% } %>
        <% if (success) { %>
          <div class="alert alert-success mt-4" role="alert">
            <svg class="w-4 h-4 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            <span><%= success %></span>
          </div>
        <% } %>

        <form action="/login" method="post" class="mt-6 space-y-4" autocomplete="on">
          <div>
            <label for="username" class="block text-sm font-semibold mb-1.5" style="color:var(--text-secondary)">Username</label>
            <input id="username" name="username" required autofocus autocomplete="username"
              class="block w-full rounded-lg border px-3.5 py-2.5 text-sm"
              style="background:var(--surface-1);border-color:var(--border-default);color:var(--text-primary)">
          </div>
          <div>
            <div class="flex justify-between items-center mb-1.5">
              <label for="password" class="block text-sm font-semibold" style="color:var(--text-secondary)">Password</label>
              <a href="/auth/forgot-password" class="text-xs font-medium" style="color:var(--brand-600)">Forgot password?</a>
            </div>
            <input id="password" type="password" name="password" required autocomplete="current-password"
              class="block w-full rounded-lg border px-3.5 py-2.5 text-sm"
              style="background:var(--surface-1);border-color:var(--border-default);color:var(--text-primary)">
          </div>
          <button type="submit" class="btn btn-primary w-full py-2.5 mt-2">
            Sign in
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
          </button>
        </form>

        <% if (googleOAuthEnabled) { %>
          <div class="relative my-5">
            <div class="absolute inset-0 flex items-center"><div class="w-full border-t" style="border-color:var(--border-default)"></div></div>
            <div class="relative flex justify-center text-xs"><span class="px-3" style="background:var(--surface-0);color:var(--text-tertiary)">or continue with</span></div>
          </div>
          <a href="/auth/google" class="btn btn-secondary w-full py-2.5 text-sm flex items-center justify-center gap-2.5">
            <svg class="w-4 h-4" viewBox="0 0 24 24"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
            Continue with Google
          </a>
        <% } %>

        <div class="relative my-5">
          <div class="absolute inset-0 flex items-center"><div class="w-full border-t" style="border-color:var(--border-default)"></div></div>
          <div class="relative flex justify-center text-xs"><span class="px-3" style="background:var(--surface-0);color:var(--text-tertiary)">New to PaperSub.AI?</span></div>
        </div>

        <a href="/register" class="btn btn-secondary w-full py-2.5 text-sm">Create a free account</a>
      </section>
    </div>
  </main>
  <%- include('partials/footer') %>
</body>
</html>
