<!DOCTYPE html>
<html lang="en">
<head><%- include('../partials/head') %></head>
<body class="min-h-screen flex flex-col" style="background:var(--surface-0);color:var(--text-primary)">
  <%- include('../partials/nav') %>
  <main class="flex-1">
    <div class="max-w-5xl mx-auto px-6 py-8">

      <div class="dashboard-hero mb-8">
        <div class="flex-1">
          <p class="eyebrow text-indigo-200">Your account</p>
          <h1 class="font-display text-4xl font-bold text-white mt-2">Profile</h1>
          <p class="text-sm text-slate-300 mt-2">Affiliation and expertise feed conflict-of-interest detection and reviewer matching.</p>
        </div>
        <div class="shrink-0 h-14 w-14 rounded-2xl flex items-center justify-center text-xl font-black text-white" style="background:rgba(255,255,255,0.15)">
          <%= user.username.slice(0,1).toUpperCase() %>
        </div>
      </div>

      <% if (error) { %>
        <div class="alert alert-warning mb-5" role="alert">
          <svg class="w-4 h-4 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
          <span><%= error %></span>
        </div>
      <% } %>
      <% if (success) { %>
        <div class="alert alert-success mb-5" role="alert">
          <svg class="w-4 h-4 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          <span><%= success %></span>
        </div>
      <% } %>

      <div class="grid md:grid-cols-[1fr_0.85fr] gap-6">

        <!-- Edit form -->
        <div class="glass-card gradient-border-card p-6 sm:p-8">
          <h2 class="font-display text-2xl font-extrabold mb-6 gradient-text">Account details</h2>
          <form action="/author/profile" method="post" class="space-y-4">

            <div>
              <label class="block text-sm font-semibold mb-1.5" style="color:var(--text-secondary)">Username</label>
              <input value="<%= user.username %>" disabled
                class="block w-full rounded-lg border px-3.5 py-2.5 text-sm cursor-not-allowed"
                style="background:var(--surface-2);border-color:var(--border-default);color:var(--text-tertiary)">
            </div>

            <div>
              <label class="block text-sm font-semibold mb-1.5" style="color:var(--text-secondary)">
                Email
                <% if (user.email_verified) { %>
                  <span class="ml-2 text-xs font-normal px-1.5 py-0.5 rounded-full" style="background:var(--success-50);color:var(--success-700);border:1px solid var(--success-100)">verified</span>
                <% } %>
              </label>
              <input type="email" name="email" value="<%= user.email || '' %>"
                class="block w-full rounded-lg border px-3.5 py-2.5 text-sm"
                style="background:var(--surface-1);border-color:var(--border-default);color:var(--text-primary)">
            </div>

            <div>
              <label class="block text-sm font-semibold mb-1.5" style="color:var(--text-secondary)">Affiliation</label>
              <input name="affiliation" value="<%= user.affiliation || '' %>" placeholder="University of Auckland"
                class="block w-full rounded-lg border px-3.5 py-2.5 text-sm"
                style="background:var(--surface-1);border-color:var(--border-default);color:var(--text-primary)">
              <p class="text-xs mt-1.5" style="color:var(--text-tertiary)">Used for conflict-of-interest detection.</p>
            </div>

            <div>
              <label class="block text-sm font-semibold mb-1.5" style="color:var(--text-secondary)">Expertise tags</label>
              <input name="expertise" value="<%= user.expertise || '' %>" placeholder="NLP, transformers, machine learning"
                class="block w-full rounded-lg border px-3.5 py-2.5 text-sm"
                style="background:var(--surface-1);border-color:var(--border-default);color:var(--text-primary)">
              <p class="text-xs mt-1.5" style="color:var(--text-tertiary)">Comma-separated. Improves reviewer–paper matching.</p>
            </div>

            <div class="pt-2">
              <button class="btn-gradient shimmer-btn">Save changes</button>
            </div>
          </form>
        </div>

        <!-- Right column -->
        <div class="space-y-5">

          <!-- Submission stats -->
          <div class="glass-card p-5">
            <p class="eyebrow mb-4" style="color:var(--brand-600)">Submission stats</p>
            <div class="grid grid-cols-2 gap-3">
              <div class="rounded-lg p-3" style="background:var(--surface-1)">
                <div class="stat-num text-2xl" style="color:var(--text-primary)"><%= stats && stats.total || 0 %></div>
                <div class="text-xs mt-0.5 uppercase tracking-wider font-semibold" style="color:var(--text-tertiary)">Total</div>
              </div>
              <div class="rounded-lg p-3" style="background:var(--surface-1)">
                <div class="stat-num text-2xl" style="color:var(--success-700)"><%= stats && stats.accepted || 0 %></div>
                <div class="text-xs mt-0.5 uppercase tracking-wider font-semibold" style="color:var(--text-tertiary)">Accepted</div>
              </div>
              <div class="rounded-lg p-3" style="background:var(--surface-1)">
                <div class="stat-num text-2xl" style="color:var(--warning-700)"><%= stats && stats.in_review || 0 %></div>
                <div class="text-xs mt-0.5 uppercase tracking-wider font-semibold" style="color:var(--text-tertiary)">In review</div>
              </div>
              <div class="rounded-lg p-3" style="background:var(--surface-1)">
                <div class="stat-num text-2xl" style="color:var(--brand-600)"><%= stats && stats.revisions || 0 %></div>
                <div class="text-xs mt-0.5 uppercase tracking-wider font-semibold" style="color:var(--text-tertiary)">Revisions</div>
              </div>
            </div>
          </div>

          <!-- AI usage -->
          <div class="glass-card p-5">
            <p class="eyebrow mb-4" style="color:var(--brand-600)">AI usage</p>
            <% if (aiUsage.length === 0) { %>
              <p class="text-sm" style="color:var(--text-tertiary)">No AI calls recorded yet.</p>
            <% } else { %>
              <ul class="space-y-2">
                <% const total = aiUsage.reduce((sum, u) => sum + Number(u.n), 0); %>
                <% aiUsage.forEach(u => { %>
                  <li>
                    <div class="flex items-center justify-between text-sm mb-1">
                      <span style="color:var(--text-secondary)"><%= u.action.replace(/_/g, ' ') %></span>
                      <span class="font-semibold tabular-nums" style="color:var(--text-primary)"><%= u.n %></span>
                    </div>
                    <div class="h-1.5 rounded-full" style="background:var(--surface-2)">
                      <div class="h-1.5 rounded-full" style="width:<%= Math.round((u.n/total)*100) %>%;background:var(--brand-500)"></div>
                    </div>
                  </li>
                <% }) %>
                <li class="pt-1 border-t text-xs" style="border-color:var(--border-default);color:var(--text-tertiary)"><%= total %> total AI calls</li>
              </ul>
            <% } %>
          </div>

          <!-- Account info -->
          <div class="glass-card p-5 text-sm space-y-2.5">
            <p class="eyebrow mb-3" style="color:var(--brand-600)">Account info</p>
            <div class="flex justify-between">
              <span style="color:var(--text-secondary)">Role</span>
              <span class="font-medium capitalize" style="color:var(--text-primary)"><%= user.role %></span>
            </div>
            <div class="flex justify-between">
              <span style="color:var(--text-secondary)">Member since</span>
              <span class="font-medium" style="color:var(--text-primary)"><%= new Date(user.created_at || Date.now()).toLocaleDateString('en-US', { year:'numeric', month:'short' }) %></span>
            </div>
            <% if (user.oauth_provider) { %>
            <div class="flex justify-between">
              <span style="color:var(--text-secondary)">Sign-in</span>
              <span class="font-medium capitalize" style="color:var(--text-primary)"><%= user.oauth_provider %> OAuth</span>
            </div>
            <% } %>
          </div>
        </div>
      </div>

      <!-- Notification preferences -->
      <section id="notification-prefs" class="glass-card gradient-border-card p-6 sm:p-8 mt-6">
        <h2 class="font-display text-2xl font-extrabold mb-1 gradient-text">Notification preferences</h2>
        <p class="text-sm mb-6" style="color:var(--text-tertiary)">Connect Slack or Microsoft Teams to receive platform events wherever your team works.</p>
        <form action="/author/profile/notification-prefs" method="post" class="space-y-6">

          <!-- Webhook URLs -->
          <div class="grid sm:grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-semibold mb-1.5" style="color:var(--text-secondary)">
                <span class="inline-flex items-center gap-1.5">
                  <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" style="color:#611f69"><path d="M5.042 15.165a2.528 2.528 0 01-2.52 2.523A2.528 2.528 0 010 15.165a2.527 2.527 0 012.522-2.52h2.52v2.52zM6.313 15.165a2.527 2.527 0 012.521-2.52 2.527 2.527 0 012.521 2.52v6.313A2.528 2.528 0 018.834 24a2.528 2.528 0 01-2.521-2.522v-6.313zM8.834 5.042a2.528 2.528 0 01-2.521-2.52A2.528 2.528 0 018.834 0a2.528 2.528 0 012.521 2.522v2.52H8.834zM8.834 6.313a2.528 2.528 0 012.521 2.521 2.528 2.528 0 01-2.521 2.521H2.522A2.528 2.528 0 010 8.834a2.528 2.528 0 012.522-2.521h6.312zM18.956 8.834a2.528 2.528 0 012.522-2.521A2.528 2.528 0 0124 8.834a2.528 2.528 0 01-2.522 2.521h-2.522V8.834zM17.688 8.834a2.528 2.528 0 01-2.523 2.521 2.527 2.527 0 01-2.52-2.521V2.522A2.527 2.527 0 0115.165 0a2.528 2.528 0 012.523 2.522v6.312zM15.165 18.956a2.528 2.528 0 012.523 2.522A2.528 2.528 0 0115.165 24a2.527 2.527 0 01-2.52-2.522v-2.522h2.52zM15.165 17.688a2.527 2.527 0 01-2.52-2.523 2.526 2.526 0 012.52-2.52h6.313A2.527 2.527 0 0124 15.165a2.528 2.528 0 01-2.522 2.523h-6.313z"/></svg>
                  Slack incoming webhook URL
                </span>
              </label>
              <input type="url" name="slack_webhook" value="<%= notificationPrefs.slack_webhook || '' %>"
                placeholder="https://hooks.slack.com/services/..."
                class="block w-full rounded-lg border px-3.5 py-2.5 text-sm"
                style="background:var(--surface-1);border-color:var(--border-default);color:var(--text-primary)">
              <p class="text-xs mt-1.5" style="color:var(--text-tertiary)">From Slack → Apps → Incoming Webhooks → Add.</p>
            </div>
            <div>
              <label class="block text-sm font-semibold mb-1.5" style="color:var(--text-secondary)">
                <span class="inline-flex items-center gap-1.5">
                  <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" style="color:#6264a7"><path d="M24 12.004C24 5.374 18.628 0 12 0 5.374 0 0 5.374 0 12.004 0 17.98 4.388 22.954 10.126 23.854V15.47H7.078v-3.466h3.048v-2.642c0-3.007 1.792-4.669 4.532-4.669 1.313 0 2.686.234 2.686.234v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.466h-2.796v8.384C19.612 22.954 24 17.98 24 12.004z"/></svg>
                  Microsoft Teams webhook URL
                </span>
              </label>
              <input type="url" name="teams_webhook" value="<%= notificationPrefs.teams_webhook || '' %>"
                placeholder="https://outlook.office.com/webhook/..."
                class="block w-full rounded-lg border px-3.5 py-2.5 text-sm"
                style="background:var(--surface-1);border-color:var(--border-default);color:var(--text-primary)">
              <p class="text-xs mt-1.5" style="color:var(--text-tertiary)">From Teams → channel → Connectors → Incoming Webhook.</p>
            </div>
          </div>

          <!-- Email toggles -->
          <div>
            <p class="text-sm font-semibold mb-3" style="color:var(--text-secondary)">Email notifications</p>
            <div class="flex flex-wrap gap-4">
              <label class="flex items-center gap-2.5 cursor-pointer">
                <input type="checkbox" name="email_on_assignment" class="w-4 h-4 rounded" style="accent-color:var(--brand-500)"
                  <%= notificationPrefs.email_on_assignment !== false ? 'checked' : '' %>>
                <span class="text-sm" style="color:var(--text-secondary)">When assigned as reviewer</span>
              </label>
              <label class="flex items-center gap-2.5 cursor-pointer">
                <input type="checkbox" name="email_on_decision" class="w-4 h-4 rounded" style="accent-color:var(--brand-500)"
                  <%= notificationPrefs.email_on_decision !== false ? 'checked' : '' %>>
                <span class="text-sm" style="color:var(--text-secondary)">When an editorial decision is made on my paper</span>
              </label>
            </div>
          </div>

          <!-- Digest frequency -->
          <div>
            <p class="text-sm font-semibold mb-3" style="color:var(--text-secondary)">In-app notification digest</p>
            <div class="flex gap-3">
              <label class="flex items-center gap-2 cursor-pointer">
                <input type="radio" name="digest" value="immediate" class="w-4 h-4" style="accent-color:var(--brand-500)"
                  <%= (notificationPrefs.digest || 'immediate') === 'immediate' ? 'checked' : '' %>>
                <span class="text-sm" style="color:var(--text-secondary)">Immediate</span>
              </label>
              <label class="flex items-center gap-2 cursor-pointer">
                <input type="radio" name="digest" value="daily" class="w-4 h-4" style="accent-color:var(--brand-500)"
                  <%= notificationPrefs.digest === 'daily' ? 'checked' : '' %>>
                <span class="text-sm" style="color:var(--text-secondary)">Daily digest</span>
              </label>
            </div>
          </div>

          <div>
            <button class="btn-gradient shimmer-btn">Save preferences</button>
          </div>
        </form>
      </section>

      <!-- GDPR / Account deletion -->
      <section id="delete-account" class="glass-card p-6 sm:p-8 mt-6" style="border-color:rgba(220,38,38,0.2)">
        <h2 class="font-display text-xl font-extrabold mb-1" style="color:#dc2626">Data &amp; account</h2>
        <p class="text-sm mb-5" style="color:var(--text-tertiary)">Download your data or permanently delete your account in compliance with GDPR.</p>
        <div class="flex flex-wrap gap-3 mb-6">
          <a href="/author/profile/export" class="btn btn-secondary text-sm">Download my data (JSON)</a>
          <a href="/privacy" class="btn btn-secondary text-sm">Privacy policy</a>
        </div>
        <details class="group">
          <summary class="cursor-pointer text-sm font-semibold select-none" style="color:#dc2626">Delete account permanently&hellip;</summary>
          <form action="/author/profile/request-deletion" method="post" class="mt-4 space-y-3 max-w-sm">
            <p class="text-xs leading-6" style="color:var(--text-tertiary)">Your account will be deactivated immediately and hard-deleted within 30 days. This cannot be undone.</p>
            <div>
              <label class="block text-sm font-semibold mb-1.5" style="color:var(--text-secondary)">Type <code class="px-1 rounded text-xs" style="background:var(--surface-2)">DELETE MY ACCOUNT</code> to confirm</label>
              <input type="text" name="confirmation" autocomplete="off" required
                class="block w-full rounded-lg border px-3.5 py-2.5 text-sm"
                style="background:var(--surface-1);border-color:rgba(220,38,38,0.4);color:var(--text-primary)">
            </div>
            <button class="btn text-sm px-4 py-2" style="background:#dc2626;color:#fff;border:none">Delete my account</button>
          </form>
        </details>
      </section>

    </div>
  </main>
  <%- include('../partials/footer') %>
</body>
</html>
