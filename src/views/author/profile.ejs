<!DOCTYPE html>
<html lang="en">
<head><%- include('../partials/head') %></head>
<body class="min-h-screen bg-slate-50 text-slate-900 flex flex-col">
  <%- include('../partials/nav') %>
  <main class="flex-1">
    <div class="max-w-4xl mx-auto px-6 py-8">
      <h1 class="font-display text-3xl font-bold">Profile</h1>
      <p class="text-sm text-slate-600 mt-1">Public profile info and your AI usage on this account.</p>
      <% if (error) { %>
        <div class="mt-4 bg-red-50 border border-red-200 text-red-800 text-sm p-3 rounded-md" role="alert"><%= error %></div>
      <% } %>
      <% if (success) { %>
        <div class="mt-4 bg-emerald-50 border border-emerald-200 text-emerald-800 text-sm p-3 rounded-md" role="alert"><%= success %></div>
      <% } %>

      <div class="grid md:grid-cols-2 gap-6 mt-6">
        <div class="card p-6">
          <h2 class="font-display text-lg font-semibold">Account details</h2>
          <form action="/author/profile" method="post" class="mt-4 space-y-3">
            <div><label class="block text-sm font-medium text-slate-700">Username</label>
              <input value="<%= user.username %>" disabled class="mt-1 block w-full rounded-md border border-slate-300 bg-slate-50 px-3 py-2 text-slate-500"></div>
            <div><label class="block text-sm font-medium text-slate-700">Email</label>
              <input type="email" name="email" value="<%= user.email || '' %>" class="mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 focus:outline-none"></div>
            <div><label class="block text-sm font-medium text-slate-700">Affiliation</label>
              <input name="affiliation" value="<%= user.affiliation || '' %>" class="mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 focus:outline-none">
              <p class="text-xs text-slate-500 mt-1">Used for conflict-of-interest detection.</p></div>
            <div><label class="block text-sm font-medium text-slate-700">Expertise</label>
              <input name="expertise" value="<%= user.expertise || '' %>" placeholder="comma-separated" class="mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 focus:outline-none"></div>
            <button class="bg-indigo-600 hover:bg-indigo-500 text-white px-4 py-2 rounded-md font-medium transition">Save</button>
          </form>
        </div>

        <div class="space-y-4">
          <div class="card p-6">
            <h2 class="font-display text-lg font-semibold">Submission stats</h2>
            <div class="grid grid-cols-2 gap-3 mt-3">
              <div><div class="stat-num text-2xl"><%= stats && stats.total || 0 %></div><div class="text-xs text-slate-500 uppercase tracking-wider">Total</div></div>
              <div><div class="stat-num text-2xl text-emerald-600"><%= stats && stats.accepted || 0 %></div><div class="text-xs text-slate-500 uppercase tracking-wider">Accepted</div></div>
              <div><div class="stat-num text-2xl text-amber-600"><%= stats && stats.in_review || 0 %></div><div class="text-xs text-slate-500 uppercase tracking-wider">In review</div></div>
              <div><div class="stat-num text-2xl text-indigo-600"><%= stats && stats.revisions || 0 %></div><div class="text-xs text-slate-500 uppercase tracking-wider">Revisions</div></div>
            </div>
          </div>

          <div class="card p-6">
            <h2 class="font-display text-lg font-semibold">AI usage on this account</h2>
            <% if (aiUsage.length === 0) { %>
              <p class="text-sm text-slate-500 mt-2">No AI calls recorded yet.</p>
            <% } else { %>
              <ul class="mt-3 space-y-1.5 text-sm">
                <% aiUsage.forEach(u => { %>
                  <li class="flex items-center justify-between">
                    <span class="text-slate-700"><%= u.action.replace(/_/g, ' ') %></span>
                    <span class="font-semibold"><%= u.n %></span>
                  </li>
                <% }) %>
              </ul>
            <% } %>
          </div>
        </div>
      </div>
    </div>
  </main>
  <%- include('../partials/footer') %>
</body>
</html>
