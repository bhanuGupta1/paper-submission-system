<!DOCTYPE html>
<html lang="en">
<head><%- include('../partials/head') %></head>
<body class="min-h-screen bg-slate-50 text-slate-900 flex flex-col">
  <%- include('../partials/nav') %>
  <main class="flex-1">
    <div class="max-w-4xl mx-auto px-6 py-8">
      <a href="/author" class="text-sm text-indigo-600 hover:text-indigo-500 link-line">← All submissions</a>
      <div class="flex items-start justify-between mt-3">
        <div>
          <h1 class="font-display text-3xl font-bold leading-tight"><%= paper.title %></h1>
          <p class="text-sm text-slate-500 mt-1">Submitted <%= new Date(paper.submission_date).toLocaleString() %></p>
        </div>
        <%- include('../partials/status', { status: paper.review_status }) %>
      </div>

      <div class="grid md:grid-cols-3 gap-3 mt-6">
        <div class="card p-4">
          <div class="text-xs uppercase tracking-wider text-slate-500">Similarity to corpus</div>
          <div class="stat-num text-2xl mt-1"><%= (paper.similarity_score * 100).toFixed(1) %>%</div>
          <div class="text-xs text-slate-500 mt-1">Higher = more similar to existing papers</div>
        </div>
        <div class="card p-4">
          <div class="text-xs uppercase tracking-wider text-slate-500">AI-text likelihood</div>
          <div class="stat-num text-2xl mt-1"><%= (paper.ai_text_likelihood * 100).toFixed(0) %>%</div>
          <div class="text-xs text-slate-500 mt-1">Heuristic flag, never a verdict</div>
        </div>
        <div class="card p-4">
          <div class="text-xs uppercase tracking-wider text-slate-500">Reviews</div>
          <div class="stat-num text-2xl mt-1"><%= reviews.length %></div>
          <div class="text-xs text-slate-500 mt-1">Total submitted</div>
        </div>
      </div>

      <div class="card p-6 mt-6">
        <h2 class="font-display text-lg font-semibold">Abstract</h2>
        <p class="text-slate-700 mt-2 leading-relaxed whitespace-pre-line"><%= paper.abstract %></p>
        <% if (paper.tags) { %>
          <div class="mt-4 flex flex-wrap gap-1.5">
            <% paper.tags.split(',').forEach(t => { %>
              <span class="inline-block text-xs bg-slate-100 text-slate-700 px-2 py-0.5 rounded-full"><%= t.trim() %></span>
            <% }) %>
          </div>
        <% } %>
        <% if (paper.ai_keywords) { %>
          <div class="mt-3 text-xs text-slate-500"><strong>AI keywords:</strong> <%= paper.ai_keywords %></div>
        <% } %>
        <% if (paper.file_path) { %>
          <a class="inline-block mt-4 text-sm text-indigo-600 hover:text-indigo-500 font-medium link-line" href="/author/papers/<%= paper.id %>/download">Download manuscript</a>
        <% } %>
      </div>

      <% if (decisions && decisions.length > 0) { %>
        <div class="mt-6">
          <h2 class="font-display text-lg font-semibold mb-3">Decision history</h2>
          <div class="space-y-2">
            <% decisions.forEach(d => { %>
              <div class="card p-4 flex items-start gap-3">
                <div class="h-8 w-8 rounded-full bg-indigo-100 text-indigo-700 flex items-center justify-center text-xs font-bold"><%= (d.editor_username || '?').slice(0,1).toUpperCase() %></div>
                <div class="flex-1">
                  <div class="text-sm"><strong><%= d.editor_username %></strong> set status to <strong class="capitalize"><%= d.to_status %></strong></div>
                  <% if (d.note) { %><div class="text-sm text-slate-600 mt-1"><%= d.note %></div><% } %>
                  <div class="text-xs text-slate-500 mt-1"><%= new Date(d.created_at).toLocaleString() %></div>
                </div>
              </div>
            <% }) %>
          </div>
        </div>
      <% } %>

      <div class="mt-6">
        <h2 class="font-display text-lg font-semibold mb-3">Reviews (<%= reviews.length %>)</h2>
        <% if (reviews.length === 0) { %>
          <p class="text-slate-500 text-sm">No reviews submitted yet.</p>
        <% } %>
        <% reviews.forEach(r => { %>
          <div class="card p-5 mb-3">
            <div class="flex items-center justify-between text-sm">
              <span class="font-medium"><%= r.reviewer_username %></span>
              <span class="text-slate-500"><%= r.review_date ? new Date(r.review_date).toLocaleDateString() : 'pending' %></span>
            </div>
            <% if (r.recommendation) { %>
              <div class="text-sm mt-2 inline-flex items-center gap-2">
                <span class="text-slate-500">Recommendation:</span>
                <span class="inline-block px-2 py-0.5 rounded-full text-xs font-medium bg-slate-100 text-slate-700"><%= r.recommendation.replace('_',' ') %></span>
                <% if (r.ai_assisted) { %><span class="text-xs text-indigo-700 bg-indigo-50 border border-indigo-200 px-2 py-0.5 rounded-full">AI-assisted</span><% } %>
              </div>
            <% } %>
            <% if (r.summary) { %><div class="mt-3 text-sm"><strong>Summary.</strong> <%= r.summary %></div><% } %>
            <% if (r.strengths) { %><div class="mt-2 text-sm"><strong>Strengths.</strong><br><%= r.strengths %></div><% } %>
            <% if (r.weaknesses) { %><div class="mt-2 text-sm"><strong>Weaknesses.</strong><br><%= r.weaknesses %></div><% } %>
          </div>
        <% }) %>
      </div>
    </div>
  </main>
  <%- include('../partials/footer') %>
</body>
</html>
