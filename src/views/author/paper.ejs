<!DOCTYPE html>
<html lang="en">
<head><%- include('../partials/head') %></head>
<body class="min-h-screen bg-slate-50 text-slate-900 flex flex-col">
  <%- include('../partials/nav') %>
  <main class="flex-1">
    <div class="max-w-7xl mx-auto px-6 py-8">
      <a href="/author" class="text-sm text-indigo-600 hover:text-indigo-500 link-line">Back to all submissions</a>
      <div class="dashboard-hero mt-4 mb-6">
        <div>
          <p class="eyebrow text-indigo-200">Submission record</p>
          <h1 class="font-display text-4xl font-bold text-white mt-2 leading-tight"><%= paper.title %></h1>
          <p class="text-sm text-slate-300 mt-2">Submitted <%= new Date(paper.submission_date).toLocaleString() %></p>
        </div>
        <%- include('../partials/status', { status: paper.review_status }) %>
      </div>

      <div class="grid md:grid-cols-3 gap-3 mb-6">
        <div class="metric-card">
          <div class="metric-label">Similarity to corpus</div>
          <div class="stat-num text-3xl mt-1"><%= (paper.similarity_score * 100).toFixed(1) %>%</div>
          <div class="text-xs text-slate-500 mt-1">Higher means closer to existing submissions.</div>
        </div>
        <div class="metric-card">
          <div class="metric-label">AI-text likelihood</div>
          <div class="stat-num text-3xl mt-1"><%= (paper.ai_text_likelihood * 100).toFixed(0) %>%</div>
          <div class="text-xs text-slate-500 mt-1">A heuristic signal, never a verdict.</div>
        </div>
        <div class="metric-card">
          <div class="metric-label">Reviews</div>
          <div class="stat-num text-3xl mt-1"><%= reviews.length %></div>
          <div class="text-xs text-slate-500 mt-1">Assigned or submitted reviews.</div>
        </div>
      </div>

      <div class="grid lg:grid-cols-[0.62fr_0.38fr] gap-6">
        <section class="space-y-5">
          <div class="card p-6">
            <h2 class="font-display text-2xl font-semibold">Abstract</h2>
            <p class="text-slate-700 mt-3 leading-relaxed whitespace-pre-line"><%= paper.abstract %></p>
            <% if (paper.tags) { %>
              <div class="mt-5 flex flex-wrap gap-1.5">
                <% paper.tags.split(',').forEach(t => { %>
                  <span class="inline-block text-xs bg-indigo-50 text-indigo-800 border border-indigo-100 px-2 py-0.5 rounded-full"><%= t.trim() %></span>
                <% }) %>
              </div>
            <% } %>
            <% if (paper.ai_keywords) { %>
              <div class="mt-4 rounded-md border border-slate-200 bg-slate-50 p-3 text-xs text-slate-600"><strong class="text-slate-800">AI keywords:</strong> <%= paper.ai_keywords %></div>
            <% } %>
            <% if (paper.file_path) { %>
              <a class="inline-block mt-5 bg-slate-950 hover:bg-slate-800 text-white text-sm px-3 py-2 rounded-md font-semibold transition" href="/author/papers/<%= paper.id %>/download">Download manuscript</a>
            <% } %>
          </div>

          <div>
            <h2 class="font-display text-2xl font-semibold mb-3">Reviews (<%= reviews.length %>)</h2>
            <% if (reviews.length === 0) { %>
              <div class="card p-6 text-slate-500 text-sm">No reviews have been submitted yet.</div>
            <% } %>
            <% reviews.forEach(r => { %>
              <div class="card p-5 mb-3">
                <div class="flex items-center justify-between gap-3 text-sm">
                  <span class="font-semibold"><%= r.reviewer_username %></span>
                  <span class="text-slate-500"><%= r.review_date ? new Date(r.review_date).toLocaleDateString() : 'pending' %></span>
                </div>
                <% if (r.recommendation) { %>
                  <div class="mt-3 flex flex-wrap items-center gap-2 text-sm">
                    <span class="score-chip">Recommendation <strong><%= r.recommendation.replace('_',' ') %></strong></span>
                    <% if (r.ai_assisted) { %><span class="score-chip">AI-assisted draft</span><% } %>
                  </div>
                <% } %>
                <% if (r.summary) { %><div class="mt-4 text-sm"><strong>Summary.</strong> <%= r.summary %></div><% } %>
                <% if (r.strengths) { %><div class="mt-3 text-sm"><strong>Strengths.</strong><br><%= r.strengths %></div><% } %>
                <% if (r.weaknesses) { %><div class="mt-3 text-sm"><strong>Weaknesses.</strong><br><%= r.weaknesses %></div><% } %>
              </div>
            <% }) %>
          </div>
        </section>

        <aside class="space-y-5">
          <div class="card p-5">
            <p class="eyebrow text-indigo-700">Status timeline</p>
            <div class="space-y-4 mt-4">
              <div class="process-step"><h3 class="font-semibold">Submitted</h3><p class="text-sm text-slate-600 mt-1"><%= new Date(paper.submission_date).toLocaleDateString() %></p></div>
              <div class="process-step"><h3 class="font-semibold">Screened</h3><p class="text-sm text-slate-600 mt-1">Integrity and keyword metadata generated.</p></div>
              <div class="process-step"><h3 class="font-semibold">Current status</h3><p class="text-sm text-slate-600 mt-1"><%= paper.review_status.replace('_', ' ') %></p></div>
            </div>
          </div>

          <% if (decisions && decisions.length > 0) { %>
            <div class="card p-5">
              <h2 class="font-display text-xl font-semibold mb-3">Decision history</h2>
              <div class="space-y-3">
                <% decisions.forEach(d => { %>
                  <div class="rounded-md border border-slate-200 bg-slate-50 p-3">
                    <div class="text-sm"><strong><%= d.editor_username %></strong> set status to <strong class="capitalize"><%= d.to_status %></strong></div>
                    <% if (d.note) { %><div class="text-sm text-slate-600 mt-1"><%= d.note %></div><% } %>
                    <div class="text-xs text-slate-500 mt-1"><%= new Date(d.created_at).toLocaleString() %></div>
                  </div>
                <% }) %>
              </div>
            </div>
          <% } %>
        </aside>
      </div>
    </div>
  </main>
  <%- include('../partials/footer') %>
</body>
</html>
