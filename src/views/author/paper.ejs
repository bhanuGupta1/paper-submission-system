<!DOCTYPE html>
<html lang="en">
<head><%- include('../partials/head') %></head>
<body class="min-h-screen flex flex-col" style="background:var(--surface-0);color:var(--text-primary)">
  <%- include('../partials/nav') %>
  <main class="flex-1">
    <div class="max-w-7xl mx-auto px-6 py-8">
      <a href="/author" class="text-sm link-line" style="color:var(--brand-600)">← All submissions</a>
      <div class="dashboard-hero mt-4 mb-6">
        <div class="flex-1">
          <p class="eyebrow text-indigo-200">Submission record · v<%= paper.current_version || 1 %></p>
          <h1 class="font-display text-4xl font-bold text-white mt-2 leading-tight"><%= paper.title %></h1>
          <p class="text-sm text-slate-300 mt-2">Submitted <%= new Date(paper.submission_date).toLocaleString() %></p>
        </div>
        <div class="flex flex-col gap-3 items-end">
          <%- include('../partials/status', { status: paper.review_status }) %>
          <% if (canRevise) { %>
            <a href="/author/papers/<%= paper.id %>/revise"
               class="bg-amber-500 hover:bg-amber-600 text-white text-sm px-4 py-2 rounded-md font-semibold transition inline-flex items-center gap-1.5">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
              Submit Revision
            </a>
          <% } %>
        </div>
      </div>

      <% if (paper.review_status === 'revisions' && paper.revision_note) { %>
        <div class="mb-6 bg-amber-50 border border-amber-200 rounded-lg p-4">
          <h3 class="font-semibold text-amber-800">Revision Required</h3>
          <p class="text-sm text-amber-700 mt-1"><%= paper.revision_note %></p>
        </div>
      <% } %>

      <div class="grid md:grid-cols-4 gap-3 mb-6">
        <div class="metric-card">
          <div class="metric-label">Similarity</div>
          <div class="stat-num text-3xl mt-1 <%= paper.similarity_score != null && paper.similarity_score > 0.7 ? 'text-red-600' : paper.similarity_score != null && paper.similarity_score > 0.4 ? 'text-amber-600' : paper.similarity_score != null ? 'text-emerald-600' : 'text-slate-400' %>"><%= paper.similarity_score != null ? (paper.similarity_score * 100).toFixed(0) + '%' : '—' %></div>
          <div class="text-xs text-slate-500 mt-1">Corpus overlap</div>
        </div>
        <div class="metric-card">
          <div class="metric-label">AI-text likelihood</div>
          <div class="stat-num text-3xl mt-1 <%= paper.ai_text_likelihood != null && paper.ai_text_likelihood > 0.7 ? 'text-amber-600' : paper.ai_text_likelihood != null ? 'text-slate-700' : 'text-slate-400' %>"><%= paper.ai_text_likelihood != null ? (paper.ai_text_likelihood * 100).toFixed(0) + '%' : '—' %></div>
          <div class="text-xs text-slate-500 mt-1">Heuristic signal</div>
        </div>
        <div class="metric-card">
          <div class="metric-label">Reviews</div>
          <div class="stat-num text-3xl mt-1"><%= reviews.length %></div>
          <div class="text-xs text-slate-500 mt-1">Submitted</div>
        </div>
        <div class="metric-card">
          <div class="metric-label">Version</div>
          <div class="stat-num text-3xl mt-1 text-indigo-600"><%= paper.current_version || 1 %></div>
          <div class="text-xs text-slate-500 mt-1"><%= versions.length %> revision<%= versions.length !== 1 ? 's' : '' %> total</div>
        </div>
      </div>

      <div class="grid lg:grid-cols-[0.62fr_0.38fr] gap-6">
        <section class="space-y-5">
          <!-- Abstract & paper info -->
          <div class="card p-6">
            <h2 class="font-display text-2xl font-semibold">Abstract</h2>
            <p class="mt-3 leading-relaxed whitespace-pre-line" style="color:var(--text-secondary)"><%= paper.abstract %></p>
            <% if (paper.tags) { %>
              <div class="mt-5 flex flex-wrap gap-1.5">
                <% paper.tags.split(',').forEach(t => { %>
                  <span class="inline-block text-xs bg-indigo-50 text-indigo-800 border border-indigo-100 px-2 py-0.5 rounded-full"><%= t.trim() %></span>
                <% }) %>
              </div>
            <% } %>
            <% if (paper.ai_keywords) { %>
              <div class="mt-4 rounded-md border p-3 text-xs" style="border-color:var(--border-default);background:var(--surface-1);color:var(--text-secondary)">
                <strong style="color:var(--text-primary)">AI keywords:</strong> <%= paper.ai_keywords %>
              </div>
            <% } %>
            <% if (paper.file_path) { %>
              <div class="mt-5 flex flex-wrap gap-2">
                <% if (paper.file_path.toLowerCase().endsWith('.pdf')) { %>
                  <button onclick="document.getElementById('pdf-viewer-<%= paper.id %>').classList.toggle('hidden')" class="btn btn-secondary btn-sm">
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
                    View PDF
                  </button>
                <% } %>
                <a class="btn btn-secondary btn-sm" href="/author/papers/<%= paper.id %>/download">
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
                  Download
                </a>
              </div>
              <% if (paper.file_path.toLowerCase().endsWith('.pdf')) { %>
                <div id="pdf-viewer-<%= paper.id %>" class="hidden mt-4 rounded-xl overflow-hidden border" style="border-color:var(--border-default)">
                  <iframe src="/author/papers/<%= paper.id %>/view" class="w-full" style="height:600px;border:none;display:block"></iframe>
                </div>
              <% } %>
            <% } %>
          </div>

          <!-- Reviews (double-blind — no reviewer names) -->
          <div>
            <h2 class="font-display text-2xl font-semibold mb-3">Reviewer feedback (<%= reviews.length %>)</h2>
            <p class="text-xs mb-3" style="color:var(--text-tertiary)">This system uses double-blind review. Reviewer identities are not disclosed.</p>
            <% if (reviews.length === 0) { %>
              <div class="card p-8 text-center">
                <div class="skeleton w-full mb-3" style="height:12px; width:60%; margin:0 auto"></div>
                <div class="skeleton w-full mb-3" style="height:12px; width:80%; margin:0 auto"></div>
                <p class="text-slate-500 text-sm mt-4">No reviews submitted yet.</p>
              </div>
            <% } %>
            <% reviews.forEach((r, i) => { %>
              <div class="card p-5 mb-3">
                <div class="flex items-center justify-between gap-3 text-sm mb-3">
                  <span class="font-semibold" style="color:var(--text-secondary)"><%= r.reviewer_username %></span>
                  <span class="text-xs" style="color:var(--text-tertiary)"><%= r.review_date ? new Date(r.review_date).toLocaleDateString() : 'Pending' %></span>
                </div>
                <% if (r.recommendation) { %>
                  <div class="flex flex-wrap gap-2 mb-3">
                    <span class="score-chip text-xs">
                      <span class="<%= r.recommendation === 'accept' ? 'text-emerald-700' : r.recommendation === 'reject' ? 'text-red-700' : 'text-amber-700' %>">
                        ● <%= r.recommendation.replace(/_/g, ' ') %>
                      </span>
                    </span>
                    <% if (r.novelty_score) { %><span class="score-chip text-xs">Novelty: <%= r.novelty_score %>/5</span><% } %>
                    <% if (r.clarity_score) { %><span class="score-chip text-xs">Clarity: <%= r.clarity_score %>/5</span><% } %>
                    <% if (r.significance_score) { %><span class="score-chip text-xs">Significance: <%= r.significance_score %>/5</span><% } %>
                    <% if (r.ai_assisted) { %><span class="score-chip text-xs text-indigo-600">AI-assisted</span><% } %>
                  </div>
                  <% if (r.summary) { %><div class="text-sm mb-2"><strong style="color:var(--text-primary)">Summary</strong><p style="color:var(--text-secondary)" class="mt-1"><%= r.summary %></p></div><% } %>
                  <% if (r.strengths) { %><div class="text-sm mb-2"><strong style="color:var(--text-primary)">Strengths</strong><p style="color:var(--text-secondary)" class="mt-1 whitespace-pre-line"><%= r.strengths %></p></div><% } %>
                  <% if (r.weaknesses) { %><div class="text-sm"><strong style="color:var(--text-primary)">Weaknesses</strong><p style="color:var(--text-secondary)" class="mt-1 whitespace-pre-line"><%= r.weaknesses %></p></div><% } %>
                <% } else { %>
                  <p class="text-sm italic" style="color:var(--text-tertiary)">Review in progress…</p>
                <% } %>
              </div>
            <% }) %>
          </div>
        </section>

        <aside class="space-y-5">
          <!-- Status timeline -->
          <div class="card p-5">
            <p class="eyebrow mb-3" style="color:var(--brand-600)">Status timeline</p>
            <div class="space-y-3">
              <div class="process-step"><h3 class="font-semibold text-sm" style="color:var(--text-primary)">Submitted</h3><p class="text-xs mt-0.5" style="color:var(--text-tertiary)"><%= new Date(paper.submission_date).toLocaleDateString() %></p></div>
              <div class="process-step"><h3 class="font-semibold text-sm" style="color:var(--text-primary)">AI screening</h3><p class="text-xs mt-0.5" style="color:var(--text-tertiary)">Plagiarism + keyword analysis complete.</p></div>
              <div class="process-step"><h3 class="font-semibold text-sm" style="color:var(--text-primary)">Current status</h3><p class="text-xs mt-0.5 capitalize" style="color:var(--text-tertiary)"><%= paper.review_status.replace('_', ' ') %></p></div>
            </div>
          </div>

          <!-- Decision history -->
          <% if (decisions && decisions.length > 0) { %>
            <div class="card p-5">
              <h2 class="font-display text-xl font-semibold mb-3">Decisions</h2>
              <div class="space-y-3">
                <% decisions.forEach(d => { %>
                  <div class="rounded-md border p-3" style="border-color:var(--border-default);background:var(--surface-1)">
                    <div class="text-sm font-medium capitalize" style="color:var(--text-primary)"><%= d.to_status.replace('_',' ') %></div>
                    <% if (d.note) { %><div class="text-sm mt-1" style="color:var(--text-secondary)"><%= d.note %></div><% } %>
                    <div class="text-xs mt-1" style="color:var(--text-tertiary)"><%= new Date(d.created_at).toLocaleString() %></div>
                  </div>
                <% }) %>
              </div>
            </div>
          <% } %>

          <!-- Revision history -->
          <% if (versions && versions.length > 1) { %>
            <div class="card p-5">
              <h2 class="font-display text-xl font-semibold mb-3">Revision history</h2>
              <div class="space-y-3">
                <% versions.forEach(v => { %>
                  <div class="rounded-md border p-3 text-sm" style="border-color:var(--border-default);background:var(--surface-1)">
                    <div class="flex items-center justify-between">
                      <span class="font-semibold" style="color:var(--text-primary)">Version <%= v.version_number %></span>
                      <span class="text-xs" style="color:var(--text-tertiary)"><%= new Date(v.submitted_at).toLocaleDateString() %></span>
                    </div>
                    <% if (v.change_note) { %>
                      <p class="text-xs mt-2 line-clamp-3 whitespace-pre-line" style="color:var(--text-secondary)"><%= v.change_note %></p>
                      <% if (v.change_note.length > 200) { %>
                        <button type="button" onclick="this.previousElementSibling.classList.toggle('line-clamp-3');this.textContent=this.textContent==='Read more'?'Show less':'Read more'"
                          class="text-xs mt-1 font-medium" style="color:var(--brand-600)">Read more</button>
                      <% } %>
                    <% } %>
                  </div>
                <% }) %>
              </div>
            </div>
          <% } %>
        </aside>
      </div>
    </div>
  </main>
  <%- include('../partials/footer') %>
</body>
</html>
