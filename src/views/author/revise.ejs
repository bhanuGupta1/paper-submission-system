<!DOCTYPE html>
<html lang="en">
<head><%- include('../partials/head') %></head>
<body class="min-h-screen bg-slate-50 text-slate-900 flex flex-col">
  <%- include('../partials/nav') %>
  <main class="flex-1">
    <div class="max-w-3xl mx-auto px-6 py-10">
      <div class="mb-6">
        <a href="/author/papers/<%= paper.id %>" class="text-indigo-600 hover:text-indigo-500 text-sm">← Back to paper</a>
        <h1 class="font-display text-3xl font-bold mt-2">Submit Revision</h1>
        <p class="text-slate-500 mt-1">Version <%= paper.current_version %> → <%= paper.current_version + 1 %></p>
      </div>

      <% if (error) { %>
        <div class="mb-6 bg-red-50 border border-red-200 text-red-800 text-sm p-3 rounded-md" role="alert"><%= error %></div>
      <% } %>

      <div class="bg-amber-50 border border-amber-200 rounded-lg p-4 mb-6">
        <h3 class="font-semibold text-amber-800">Revision Required</h3>
        <% if (paper.revision_note) { %>
          <p class="text-sm text-amber-700 mt-1"><%= paper.revision_note %></p>
        <% } else { %>
          <p class="text-sm text-amber-700 mt-1">Please address reviewer feedback and provide a response note describing your changes.</p>
        <% } %>
      </div>

      <form action="/author/papers/<%= paper.id %>/revise" method="post" enctype="multipart/form-data" class="card p-8 space-y-6" id="reviseForm">
        <div>
          <label for="title" class="block text-sm font-semibold text-slate-700">Title <span class="text-red-500">*</span></label>
          <input id="title" name="title" required value="<%= paper.title %>"
            class="mt-1 block w-full rounded-md border border-slate-300 px-3 py-2.5 focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 focus:outline-none">
        </div>

        <div>
          <label for="authors" class="block text-sm font-semibold text-slate-700">Author list <span class="text-red-500">*</span></label>
          <input id="authors" name="authors" required value="<%= paper.authors %>"
            class="mt-1 block w-full rounded-md border border-slate-300 px-3 py-2.5 focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 focus:outline-none">
          <p class="text-xs text-slate-500 mt-1">Full names, comma-separated</p>
        </div>

        <div>
          <label for="abstract" class="block text-sm font-semibold text-slate-700">Abstract <span class="text-red-500">*</span></label>
          <textarea id="abstract" name="abstract" rows="8" required
            class="mt-1 block w-full rounded-md border border-slate-300 px-3 py-2.5 focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 focus:outline-none font-mono text-sm"><%= paper.abstract %></textarea>
          <p class="text-xs text-slate-500 mt-1"><span id="abstractWc">0</span> words</p>
        </div>

        <div>
          <label for="keywords" class="block text-sm font-semibold text-slate-700">Keywords</label>
          <input id="keywords" name="keywords" value="<%= paper.keywords || '' %>"
            class="mt-1 block w-full rounded-md border border-slate-300 px-3 py-2.5 focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 focus:outline-none">
          <p class="text-xs text-slate-500 mt-1">Comma-separated</p>
        </div>

        <div>
          <label class="block text-sm font-semibold text-slate-700">Revised manuscript (optional)</label>
          <div class="mt-1 border-2 border-dashed border-slate-300 rounded-lg p-6 text-center hover:border-indigo-400 transition">
            <input type="file" name="paperFile" id="paperFile" accept=".pdf,.doc,.docx,.txt" class="hidden" onchange="updateFilename(this)">
            <label for="paperFile" class="cursor-pointer">
              <svg class="mx-auto h-8 w-8 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"/></svg>
              <p class="mt-2 text-sm text-slate-600" id="fileLabel">Click to upload or drag and drop PDF, DOCX, or TXT (max 10 MB)</p>
              <p class="text-xs text-slate-500 mt-1">Leave empty to keep the existing file</p>
            </label>
          </div>
        </div>

        <div>
          <label for="changeNote" class="block text-sm font-semibold text-slate-700">Response to reviewers <span class="text-red-500">*</span></label>
          <textarea id="changeNote" name="changeNote" rows="5" required minlength="10" placeholder="Describe the changes you made and how you addressed reviewer comments..."
            class="mt-1 block w-full rounded-md border border-slate-300 px-3 py-2.5 focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 focus:outline-none"></textarea>
          <p class="text-xs text-slate-500 mt-1">This note will be visible to editors when reviewing your revision.</p>
        </div>

        <div class="flex gap-3 pt-2">
          <button type="submit" class="bg-indigo-600 hover:bg-indigo-700 text-white px-6 py-2.5 rounded-md font-semibold transition" id="submitBtn">
            Submit revision
          </button>
          <a href="/author/papers/<%= paper.id %>" class="px-6 py-2.5 rounded-md border border-slate-300 text-slate-700 hover:bg-slate-100 font-medium transition">Cancel</a>
        </div>
      </form>
    </div>
  </main>
  <%- include('../partials/footer') %>
  <script>
    function updateFilename(input) {
      const label = document.getElementById('fileLabel');
      label.textContent = input.files[0] ? input.files[0].name : 'Click to upload or drag and drop PDF, DOCX, or TXT (max 10 MB)';
    }
    const abstract = document.getElementById('abstract');
    const wc = document.getElementById('abstractWc');
    function updateWc() { wc.textContent = abstract.value.trim().split(/\s+/).filter(Boolean).length; }
    abstract.addEventListener('input', updateWc);
    updateWc();
    document.getElementById('reviseForm').addEventListener('submit', (e) => {
      const btn = document.getElementById('submitBtn');
      btn.disabled = true;
      btn.textContent = 'Submitting…';
    });
  </script>
</body>
</html>
