<!DOCTYPE html>
<html lang="en">
<head><%- include('../partials/head') %></head>
<body class="min-h-screen flex flex-col" style="background:var(--surface-0);color:var(--text-primary)">
  <%- include('../partials/nav') %>
  <main class="flex-1">
    <div class="max-w-3xl mx-auto px-6 py-10">
      <div class="mb-6">
        <a href="/author/papers/<%= paper.id %>" class="text-sm link-line" style="color:var(--brand-600)">← Back to paper</a>
        <h1 class="font-display text-3xl font-bold mt-2" style="color:var(--text-primary)">Submit Revision</h1>
        <p class="text-sm mt-1" style="color:var(--text-secondary)">Version <%= paper.current_version %> → <%= paper.current_version + 1 %></p>
      </div>

      <% if (error) { %>
        <div class="alert alert-warning mb-5" role="alert">
          <svg class="w-4 h-4 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
          <span><%= error %></span>
        </div>
      <% } %>

      <div class="rounded-lg border p-4 mb-6" style="background:var(--warning-50);border-color:var(--warning-200)">
        <h3 class="font-semibold" style="color:var(--warning-800)">Revision Required</h3>
        <% if (paper.revision_note) { %>
          <p class="text-sm mt-1" style="color:var(--warning-700)"><%= paper.revision_note %></p>
        <% } else { %>
          <p class="text-sm mt-1" style="color:var(--warning-700)">Please address reviewer feedback and provide a response note describing your changes.</p>
        <% } %>
      </div>

      <form action="/author/papers/<%= paper.id %>/revise" method="post" enctype="multipart/form-data" class="card p-8 space-y-5" id="reviseForm">

        <div>
          <label for="title" class="block text-sm font-semibold mb-1.5" style="color:var(--text-secondary)">
            Title <span style="color:var(--error-600)">*</span>
          </label>
          <input id="title" name="title" required value="<%= paper.title %>"
            class="block w-full rounded-lg border px-3.5 py-2.5 text-sm"
            style="background:var(--surface-1);border-color:var(--border-default);color:var(--text-primary)">
        </div>

        <div>
          <label for="authors" class="block text-sm font-semibold mb-1.5" style="color:var(--text-secondary)">
            Author list <span style="color:var(--error-600)">*</span>
          </label>
          <input id="authors" name="authors" required value="<%= paper.authors %>"
            class="block w-full rounded-lg border px-3.5 py-2.5 text-sm"
            style="background:var(--surface-1);border-color:var(--border-default);color:var(--text-primary)">
          <p class="text-xs mt-1.5" style="color:var(--text-tertiary)">Full names, comma-separated</p>
        </div>

        <div>
          <label for="abstract" class="block text-sm font-semibold mb-1.5" style="color:var(--text-secondary)">
            Abstract <span style="color:var(--error-600)">*</span>
          </label>
          <textarea id="abstract" name="abstract" rows="8" required
            class="block w-full rounded-lg border px-3.5 py-2.5 text-sm font-mono"
            style="background:var(--surface-1);border-color:var(--border-default);color:var(--text-primary)"><%= paper.abstract %></textarea>
          <p class="text-xs mt-1.5" style="color:var(--text-tertiary)"><span id="abstractWc">0</span> words</p>
        </div>

        <div>
          <label for="keywords" class="block text-sm font-semibold mb-1.5" style="color:var(--text-secondary)">Keywords</label>
          <input id="keywords" name="keywords" value="<%= paper.keywords || '' %>" placeholder="Comma-separated"
            class="block w-full rounded-lg border px-3.5 py-2.5 text-sm"
            style="background:var(--surface-1);border-color:var(--border-default);color:var(--text-primary)">
        </div>

        <div>
          <label class="block text-sm font-semibold mb-1.5" style="color:var(--text-secondary)">Revised manuscript <span class="font-normal text-xs" style="color:var(--text-tertiary)">(optional)</span></label>
          <div class="rounded-lg border-2 border-dashed p-6 text-center transition"
               style="border-color:var(--border-default);background:var(--surface-1)">
            <input type="file" name="paperFile" id="paperFile" accept=".pdf,.doc,.docx,.txt" class="hidden" onchange="updateFilename(this)">
            <label for="paperFile" class="cursor-pointer block">
              <svg class="mx-auto h-8 w-8 mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="color:var(--text-tertiary)"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"/></svg>
              <p class="text-sm" id="fileLabel" style="color:var(--text-secondary)">Click to upload · PDF, DOCX, or TXT · max 10 MB</p>
              <p class="text-xs mt-1" style="color:var(--text-tertiary)">Leave empty to keep the existing file</p>
            </label>
          </div>
        </div>

        <div>
          <label for="changeNote" class="block text-sm font-semibold mb-1.5" style="color:var(--text-secondary)">
            Response to reviewers <span style="color:var(--error-600)">*</span>
          </label>
          <textarea id="changeNote" name="changeNote" rows="5" required minlength="10"
            placeholder="Describe the changes you made and how you addressed reviewer comments…"
            class="block w-full rounded-lg border px-3.5 py-2.5 text-sm"
            style="background:var(--surface-1);border-color:var(--border-default);color:var(--text-primary)"></textarea>
          <p class="text-xs mt-1.5" style="color:var(--text-tertiary)">Visible to editors when reviewing your revision.</p>
        </div>

        <div class="flex gap-3 pt-2">
          <button type="submit" class="btn btn-primary px-6" id="submitBtn">Submit revision</button>
          <a href="/author/papers/<%= paper.id %>" class="btn btn-secondary px-6">Cancel</a>
        </div>
      </form>
    </div>
  </main>
  <%- include('../partials/footer') %>
  <script>
    function updateFilename(input) {
      document.getElementById('fileLabel').textContent = input.files[0]
        ? input.files[0].name
        : 'Click to upload · PDF, DOCX, or TXT · max 10 MB';
    }
    const abstract = document.getElementById('abstract');
    const wc = document.getElementById('abstractWc');
    function updateWc() { wc.textContent = abstract.value.trim().split(/\s+/).filter(Boolean).length; }
    abstract.addEventListener('input', updateWc);
    updateWc();
    document.getElementById('reviseForm').addEventListener('submit', () => {
      const btn = document.getElementById('submitBtn');
      btn.disabled = true;
      btn.textContent = 'Submitting…';
    });
  </script>
</body>
</html>
