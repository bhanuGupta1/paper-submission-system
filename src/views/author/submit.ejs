<!DOCTYPE html>
<html lang="en">
<head><%- include('../partials/head') %></head>
<body class="min-h-screen flex flex-col" style="background:var(--surface-0);color:var(--text-primary)">
  <%- include('../partials/nav') %>
  <main class="flex-1">
    <div class="max-w-7xl mx-auto px-6 py-8">
      <div class="dashboard-hero mb-6">
        <div>
          <p class="eyebrow text-indigo-200">New submission</p>
          <h1 class="font-display text-4xl font-bold text-white mt-2">Submit a paper</h1>
          <p class="text-sm text-slate-300 mt-2 max-w-2xl">Use optional AI assistance to refine metadata before your manuscript enters reviewer matching.</p>
        </div>
      </div>

      <% if (error) { %>
        <div class="alert alert-warning mb-5" role="alert">
          <svg class="w-4 h-4 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
          <span><%= error %></span>
        </div>
      <% } %>

      <div class="grid lg:grid-cols-[0.68fr_0.32fr] gap-6">
        <form action="/author/submit" method="post" enctype="multipart/form-data" class="glass-card gradient-border-card p-6 sm:p-8 space-y-5">

          <div class="grid md:grid-cols-2 gap-4">
            <div class="md:col-span-2">
              <label class="block text-sm font-semibold mb-1.5" style="color:var(--text-secondary)">Title</label>
              <input id="title" name="title" required placeholder="A concise, descriptive manuscript title"
                class="block w-full rounded-lg border px-3.5 py-2.5 text-sm"
                style="background:var(--surface-1);border-color:var(--border-default);color:var(--text-primary)">
            </div>
            <div class="md:col-span-2">
              <label class="block text-sm font-semibold mb-1.5" style="color:var(--text-secondary)">
                Authors <span class="font-normal text-xs" style="color:var(--text-tertiary)">(comma-separated)</span>
              </label>
              <input name="authors" required placeholder="Jane Smith, John Doe"
                class="block w-full rounded-lg border px-3.5 py-2.5 text-sm"
                style="background:var(--surface-1);border-color:var(--border-default);color:var(--text-primary)">
            </div>
          </div>

          <div>
            <div class="flex flex-wrap items-center justify-between gap-3 mb-2">
              <label class="block text-sm font-semibold" style="color:var(--text-secondary)" for="abstract">Abstract</label>
              <div class="flex flex-wrap gap-2">
                <button type="button" id="polishBtn"
                  class="text-xs px-2.5 py-1 rounded-md font-semibold border transition"
                  style="background:var(--brand-50);color:var(--brand-700);border-color:var(--brand-200)">Polish</button>
                <button type="button" id="titlesBtn"
                  class="text-xs px-2.5 py-1 rounded-md font-semibold border transition"
                  style="background:var(--brand-50);color:var(--brand-700);border-color:var(--brand-200)">Suggest titles</button>
                <button type="button" id="kwBtn"
                  class="text-xs px-2.5 py-1 rounded-md font-semibold border transition"
                  style="background:var(--brand-50);color:var(--brand-700);border-color:var(--brand-200)">Extract keywords</button>
              </div>
            </div>
            <textarea id="abstract" name="abstract" rows="9" required placeholder="Minimum 50 characters."
              class="block w-full rounded-lg border px-3.5 py-2.5 text-sm"
              style="background:var(--surface-1);border-color:var(--border-default);color:var(--text-primary)"></textarea>
            <div id="aiPanel" class="hidden mt-3 rounded-lg border p-4 text-sm space-y-2"
                 style="background:var(--brand-50);border-color:var(--brand-200);color:var(--brand-950)"></div>
          </div>

          <div class="grid md:grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-semibold mb-1.5" style="color:var(--text-secondary)">
                Keywords <span class="font-normal text-xs" style="color:var(--text-tertiary)">(optional)</span>
              </label>
              <input id="keywords" name="keywords" placeholder="machine learning, NLP"
                class="block w-full rounded-lg border px-3.5 py-2.5 text-sm"
                style="background:var(--surface-1);border-color:var(--border-default);color:var(--text-primary)">
            </div>
            <div>
              <label class="block text-sm font-semibold mb-1.5" style="color:var(--text-secondary)">
                Tags <span class="font-normal text-xs" style="color:var(--text-tertiary)">(optional)</span>
              </label>
              <input name="tags" placeholder="NLP, ML, education"
                class="block w-full rounded-lg border px-3.5 py-2.5 text-sm"
                style="background:var(--surface-1);border-color:var(--border-default);color:var(--text-primary)">
            </div>
            <% if (tracks && tracks.length > 0) { %>
            <div class="md:col-span-2">
              <label class="block text-sm font-semibold mb-1.5" style="color:var(--text-secondary)">
                Track <span class="font-normal text-xs" style="color:var(--text-tertiary)">(optional)</span>
              </label>
              <select name="trackId" id="trackId"
                class="block w-full rounded-lg border px-3.5 py-2.5 text-sm"
                style="background:var(--surface-1);border-color:var(--border-default);color:var(--text-primary)">
                <option value="">No specific track</option>
                <% tracks.forEach(t => { %>
                  <option value="<%= t.id %>" data-deadline="<%= t.submission_deadline || '' %>">
                    <%= t.name %><% if (t.submission_deadline) { %> (deadline: <%= new Date(t.submission_deadline).toLocaleDateString() %>)<% } %>
                  </option>
                <% }) %>
              </select>
              <p id="track-deadline-warning" class="hidden mt-1.5 text-xs font-medium" style="color:var(--warning-700)"></p>
            </div>
            <% } %>
          </div>

          <!-- Writing quality feedback -->
          <div>
            <button type="button" id="feedbackBtn"
              class="text-xs px-2.5 py-1 rounded-md font-semibold border transition inline-flex items-center gap-1.5"
              style="background:var(--surface-1);color:var(--text-secondary);border-color:var(--border-default)">
              <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/></svg>
              Check writing quality
            </button>
            <div id="feedbackPanel" class="hidden mt-3 rounded-lg border p-4 space-y-1.5"
                 style="background:var(--surface-1);border-color:var(--border-default)"></div>
          </div>

          <!-- File upload -->
          <div class="rounded-lg border-2 border-dashed p-5" style="border-color:var(--border-default);background:var(--surface-1)">
            <label class="block text-sm font-semibold mb-2" style="color:var(--text-secondary)">Manuscript file</label>
            <input type="file" name="paperFile" accept=".pdf,.doc,.docx,.txt"
              class="block w-full text-sm" style="color:var(--text-secondary)">
            <p class="text-xs mt-2" style="color:var(--text-tertiary)">PDF, DOC, DOCX, or TXT · max 10 MB</p>
          </div>

          <!-- AI Pre-submission Screening -->
          <div class="rounded-xl border p-5 space-y-3" style="background:var(--surface-1);border-color:var(--border-default)">
            <div class="flex items-center justify-between flex-wrap gap-2">
              <div>
                <p class="text-sm font-semibold" style="color:var(--text-primary)">AI Pre-submission Checks</p>
                <p class="text-xs mt-0.5" style="color:var(--text-tertiary)">AI Suggestion — review before submitting</p>
              </div>
              <div class="flex flex-wrap gap-2">
                <button type="button" id="runScreeningBtn" class="btn btn-sm" style="background:var(--brand-600);color:white;border-color:var(--brand-600)">Desk check</button>
                <button type="button" id="runEthicsBtn" class="btn btn-sm" style="background:var(--surface-0);color:var(--text-secondary);border-color:var(--border-default)">Ethics</button>
                <button type="button" id="runCitationBtn" class="btn btn-sm" style="background:var(--surface-0);color:var(--text-secondary);border-color:var(--border-default)">Citations</button>
              </div>
            </div>
            <div id="screeningPanel" class="hidden space-y-2"></div>
            <div id="ethicsPanel" class="hidden space-y-2"></div>
            <div id="citationPanel" class="hidden space-y-2"></div>
          </div>

          <!-- Advanced Writing Tools -->
          <div class="rounded-xl border p-5 space-y-3" style="background:var(--surface-1);border-color:var(--border-default)">
            <div class="flex items-center justify-between flex-wrap gap-2">
              <p class="text-sm font-semibold" style="color:var(--text-primary)">Advanced Writing Tools</p>
              <div class="flex flex-wrap gap-2">
                <button type="button" id="writingScoreBtn" class="btn btn-sm" style="background:var(--surface-0);color:var(--text-secondary);border-color:var(--border-default)">Score abstract</button>
                <button type="button" id="toneImproveBtn" class="btn btn-sm" style="background:var(--surface-0);color:var(--text-secondary);border-color:var(--border-default)">Improve tone</button>
              </div>
            </div>
            <div id="writingScorePanel" class="hidden text-sm space-y-1.5"></div>
            <div id="tonePanel" class="hidden text-sm space-y-2"></div>
            <div class="border-t pt-3" style="border-color:var(--border-default)">
              <p class="text-xs font-semibold mb-2" style="color:var(--text-tertiary)">Section-by-section feedback</p>
              <div class="flex gap-2 mb-2 flex-wrap">
                <select id="sectionType" class="rounded-md border px-2.5 py-1.5 text-xs" style="background:var(--surface-0);border-color:var(--border-default);color:var(--text-primary)">
                  <option value="introduction">Introduction</option>
                  <option value="methods">Methods</option>
                  <option value="results">Results</option>
                  <option value="discussion">Discussion</option>
                  <option value="conclusion">Conclusion</option>
                  <option value="abstract">Abstract</option>
                </select>
                <button type="button" id="sectionFeedbackBtn" class="btn btn-sm" style="background:var(--surface-0);color:var(--text-secondary);border-color:var(--border-default)">Get feedback</button>
              </div>
              <textarea id="sectionText" rows="4" placeholder="Paste a manuscript section here for AI feedback…"
                class="block w-full rounded-lg border px-3 py-2 text-xs"
                style="background:var(--surface-0);border-color:var(--border-default);color:var(--text-primary)"></textarea>
              <div id="sectionFeedbackPanel" class="hidden mt-2 space-y-1"></div>
            </div>
          </div>

          <!-- AI Insights (v3) -->
          <div class="rounded-xl border p-5 space-y-3" style="background:var(--surface-1);border-color:var(--border-default)">
            <div class="flex items-center justify-between flex-wrap gap-2">
              <div>
                <p class="text-sm font-semibold" style="color:var(--text-primary)">AI Insights</p>
                <p class="text-xs mt-0.5" style="color:var(--text-tertiary)">AI Suggestion — uses title + abstract · review before submitting</p>
              </div>
              <div class="flex flex-wrap gap-2">
                <button type="button" id="plainSummaryBtn" class="btn btn-sm" style="background:var(--brand-600);color:white;border-color:var(--brand-600)">Plain-language summary</button>
                <button type="button" id="contribBtn" class="btn btn-sm" style="background:var(--surface-0);color:var(--text-secondary);border-color:var(--border-default)">Key contributions</button>
                <button type="button" id="titleCheckBtn" class="btn btn-sm" style="background:var(--surface-0);color:var(--text-secondary);border-color:var(--border-default)">Title ↔ abstract</button>
                <button type="button" id="limitationsBtn" class="btn btn-sm" style="background:var(--surface-0);color:var(--text-secondary);border-color:var(--border-default)">Limitations</button>
              </div>
            </div>
            <div id="plainSummaryPanel" class="hidden text-sm space-y-2"></div>
            <div id="contribPanel" class="hidden text-sm space-y-2"></div>
            <div id="titleCheckPanel" class="hidden text-sm space-y-2"></div>
            <div id="limitationsPanel" class="hidden text-sm space-y-2"></div>
          </div>

          <div class="flex items-center justify-end pt-1">
            <button class="btn-gradient shimmer-btn">
              Submit for review
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
            </button>
          </div>
        </form>

        <aside class="space-y-4">
          <div class="glass-card p-5">
            <p class="eyebrow mb-4" style="color:var(--brand-600)">Review pipeline</p>
            <div class="space-y-4">
              <div class="process-step"><h3 class="font-semibold text-sm" style="color:var(--text-primary)">1. Metadata</h3><p class="text-sm mt-1" style="color:var(--text-secondary)">Title, authors, abstract, keywords, and optional tags.</p></div>
              <div class="process-step"><h3 class="font-semibold text-sm" style="color:var(--text-primary)">2. Integrity signals</h3><p class="text-sm mt-1" style="color:var(--text-secondary)">Similarity and AI-text likelihood for editor triage.</p></div>
              <div class="process-step"><h3 class="font-semibold text-sm" style="color:var(--text-primary)">3. Reviewer matching</h3><p class="text-sm mt-1" style="color:var(--text-secondary)">Expertise vectors and COI checks find the best reviewers.</p></div>
              <div class="process-step"><h3 class="font-semibold text-sm" style="color:var(--text-primary)">4. Decision</h3><p class="text-sm mt-1" style="color:var(--text-secondary)">Editors make the final call with a full audit trail.</p></div>
            </div>
          </div>
          <div class="glass-card p-5">
            <h2 class="font-display text-lg font-semibold" style="color:var(--text-primary)">AI transparency</h2>
            <p class="text-sm mt-2 leading-relaxed" style="color:var(--text-secondary)">Assists are optional, logged, and support human authorship — not replace editorial judgement.</p>
          </div>
        </aside>
      </div>
    </div>
  </main>
  <%- include('../partials/footer') %>

  <script>
    const $ = (id) => document.getElementById(id);
    const panel = $('aiPanel');
    const showPanel = (html) => { panel.classList.remove('hidden'); panel.innerHTML = html; };
    const escapeHtml = (value) => String(value || '').replace(/[&<>"']/g, (ch) => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[ch]));
    const callAI = async (path, body) => {
      const r = await fetch(path, { method: 'POST', headers: {'Content-Type':'application/json'}, body: JSON.stringify(body) });
      if (!r.ok) throw new Error('AI request failed');
      return r.json();
    };

    $('polishBtn').addEventListener('click', async () => {
      const text = $('abstract').value.trim();
      if (!text) return showPanel('<em>Write an abstract first.</em>');
      showPanel('<em>Polishing the abstract…</em>');
      try {
        const out = await callAI('/api/ai/polish', { text });
        const revised = escapeHtml(out.revised || '');
        const tips = (out.suggestions || []).map((s) => '<li>' + escapeHtml(s) + '</li>').join('');
        showPanel(`<div class="font-semibold mb-2">Suggested revision</div>
                   <div class="rounded-md p-3 text-sm mb-2" style="background:var(--surface-0);border:1px solid var(--border-default)">${revised}</div>
                   ${tips ? '<ul class="list-disc list-inside text-sm space-y-1">' + tips + '</ul>' : ''}
                   <button id="applyPolish" type="button" class="btn btn-sm btn-primary mt-2">Apply revision</button>`);
        document.getElementById('applyPolish').onclick = () => { $('abstract').value = out.revised || $('abstract').value; };
      } catch { showPanel('<em>Could not contact AI service.</em>'); }
    });

    $('titlesBtn').addEventListener('click', async () => {
      const abs = $('abstract').value.trim();
      if (!abs) return showPanel('<em>Write an abstract first.</em>');
      showPanel('<em>Generating titles…</em>');
      try {
        const out = await callAI('/api/ai/titles', { abstract: abs });
        showPanel('<div class="font-semibold mb-2">Suggested titles</div><ul class="list-disc list-inside text-sm space-y-1">' +
          (out.titles || []).map((t) => `<li><button type="button" class="text-left hover:underline" data-title="${escapeHtml(t)}">${escapeHtml(t)}</button></li>`).join('') + '</ul>');
        panel.querySelectorAll('button[data-title]').forEach((b) => { b.onclick = () => { $('title').value = b.dataset.title; }; });
      } catch { showPanel('<em>Could not contact AI service.</em>'); }
    });

    $('kwBtn').addEventListener('click', async () => {
      const abs = $('abstract').value.trim();
      if (!abs) return showPanel('<em>Write an abstract first.</em>');
      showPanel('<em>Extracting keywords…</em>');
      try {
        const out = await callAI('/api/ai/keywords', { abstract: abs });
        $('keywords').value = (out.keywords || []).join(', ');
        showPanel('<em>Keywords filled in below.</em>');
      } catch { showPanel('<em>Could not contact AI service.</em>'); }
    });

    const feedbackPanel = $('feedbackPanel');
    $('feedbackBtn').addEventListener('click', async () => {
      const text = $('abstract').value.trim();
      if (!text) { feedbackPanel.classList.remove('hidden'); feedbackPanel.innerHTML = '<em class="text-sm">Write an abstract first.</em>'; return; }
      feedbackPanel.classList.remove('hidden');
      feedbackPanel.innerHTML = '<em class="text-sm">Analysing abstract…</em>';
      try {
        const resp = await fetch('/api/ai/writing-feedback', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ text, type: 'abstract' }),
        });
        if (!resp.ok) throw new Error('failed');
        const out = await resp.json();
        const levelIcon = { error: '❌', warning: '⚠️', success: '✅', info: 'ℹ️' };
        const levelColor = { error: 'var(--error-700)', warning: 'var(--warning-700)', success: 'var(--success-700)', info: 'var(--text-secondary)' };
        let html = '<div class="text-xs font-semibold mb-2" style="color:var(--text-tertiary)">' + out.wordCount + ' words · ' + out.sentenceCount + ' sentences</div>'
          + (out.feedback || []).map(f =>
            '<div class="text-xs" style="color:' + (levelColor[f.level] || 'var(--text-secondary)') + '">'
            + (levelIcon[f.level] || '•') + ' ' + escapeHtml(f.message) + '</div>'
          ).join('');
        if (out.aiSuggestions && out.aiSuggestions.length) {
          html += '<div class="text-xs font-semibold mt-3 mb-1" style="color:var(--brand-600)">AI suggestions</div>'
            + out.aiSuggestions.map(s => '<div class="text-xs" style="color:var(--text-secondary)">✦ ' + escapeHtml(s) + '</div>').join('');
        }
        feedbackPanel.innerHTML = html;
      } catch {
        feedbackPanel.innerHTML = '<em class="text-xs" style="color:var(--error-700)">Could not contact AI service.</em>';
      }
    });

    const trackSel = $('trackId');
    const deadlineWarn = $('track-deadline-warning');
    if (trackSel && deadlineWarn) {
      trackSel.addEventListener('change', function () {
        const opt = this.options[this.selectedIndex];
        const dl = opt && opt.dataset.deadline;
        if (dl) {
          const dlDate = new Date(dl);
          const diffDays = Math.ceil((dlDate - Date.now()) / 86400000);
          if (diffDays < 0) {
            deadlineWarn.textContent = '⚠ This track\'s submission deadline has passed (' + dlDate.toLocaleDateString() + ').';
            deadlineWarn.classList.remove('hidden');
          } else if (diffDays <= 7) {
            deadlineWarn.textContent = '⏰ Deadline approaching: ' + dlDate.toLocaleDateString() + ' (' + diffDays + ' day' + (diffDays !== 1 ? 's' : '') + ' remaining).';
            deadlineWarn.classList.remove('hidden');
          } else {
            deadlineWarn.classList.add('hidden');
          }
        } else {
          deadlineWarn.classList.add('hidden');
        }
      });
    }

    // ── AI Pre-submission Checks ──────────────────────────────────────────────
    const screeningPanel = $('screeningPanel');
    const ethicsPanel    = $('ethicsPanel');
    const citationPanel  = $('citationPanel');

    function verdictBadge(verdict) {
      const bg = { PASS: '#16a34a', WARN: '#d97706', FAIL: '#dc2626' };
      const v = (verdict || 'WARN').toUpperCase();
      return `<span class="text-xs font-bold px-2 py-0.5 rounded-full" style="background:${bg[v] || bg.WARN};color:white">${escapeHtml(v)}</span>`;
    }

    function renderIssues(items) {
      if (!items || !items.length) return '';
      return '<ul class="text-xs space-y-1 mt-1.5 pl-1">' +
        items.map(i => '<li style="color:var(--text-secondary)">• ' + escapeHtml(typeof i === 'string' ? i : (i.message || i.description || String(i))) + '</li>').join('') +
        '</ul>';
    }

    $('runScreeningBtn').addEventListener('click', async () => {
      const title    = $('title').value.trim();
      const abstract = $('abstract').value.trim();
      if (!title || !abstract) {
        screeningPanel.classList.remove('hidden');
        screeningPanel.innerHTML = '<p class="text-xs" style="color:var(--warning-700)">Fill in title and abstract first.</p>';
        return;
      }
      screeningPanel.classList.remove('hidden');
      screeningPanel.innerHTML = '<p class="text-xs" style="color:var(--text-tertiary)">Running desk rejection check…</p>';
      try {
        const words = abstract.split(/\s+/).filter(Boolean).length;
        const out = await callAI('/api/ai/pre-submission-check', {
          title, abstract, wordCount: words, sections: 1, referenceCount: 0,
          keywords: $('keywords').value.trim() || null,
        });
        const confidence = out.confidence != null ? ' · ' + out.confidence + '% confidence' : '';
        screeningPanel.innerHTML =
          '<div class="flex items-center gap-2 flex-wrap">' + verdictBadge(out.verdict) +
          '<span class="text-xs" style="color:var(--text-tertiary)">' + escapeHtml(out.summary || '') + escapeHtml(confidence) + '</span></div>' +
          renderIssues(out.issues);
      } catch {
        screeningPanel.innerHTML = '<p class="text-xs" style="color:var(--error-700)">Could not contact AI service.</p>';
      }
    });

    $('runEthicsBtn').addEventListener('click', async () => {
      const abstract = $('abstract').value.trim();
      if (!abstract) {
        ethicsPanel.classList.remove('hidden');
        ethicsPanel.innerHTML = '<p class="text-xs" style="color:var(--warning-700)">Write an abstract first.</p>';
        return;
      }
      ethicsPanel.classList.remove('hidden');
      ethicsPanel.innerHTML = '<p class="text-xs" style="color:var(--text-tertiary)">Checking ethics & compliance…</p>';
      try {
        const out = await callAI('/api/ai/ethics-check', {
          title: $('title').value.trim(), abstract,
        });
        ethicsPanel.innerHTML =
          '<div class="flex items-center gap-2 flex-wrap">' + verdictBadge(out.verdict) +
          '<span class="text-xs" style="color:var(--text-tertiary)">' + escapeHtml(out.summary || '') + '</span></div>' +
          renderIssues(out.flags);
      } catch {
        ethicsPanel.innerHTML = '<p class="text-xs" style="color:var(--error-700)">Could not contact AI service.</p>';
      }
    });

    $('runCitationBtn').addEventListener('click', async () => {
      const abstract = $('abstract').value.trim();
      if (!abstract) {
        citationPanel.classList.remove('hidden');
        citationPanel.innerHTML = '<p class="text-xs" style="color:var(--warning-700)">Write an abstract first.</p>';
        return;
      }
      citationPanel.classList.remove('hidden');
      citationPanel.innerHTML = '<p class="text-xs" style="color:var(--text-tertiary)">Checking citations…</p>';
      try {
        const out = await callAI('/api/ai/citation-check', { abstract });
        const hasSuspect = out.suspectCitations && out.suspectCitations.length > 0;
        citationPanel.innerHTML =
          '<div class="flex items-center gap-2 flex-wrap">' + verdictBadge(hasSuspect ? 'WARN' : 'PASS') +
          '<span class="text-xs" style="color:var(--text-tertiary)">' + escapeHtml(out.summary || '') + '</span></div>' +
          renderIssues(out.suspectCitations);
      } catch {
        citationPanel.innerHTML = '<p class="text-xs" style="color:var(--error-700)">Could not contact AI service.</p>';
      }
    });

    // ── Advanced Writing Tools ────────────────────────────────────────────────
    const writingScorePanel   = $('writingScorePanel');
    const tonePanel           = $('tonePanel');
    const sectionFeedbackPanel = $('sectionFeedbackPanel');

    $('writingScoreBtn').addEventListener('click', async () => {
      const text = $('abstract').value.trim();
      if (!text) {
        writingScorePanel.classList.remove('hidden');
        writingScorePanel.innerHTML = '<p class="text-xs" style="color:var(--warning-700)">Write an abstract first.</p>';
        return;
      }
      writingScorePanel.classList.remove('hidden');
      writingScorePanel.innerHTML = '<p class="text-xs" style="color:var(--text-tertiary)">Scoring…</p>';
      try {
        const out = await callAI('/api/ai/writing-score', { text });
        const score = out.overallScore != null ? out.overallScore : '—';
        const dims  = out.dimensions || {};
        const dimHtml = Object.entries(dims).map(([k, v]) =>
          '<div class="flex justify-between text-xs"><span style="color:var(--text-secondary)">' + escapeHtml(k) + '</span><span class="font-semibold">' + v + '/10</span></div>'
        ).join('');
        const improvementsHtml = (out.improvements || []).length
          ? '<div class="text-xs font-semibold mt-2" style="color:var(--text-tertiary)">Improvements</div><ul class="text-xs space-y-1 mt-1">' +
            out.improvements.map(i => '<li style="color:var(--text-secondary)">• ' + escapeHtml(i) + '</li>').join('') + '</ul>'
          : '';
        writingScorePanel.innerHTML =
          '<div class="flex items-center gap-3 mb-2"><span class="text-2xl font-bold" style="color:var(--brand-600)">' + score +
          '<span class="text-sm font-normal">/10</span></span><span class="text-xs" style="color:var(--text-secondary)">' + escapeHtml(out.summary || '') + '</span></div>' +
          dimHtml + improvementsHtml;
      } catch {
        writingScorePanel.innerHTML = '<p class="text-xs" style="color:var(--error-700)">Could not contact AI service.</p>';
      }
    });

    $('toneImproveBtn').addEventListener('click', () => {
      const text = $('abstract').value.trim();
      if (!text) {
        tonePanel.classList.remove('hidden');
        tonePanel.innerHTML = '<p class="text-xs" style="color:var(--warning-700)">Write an abstract first.</p>';
        return;
      }
      tonePanel.classList.remove('hidden');
      tonePanel.innerHTML = '';
      const out = document.createElement('div');
      out.style.cssText = 'font-size:0.75rem;line-height:1.6;color:var(--text-secondary);white-space:pre-wrap;min-height:2rem;';
      out.textContent = 'Improving tone…';
      tonePanel.appendChild(out);
      let improved = '';
      const url = '/api/ai/stream/tone-improve?text=' + encodeURIComponent(text.slice(0, 2000));
      const es = new EventSource(url);
      es.onmessage = (e) => {
        try {
          const d = JSON.parse(e.data);
          if (d.text) { improved += d.text; out.textContent = improved; }
          if (d.done) {
            es.close();
            if (improved) {
              const apply = document.createElement('button');
              apply.type = 'button';
              apply.className = 'btn btn-sm mt-2';
              apply.style.cssText = 'font-size:0.7rem;display:block;';
              apply.textContent = 'Apply to abstract';
              apply.onclick = () => { $('abstract').value = improved; tonePanel.classList.add('hidden'); };
              tonePanel.appendChild(apply);
            }
          }
          if (d.error) { out.textContent = 'AI service error: ' + d.error; es.close(); }
        } catch { /* ignore parse errors in partial chunks */ }
      };
      es.onerror = () => { if (improved) { es.close(); } else { out.textContent = 'Connection lost.'; es.close(); } };
    });

    $('sectionFeedbackBtn').addEventListener('click', async () => {
      const text        = $('sectionText').value.trim();
      const sectionType = $('sectionType').value;
      if (!text) {
        sectionFeedbackPanel.classList.remove('hidden');
        sectionFeedbackPanel.innerHTML = '<p class="text-xs" style="color:var(--warning-700)">Paste a section first.</p>';
        return;
      }
      sectionFeedbackPanel.classList.remove('hidden');
      sectionFeedbackPanel.innerHTML = '<p class="text-xs" style="color:var(--text-tertiary)">Analysing ' + escapeHtml(sectionType) + ' section…</p>';
      try {
        const out = await callAI('/api/ai/section-feedback', { text, sectionType });
        const strengths  = (out.strengths  || []).map(s => '<li class="text-xs" style="color:var(--success-700)">✓ ' + escapeHtml(s) + '</li>').join('');
        const weaknesses = (out.weaknesses || []).map(s => '<li class="text-xs" style="color:var(--warning-700)">⚠ ' + escapeHtml(s) + '</li>').join('');
        const suggestions = (out.suggestions || []).map(s => '<li class="text-xs" style="color:var(--text-secondary)">✦ ' + escapeHtml(s) + '</li>').join('');
        sectionFeedbackPanel.innerHTML =
          '<div class="text-xs font-semibold mb-1" style="color:var(--text-tertiary)">' + escapeHtml(sectionType) + ' section</div>' +
          (strengths  ? '<ul class="space-y-1 mb-1.5">' + strengths  + '</ul>' : '') +
          (weaknesses ? '<ul class="space-y-1 mb-1.5">' + weaknesses + '</ul>' : '') +
          (suggestions ? '<div class="text-xs font-semibold mb-1" style="color:var(--brand-600)">Suggestions</div><ul class="space-y-1">' + suggestions + '</ul>' : '');
      } catch {
        sectionFeedbackPanel.innerHTML = '<p class="text-xs" style="color:var(--error-700)">Could not contact AI service.</p>';
      }
    });

    // ── AI Insights (v3): plain summary · key contributions · title↔abstract · limitations ──
    const plainSummaryPanel = $('plainSummaryPanel');
    const contribPanel      = $('contribPanel');
    const titleCheckPanel   = $('titleCheckPanel');
    const limitationsPanel  = $('limitationsPanel');

    const ulList = (items, color) => (items && items.length)
      ? '<ul class="text-xs space-y-1 mt-1 pl-1">' + items.map(i =>
          '<li style="color:' + (color || 'var(--text-secondary)') + '">• ' +
          escapeHtml(typeof i === 'string' ? i : (i.message || i.text || JSON.stringify(i))) + '</li>').join('') + '</ul>'
      : '';
    const providerFoot = (out) => {
      const bits = [];
      if (out.provider) bits.push('Provider: ' + escapeHtml(out.provider));
      if (out.confidence != null && out.confidence !== 0) bits.push(out.confidence + '% confidence');
      return bits.length
        ? '<div class="text-xs mt-2 pt-2 border-t" style="color:var(--text-tertiary);border-color:var(--border-default)">' + bits.join(' · ') + '</div>'
        : '';
    };
    const requireAbstract = (p) => {
      const title = $('title').value.trim(), abstract = $('abstract').value.trim();
      if (!abstract) { p.classList.remove('hidden'); p.innerHTML = '<p class="text-xs" style="color:var(--warning-700)">Write an abstract first.</p>'; return null; }
      return { title, abstract };
    };

    $('plainSummaryBtn').addEventListener('click', async () => {
      const v = requireAbstract(plainSummaryPanel); if (!v) return;
      plainSummaryPanel.classList.remove('hidden');
      plainSummaryPanel.innerHTML = '<p class="text-xs" style="color:var(--text-tertiary)">Writing a plain-language summary…</p>';
      try {
        const out = await callAI('/api/ai/plain-summary', v);
        if (!out.plain_summary) {
          plainSummaryPanel.innerHTML = '<p class="text-xs" style="color:var(--text-tertiary)">' + escapeHtml(out.summary || 'No summary available.') + '</p>' + providerFoot(out);
          return;
        }
        const terms = (out.key_terms_explained || []).map(t =>
          '<li style="color:var(--text-secondary)"><span class="font-semibold">' + escapeHtml(t.term || '') + '</span> — ' + escapeHtml(t.explanation || '') + '</li>').join('');
        plainSummaryPanel.innerHTML =
          '<div class="rounded-md p-3" style="background:var(--surface-0);border:1px solid var(--border-default);color:var(--text-primary)">' + escapeHtml(out.plain_summary) + '</div>' +
          (out.why_it_matters ? '<div class="text-xs mt-1"><span class="font-semibold" style="color:var(--brand-600)">Why it matters:</span> <span style="color:var(--text-secondary)">' + escapeHtml(out.why_it_matters) + '</span></div>' : '') +
          (terms ? '<div class="text-xs font-semibold mt-2" style="color:var(--text-tertiary)">Key terms</div><ul class="text-xs space-y-1 mt-1">' + terms + '</ul>' : '') +
          (out.target_reading_level ? '<div class="text-xs mt-1" style="color:var(--text-tertiary)">Reading level: ' + escapeHtml(out.target_reading_level) + '</div>' : '') +
          providerFoot(out);
      } catch { plainSummaryPanel.innerHTML = '<p class="text-xs" style="color:var(--error-700)">Could not contact AI service.</p>'; }
    });

    $('contribBtn').addEventListener('click', async () => {
      const v = requireAbstract(contribPanel); if (!v) return;
      contribPanel.classList.remove('hidden');
      contribPanel.innerHTML = '<p class="text-xs" style="color:var(--text-tertiary)">Extracting key contributions…</p>';
      try {
        const out = await callAI('/api/ai/key-contributions', v);
        const items = out.contributions || [];
        if (!items.length) {
          contribPanel.innerHTML = '<p class="text-xs" style="color:var(--text-tertiary)">' + escapeHtml(out.summary || 'No contributions extracted.') + '</p>' + providerFoot(out);
          return;
        }
        const li = items.map(c => {
          const text = typeof c === 'string' ? c : (c.contribution || '');
          const type = (c && typeof c === 'object' && c.type)
            ? ' <span style="font-size:0.65rem;background:var(--brand-50);color:var(--brand-700);padding:1px 6px;border-radius:9999px;margin-left:4px">' + escapeHtml(c.type) + '</span>' : '';
          const ungrounded = (c && typeof c === 'object' && c.grounded_in_text === false)
            ? ' <span style="font-size:0.65rem;color:var(--warning-700)">⚠ not grounded</span>' : '';
          return '<li style="color:var(--text-secondary)">• ' + escapeHtml(text) + type + ungrounded + '</li>';
        }).join('');
        contribPanel.innerHTML =
          '<ul class="text-xs space-y-1.5">' + li + '</ul>' +
          (out.novelty_assessment ? '<div class="text-xs mt-2"><span class="font-semibold" style="color:var(--brand-600)">Novelty:</span> <span style="color:var(--text-secondary)">' + escapeHtml(out.novelty_assessment) + '</span>' + (out.novelty_score != null ? ' <span class="font-semibold">(' + out.novelty_score + '/100)</span>' : '') + '</div>' : '') +
          providerFoot(out);
      } catch { contribPanel.innerHTML = '<p class="text-xs" style="color:var(--error-700)">Could not contact AI service.</p>'; }
    });

    $('titleCheckBtn').addEventListener('click', async () => {
      const title = $('title').value.trim(), abstract = $('abstract').value.trim();
      if (!title || !abstract) {
        titleCheckPanel.classList.remove('hidden');
        titleCheckPanel.innerHTML = '<p class="text-xs" style="color:var(--warning-700)">Fill in title and abstract first.</p>';
        return;
      }
      titleCheckPanel.classList.remove('hidden');
      titleCheckPanel.innerHTML = '<p class="text-xs" style="color:var(--text-tertiary)">Checking title vs. abstract…</p>';
      try {
        const out = await callAI('/api/ai/title-check', { title, abstract });
        const aligned = out.aligned;
        const badge = aligned === true ? verdictBadge('PASS')
          : aligned === false ? verdictBadge('WARN')
          : '<span class="text-xs font-bold px-2 py-0.5 rounded-full" style="background:#64748b;color:white">N/A</span>';
        const score = out.consistency_score != null ? out.consistency_score + '/100' : '';
        let html = '<div class="flex items-center gap-2 flex-wrap">' + badge +
          '<span class="text-xs" style="color:var(--text-tertiary)">' + (score ? 'Consistency ' + escapeHtml(score) : escapeHtml(out.summary || '')) + '</span></div>';
        if ((out.mismatches || []).length) html += '<div class="text-xs font-semibold mt-2" style="color:var(--warning-700)">Mismatches</div>' + ulList(out.mismatches, 'var(--warning-700)');
        if ((out.overclaims || []).length) html += '<div class="text-xs font-semibold mt-2" style="color:var(--warning-700)">Over-claims</div>' + ulList(out.overclaims, 'var(--warning-700)');
        if ((out.missing_from_title || []).length) html += '<div class="text-xs font-semibold mt-2" style="color:var(--text-tertiary)">Missing from title</div>' + ulList(out.missing_from_title);
        if ((out.suggested_titles || []).length) {
          html += '<div class="text-xs font-semibold mt-2" style="color:var(--brand-600)">Suggested titles</div><ul class="text-xs space-y-1 mt-1">' +
            out.suggested_titles.map(t => '<li>• <button type="button" class="text-left hover:underline" data-sugtitle="' + escapeHtml(t) + '" style="color:var(--text-secondary)">' + escapeHtml(t) + '</button></li>').join('') + '</ul>';
        }
        html += providerFoot(out);
        titleCheckPanel.innerHTML = html;
        titleCheckPanel.querySelectorAll('button[data-sugtitle]').forEach(b => { b.onclick = () => { $('title').value = b.dataset.sugtitle; }; });
      } catch { titleCheckPanel.innerHTML = '<p class="text-xs" style="color:var(--error-700)">Could not contact AI service.</p>'; }
    });

    $('limitationsBtn').addEventListener('click', async () => {
      const v = requireAbstract(limitationsPanel); if (!v) return;
      limitationsPanel.classList.remove('hidden');
      limitationsPanel.innerHTML = '<p class="text-xs" style="color:var(--text-tertiary)">Finding limitations…</p>';
      try {
        const out = await callAI('/api/ai/limitations', { title: v.title, abstract: v.abstract });
        const sevColors = { LOW: '#16a34a', MEDIUM: '#d97706', HIGH: '#dc2626' };
        const sev = (out.severity || 'UNKNOWN').toUpperCase();
        const sevBadge = '<span class="text-xs font-bold px-2 py-0.5 rounded-full" style="background:' + (sevColors[sev] || '#64748b') + ';color:white">' + escapeHtml(sev) + '</span>';
        const hasAny = (out.stated_limitations || []).length || (out.potential_unstated_limitations || []).length;
        if (!hasAny && out.summary) {
          limitationsPanel.innerHTML = '<p class="text-xs" style="color:var(--text-tertiary)">' + escapeHtml(out.summary) + '</p>' + providerFoot(out);
          return;
        }
        let html = '<div class="flex items-center gap-2 flex-wrap">' + sevBadge + '<span class="text-xs" style="color:var(--text-tertiary)">severity</span></div>';
        if ((out.stated_limitations || []).length) html += '<div class="text-xs font-semibold mt-2" style="color:var(--text-tertiary)">Stated by authors</div>' + ulList(out.stated_limitations);
        if ((out.potential_unstated_limitations || []).length) html += '<div class="text-xs font-semibold mt-2" style="color:var(--warning-700)">Likely unstated</div>' + ulList(out.potential_unstated_limitations, 'var(--warning-700)');
        if ((out.reviewer_questions || []).length) html += '<div class="text-xs font-semibold mt-2" style="color:var(--brand-600)">Reviewer questions</div>' + ulList(out.reviewer_questions);
        if ((out.suggestions || []).length) html += '<div class="text-xs font-semibold mt-2" style="color:var(--text-tertiary)">Suggestions</div>' + ulList(out.suggestions);
        html += providerFoot(out);
        limitationsPanel.innerHTML = html;
      } catch { limitationsPanel.innerHTML = '<p class="text-xs" style="color:var(--error-700)">Could not contact AI service.</p>'; }
    });
  </script>
</body>
</html>
