<!DOCTYPE html>
<html lang="en">
<head><%- include('../partials/head') %></head>
<body class="min-h-screen bg-slate-50 text-slate-900 flex flex-col">
  <%- include('../partials/nav') %>
  <main class="flex-1 flex items-center justify-center px-6">
    <div class="text-center max-w-md">
      <p class="text-8xl font-display font-bold text-amber-200">403</p>
      <h1 class="text-2xl font-bold text-slate-800 mt-4">Access denied</h1>
      <p class="text-slate-500 mt-2"><%= message || "You don't have permission to view this page." %></p>
      <div class="mt-8 flex gap-3 justify-center">
        <a href="/" class="bg-indigo-600 hover:bg-indigo-700 text-white px-5 py-2.5 rounded-md font-medium transition">Go home</a>
        <button onclick="history.back()" class="px-5 py-2.5 border border-slate-300 rounded-md text-slate-700 hover:bg-slate-100 font-medium transition">Go back</button>
      </div>
    </div>
  </main>
  <%- include('../partials/footer') %>
</body>
</html>
