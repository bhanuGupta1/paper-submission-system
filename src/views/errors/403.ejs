<!DOCTYPE html>
<html lang="en">
<head><%- include('../partials/head') %></head>
<body class="min-h-screen bg-slate-50 text-slate-900 flex flex-col">
  <%- include('../partials/nav') %>
  <main class="flex-1 flex items-center justify-center px-6">
    <div class="text-center max-w-md">
      <p class="font-display font-extrabold" style="font-size:6rem; line-height:1; color:#fde68a">403</p>
      <h1 class="font-display text-2xl font-bold mt-4">Access denied</h1>
      <p class="mt-2" style="color:var(--text-tertiary)"><%= message || "You don't have permission to view this page." %></p>
      <div class="mt-8 flex gap-3 justify-center">
        <a href="/" class="btn btn-primary">Go home</a>
        <button onclick="history.back()" class="btn btn-secondary">Go back</button>
      </div>
    </div>
  </main>
  <%- include('../partials/footer') %>
</body>
</html>
