<!DOCTYPE html>
<html lang="en">
<head><%- include('../partials/head') %></head>
<body class="min-h-screen bg-slate-50 text-slate-900 flex flex-col">
  <%- include('../partials/nav') %>
  <main class="flex-1 flex items-center justify-center px-6 py-20">
    <div class="text-center max-w-lg">
      <div class="relative inline-block mb-8">
        <div class="font-display font-extrabold select-none" style="font-size:9rem;line-height:1;color:var(--border-default);letter-spacing:-0.04em">403</div>
        <div class="absolute inset-0 flex items-center justify-center">
          <div class="w-20 h-20 rounded-2xl flex items-center justify-center" style="background:linear-gradient(135deg,#dc2626,#f97316);box-shadow:0 16px 40px rgba(220,38,38,0.35)">
            <svg class="w-9 h-9 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
          </div>
        </div>
      </div>

      <h1 class="font-display text-3xl font-bold" style="color:var(--text-primary)">Access denied</h1>
      <p class="mt-3 text-base" style="color:var(--text-secondary)"><%= message || "You don't have permission to view this page." %></p>

      <div class="mt-8 flex flex-wrap gap-3 justify-center">
        <a href="/" class="btn btn-primary btn-lg">Go home</a>
        <button onclick="history.back()" class="btn btn-secondary btn-lg">Go back</button>
        <% if (!currentUser) { %>
          <a href="/login" class="btn btn-secondary btn-lg">Sign in</a>
        <% } %>
      </div>
    </div>
  </main>
  <%- include('../partials/footer') %>
</body>
</html>
