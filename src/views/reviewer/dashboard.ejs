<!DOCTYPE html>
<html lang="en">
<head><%- include('../partials/head') %></head>
<body class="min-h-screen flex flex-col" style="background:var(--surface-0);color:var(--text-primary)">
  <%- include('../partials/nav') %>
  <main class="flex-1 relative overflow-hidden">
    <div class="page-photo-bg" style="background-image:url('https://images.unsplash.com/photo-1450101499163-c8848c66ca85?auto=format&fit=crop&w=1920&q=80')" aria-hidden="true"></div>
    <div class="max-w-7xl mx-auto px-6 py-8 relative z-10">

      <div class="dashboard-hero mb-6">
        <div>
          <p class="eyebrow text-indigo-200">Reviewer cockpit</p>
          <h1 class="font-display text-4xl sm:text-5xl font-extrabold text-white mt-2">Review assignments</h1>
          <p class="text-sm text-slate-300 mt-2 max-w-2xl">Prioritize assigned manuscripts, draft structured reviews, and keep your completion record visible.</p>
        </div>
        <div class="shrink-0">
          <a href="/reviewer/calendar.ics" class="btn btn-sm" style="background:rgba(255,255,255,0.12);border-color:rgba(255,255,255,0.2);color:white" title="Download review deadlines as a calendar file">
            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
            Export deadlines (.ics)
          </a>
        </div>
      </div>

      <div class="grid grid-cols-2 lg:grid-cols-5 gap-4 mb-8">
        <article class="stat-glass-card glass-card p-5 col-span-1">
          <div class="stat-num text-3xl gradient-text"><%= stats.total %></div>
          <div class="metric-label">Assigned</div>
          <div class="sparkline mt-3" aria-hidden="true"><span style="height:40%"></span><span style="height:60%"></span><span style="height:50%"></span><span style="height:80%"></span><span style="height:65%"></span><span style="height:90%"></span></div>
        </article>
        <article class="stat-glass-card glass-card p-5 col-span-1">
          <div class="stat-num text-3xl gradient-text"><%= stats.pending %></div>
          <div class="metric-label">Pending</div>
          <div class="sparkline amber mt-3" aria-hidden="true"><span style="height:55%"></span><span style="height:75%"></span><span style="height:60%"></span><span style="height:85%"></span><span style="height:70%"></span><span style="height:50%"></span></div>
        </article>
        <article class="stat-glass-card glass-card p-5 col-span-1">
          <div class="stat-num text-3xl gradient-text"><%= stats.completed %></div>
          <div class="metric-label">Completed</div>
          <div class="sparkline green mt-3" aria-hidden="true"><span style="height:25%"></span><span style="height:40%"></span><span style="height:55%"></span><span style="height:68%"></span><span style="height:82%"></span><span style="height:95%"></span></div>
        </article>
        <article class="stat-glass-card glass-card p-5 col-span-1">
          <div class="stat-num text-3xl <%= stats.overdue > 0 ? 'text-rose-500' : '' %> <%= stats.overdue === 0 ? 'gradient-text' : '' %>"><%= stats.overdue %></div>
          <div class="metric-label">Overdue</div>
          <div class="sparkline violet mt-3" aria-hidden="true"><span style="height:30%"></span><span style="height:45%"></span><span style="height:35%"></span><span style="height:50%"></span><span style="height:40%"></span><span style="height:30%"></span></div>
        </article>
        <article class="stat-glass-card glass-card p-5 col-span-1">
          <div class="stat-num text-3xl gradient-text"><%= stats.completionRate %>%</div>
          <div class="metric-label">Completion</div>
          <div class="sparkline mt-3" aria-hidden="true"><span style="height:50%"></span><span style="height:60%"></span><span style="height:70%"></span><span style="height:75%"></span><span style="height:80%"></span><span style="height:<%= stats.completionRate %>%"></span></div>
        </article>
      </div>

      <% if (assignments.length === 0) { %>
        <div class="glass-card p-12 text-center">
          <div class="inline-flex h-16 w-16 items-center justify-center rounded-2xl mb-5" style="background:linear-gradient(135deg,rgba(99,102,241,0.15),rgba(6,182,212,0.10));border:1px solid rgba(99,102,241,0.2)">
            <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="color:var(--brand-500)"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          </div>
          <p class="eyebrow" style="color:var(--brand-500)">Clear desk</p>
          <h2 class="font-display text-3xl font-extrabold mt-2" style="color:var(--text-primary)">No active assignments.</h2>
          <p class="mt-3 max-w-md mx-auto" style="color:var(--text-secondary)">New assignments will appear here with paper context and review actions.</p>
        </div>
      <% } else { %>
        <div class="review-grid">
          <% assignments.filter(a => !a.declined_at).forEach(p => { %>
            <article class="glass-card gradient-border-card p-5 flex flex-col gap-4">
              <div class="flex items-start justify-between gap-3">
                <div class="flex-1 min-w-0">
                  <p class="text-xs uppercase tracking-wider font-bold" style="color:var(--text-tertiary)">Assigned <%= new Date(p.assigned_at).toLocaleDateString() %></p>
                  <h2 class="font-display text-xl font-extrabold mt-2 leading-snug" style="color:var(--text-primary)"><%= p.paper_title || p.title %></h2>
                </div>
                <% if (p.recommendation) { %>
                  <span class="shrink-0 status-pill" style="background:rgba(5,150,105,0.12);color:#059669;border:1px solid rgba(5,150,105,0.25)">Done</span>
                <% } else if (p.deadline && new Date(p.deadline) < new Date()) { %>
                  <span class="shrink-0 status-pill" style="background:rgba(220,38,38,0.10);color:#dc2626;border:1px solid rgba(220,38,38,0.25)">Overdue</span>
                <% } else { %>
                  <span class="shrink-0 status-pill" style="background:rgba(217,119,6,0.10);color:#d97706;border:1px solid rgba(217,119,6,0.25)">Pending</span>
                <% } %>
              </div>

              <% if (p.abstract) { %>
                <p class="text-sm line-clamp-3 leading-relaxed" style="color:var(--text-secondary)"><%= p.abstract %></p>
              <% } %>

              <div class="flex flex-wrap gap-2 text-xs">
                <% if (p.recommendation) { %>
                  <span class="score-chip">Rec: <strong><%= p.recommendation.replace('_', ' ') %></strong></span>
                <% } else { %>
                  <span class="score-chip">Rec: <strong>pending</strong></span>
                <% } %>
                <% if (p.deadline) { %>
                  <span class="score-chip">Due: <strong><%= new Date(p.deadline).toLocaleDateString() %></strong></span>
                <% } %>
                <% if (p.ai_assisted) { %>
                  <span class="score-chip">AI draft used</span>
                <% } %>
              </div>

              <div class="flex justify-between items-center gap-2 mt-auto pt-3" style="border-top:1px solid var(--border-default)">
                <a class="btn-gradient shimmer-btn text-sm" href="/reviewer/papers/<%= p.paper_id %>">
                  <%= p.recommendation ? 'View review' : 'Start review' %>
                </a>
                <% if (!p.recommendation) { %>
                  <button
                    data-paper-id="<%= p.paper_id %>"
                    data-title="<%= p.paper_title || '' %>"
                    class="coi-btn text-xs font-semibold px-3 py-1.5 rounded-lg transition"
                    style="color:var(--warning-700);background:rgba(217,119,6,0.08);border:1px solid rgba(217,119,6,0.2)">
                    Declare COI
                  </button>
                <% } %>
              </div>
            </article>
          <% }) %>
        </div>
      <% } %>
    </div>
  </main>
  <%- include('../partials/footer') %>

  <!-- COI Declaration Modal -->
  <div id="coiModal" class="hidden confirm-overlay">
    <div class="confirm-box">
      <h2 class="font-display font-bold text-lg mb-1">Declare Conflict of Interest</h2>
      <p id="coiPaperTitle" class="text-sm mb-4" style="color:var(--text-secondary)"></p>
      <textarea id="coiReason" rows="3" placeholder="Describe the nature of the conflict (e.g. co-author, shared institution, personal relationship)..."
        class="w-full rounded-md px-3 py-2 text-sm mb-4"
        style="background:var(--surface-1);border:1px solid var(--border-default);color:var(--text-primary)"></textarea>
      <div class="flex gap-3">
        <button onclick="submitCoi()" class="btn-gradient shimmer-btn text-sm">Declare &amp; Decline</button>
        <button onclick="document.getElementById('coiModal').classList.add('hidden')" class="btn btn-secondary text-sm">Cancel</button>
      </div>
    </div>
  </div>

  <script>
    let _coiPaperId = null;
    function declareCoi(paperId, title) {
      _coiPaperId = paperId;
      document.getElementById('coiPaperTitle').textContent = title;
      document.getElementById('coiReason').value = '';
      document.getElementById('coiModal').classList.remove('hidden');
    }

    document.querySelectorAll('.coi-btn').forEach(btn => {
      btn.addEventListener('click', () => declareCoi(btn.dataset.paperId, btn.dataset.title));
    });
    async function submitCoi() {
      const reason = document.getElementById('coiReason').value.trim();
      if (!reason) { showToast('Please describe the conflict', 'warning'); return; }
      try {
        const r = await fetch(`/reviewer/papers/${_coiPaperId}/coi`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ reason }),
        });
        const data = await r.json();
        if (r.ok) { showToast('COI declared and assignment declined', 'success'); document.getElementById('coiModal').classList.add('hidden'); setTimeout(() => location.reload(), 1200); }
        else showToast(data.error || 'Error', 'error');
      } catch { showToast('Network error', 'error'); }
    }
  </script>
</body>
</html>
