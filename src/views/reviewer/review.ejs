<!DOCTYPE html>
<html lang="en">
<head><%- include('../partials/head') %></head>
<body class="min-h-screen flex flex-col" style="background:var(--surface-0);color:var(--text-primary)">
  <%- include('../partials/nav') %>
  <main class="flex-1">
    <div class="max-w-7xl mx-auto px-6 py-8">
      <div class="flex items-center justify-between mb-4">
        <a href="/reviewer" class="text-sm link-line" style="color:var(--brand-600)">← Assignments</a>
        <% if (!review.review_date) { %>
          <button onclick="openDeclineModal()"
            class="text-sm font-medium px-3 py-1.5 border rounded-md transition"
            style="color:var(--error-700);border-color:var(--error-200);background:var(--error-50)">Decline assignment</button>
        <% } %>
      </div>

      <% if (review.deadline) { %>
        <% const isOverdue = new Date(review.deadline) < new Date(); %>
        <div class="mb-4 p-3 rounded-lg border text-sm"
             style="background:<%= isOverdue ? 'var(--error-50)' : 'var(--warning-50)' %>;border-color:<%= isOverdue ? 'var(--error-200)' : 'var(--warning-200)' %>;color:<%= isOverdue ? 'var(--error-700)' : 'var(--warning-700)' %>">
          <%= isOverdue ? '⚠ Review overdue.' : 'Review due:' %> <strong><%= new Date(review.deadline).toLocaleString() %></strong>
        </div>
      <% } %>

      <div class="grid lg:grid-cols-[0.38fr_0.62fr] gap-6">
        <aside class="space-y-4">
          <div class="glass-card p-6">
            <p class="eyebrow mb-2" style="color:var(--brand-600)">Double-blind manuscript</p>
            <h1 class="font-display text-2xl font-bold leading-tight" style="color:var(--text-primary)"><%= paper.title %></h1>
            <p class="text-xs mt-1 italic" style="color:var(--text-tertiary)"><%= paper.authors %></p>
            <div class="mt-3 flex flex-wrap gap-2 text-xs">
              <span class="score-chip">Similarity <strong><%= paper.similarity_score != null ? (paper.similarity_score * 100).toFixed(0) + '%' : '—' %></strong></span>
              <span class="score-chip">AI signal <strong><%= paper.ai_text_likelihood != null ? (paper.ai_text_likelihood * 100).toFixed(0) + '%' : '—' %></strong></span>
            </div>
          </div>

          <div class="glass-card p-6">
            <h2 class="font-semibold text-sm mb-2" style="color:var(--text-primary)">Abstract</h2>
            <p class="text-sm leading-relaxed whitespace-pre-line" style="color:var(--text-secondary)"><%= paper.abstract %></p>
            <% if (paper.file_path && paper.file_path.toLowerCase().endsWith('.pdf')) { %>
              <div class="mt-4 flex gap-2">
                <button onclick="document.getElementById('pdf-pane').classList.toggle('hidden')" class="btn btn-secondary btn-sm text-xs">
                  <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
                  View PDF
                </button>
              </div>
              <div id="pdf-pane" class="hidden mt-3 rounded-xl overflow-hidden border" style="border-color:var(--border-default)">
                <iframe src="/reviewer/papers/<%= paper.id %>/view" class="w-full" style="height:480px;border:none;display:block"></iframe>
              </div>
            <% } %>
          </div>

          <div class="glass-card p-4" style="background:var(--info-50);border-color:var(--info-100)">
            <p class="text-xs font-semibold mb-1.5" style="color:var(--info-700)">Review standards</p>
            <ul class="text-xs space-y-1" style="color:var(--info-700)">
              <li>• Be constructive, specific, and evidence-based</li>
              <li>• Score each dimension independently (1–5)</li>
              <li>• AI drafts are starting points — edit before submitting</li>
              <li>• If you have a conflict, use "Declare COI" on the dashboard</li>
            </ul>
          </div>

          <!-- AI Rubric -->
          <div class="glass-card p-5">
            <div class="flex items-center justify-between mb-2">
              <div>
                <h2 class="font-semibold text-sm" style="color:var(--text-primary)">Review rubric</h2>
                <p class="text-xs mt-0.5" style="color:var(--text-tertiary)">AI-generated criteria for this paper</p>
              </div>
              <button type="button" id="rubricBtn" class="btn btn-sm" style="background:var(--surface-1);color:var(--text-secondary);border-color:var(--border-default)">Generate</button>
            </div>
            <div id="rubricPanel" class="hidden text-xs space-y-2 mt-2"></div>
          </div>

          <!-- Discussion thread -->
          <div class="glass-card p-5">
            <h2 class="font-semibold text-sm mb-3" style="color:var(--text-primary)">Editor discussion</h2>
            <div id="discussionList" class="space-y-2 max-h-64 overflow-y-auto mb-3">
              <% if (!discussion || discussion.length === 0) { %>
                <p class="text-xs italic" style="color:var(--text-tertiary)">No messages yet.</p>
              <% } else { %>
                <% discussion.forEach(msg => { %>
                  <div class="rounded-md p-2.5 text-xs"
                       style="background:var(--surface-1);border:1px solid var(--border-default)">
                    <div class="flex justify-between mb-1" style="color:var(--text-tertiary)">
                      <span class="font-semibold" style="color:var(--text-secondary)"><%= msg.username %></span>
                      <span><%= new Date(msg.created_at).toLocaleDateString() %></span>
                    </div>
                    <p style="color:var(--text-secondary)"><%= msg.message %></p>
                  </div>
                <% }) %>
              <% } %>
            </div>
            <div class="flex gap-2">
              <input type="text" id="discussionInput" placeholder="Message editor…" maxlength="500"
                class="flex-1 text-xs rounded-md border px-2.5 py-1.5"
                style="background:var(--surface-1);border-color:var(--border-default);color:var(--text-primary)">
              <button onclick="postMessage()" class="btn btn-sm btn-primary text-xs">Send</button>
            </div>
          </div>
        </aside>

        <section>
          <div class="flex flex-wrap justify-between items-center gap-3 mb-4">
            <div>
              <p class="eyebrow" style="color:var(--brand-600)">Structured review</p>
              <h2 class="font-display text-3xl font-bold mt-1" style="color:var(--text-primary)">Your assessment</h2>
            </div>
            <div class="flex gap-2 flex-wrap">
              <button id="reviewAssistToggle" class="btn btn-secondary text-sm">Review assist</button>
              <button id="aiDraftBtn" class="btn btn-secondary text-sm" aria-label="Generate AI draft review">Generate AI draft</button>
            </div>
          </div>

          <!-- Review Assist Panel -->
          <div id="reviewAssistCard" class="hidden glass-card p-5 mb-4 space-y-3">
            <div>
              <p class="text-sm font-semibold" style="color:var(--text-primary)">AI Review Assistant</p>
              <p class="text-xs mt-0.5" style="color:var(--text-tertiary)">Turn rough notes or observations into structured feedback</p>
            </div>
            <textarea id="roughNotes" rows="4" placeholder="Paste bullet points, rough observations, or initial thoughts about the paper…"
              class="block w-full rounded-lg border px-3 py-2 text-sm"
              style="background:var(--surface-1);border-color:var(--border-default);color:var(--text-primary)"></textarea>
            <div class="flex gap-2">
              <button type="button" id="reviewAssistBtn" class="btn btn-sm btn-primary">Generate structured feedback</button>
              <button type="button" id="reviewAssistApplyBtn" class="btn btn-sm hidden" style="background:var(--success-600);color:white;border-color:var(--success-600)">Apply to form</button>
            </div>
            <div id="reviewAssistResult" class="hidden text-xs rounded-lg border p-3 space-y-2"
                 style="background:var(--surface-0);border-color:var(--border-default)"></div>
          </div>

          <form action="/reviewer/reviews/<%= review.id %>" method="post" class="glass-card p-6 space-y-5" id="reviewForm">
            <input type="hidden" name="ai_assisted" id="ai_assisted" value="<%= review.ai_assisted ? '1' : '0' %>">

            <div>
              <label for="summary" class="block text-sm font-semibold mb-1" style="color:var(--text-secondary)">
                Summary <span style="color:var(--error-600)">*</span>
              </label>
              <p class="text-xs mb-1.5" style="color:var(--text-tertiary)">Briefly summarize the paper and your overall assessment</p>
              <textarea name="summary" id="summary" rows="3" required
                class="block w-full rounded-lg border px-3.5 py-2.5 text-sm"
                style="background:var(--surface-1);border-color:var(--border-default);color:var(--text-primary)"><%= review.summary || '' %></textarea>
            </div>

            <div class="grid md:grid-cols-2 gap-4">
              <div>
                <label for="strengths" class="block text-sm font-semibold mb-1" style="color:var(--text-secondary)">
                  Strengths <span style="color:var(--error-600)">*</span>
                </label>
                <textarea name="strengths" id="strengths" rows="4" required
                  class="block w-full rounded-lg border px-3.5 py-2.5 text-sm"
                  style="background:var(--surface-1);border-color:var(--border-default);color:var(--text-primary)"><%= review.strengths || '' %></textarea>
              </div>
              <div>
                <label for="weaknesses" class="block text-sm font-semibold mb-1" style="color:var(--text-secondary)">
                  Weaknesses <span style="color:var(--error-600)">*</span>
                </label>
                <textarea name="weaknesses" id="weaknesses" rows="4" required
                  class="block w-full rounded-lg border px-3.5 py-2.5 text-sm"
                  style="background:var(--surface-1);border-color:var(--border-default);color:var(--text-primary)"><%= review.weaknesses || '' %></textarea>
              </div>
            </div>

            <!-- Score sliders -->
            <div class="grid grid-cols-3 gap-4">
              <% [['novelty_score','Novelty'],['clarity_score','Clarity'],['significance_score','Significance']].forEach(([name, label]) => { %>
              <div>
                <label class="block text-sm font-semibold mb-1" style="color:var(--text-secondary)">
                  <%= label %> <span id="<%= name %>_display" style="color:var(--brand-600)" class="font-bold"><%= review[name] || 3 %></span>/5
                </label>
                <input type="range" min="1" max="5" step="1" name="<%= name %>" id="<%= name %>"
                  value="<%= review[name] || 3 %>"
                  class="w-full accent-indigo-600"
                  oninput="document.getElementById('<%= name %>_display').textContent = this.value">
                <div class="flex justify-between text-xs mt-0.5" style="color:var(--text-tertiary)"><span>Poor</span><span>Excellent</span></div>
              </div>
              <% }) %>
            </div>

            <div>
              <label for="recommendation" class="block text-sm font-semibold mb-1" style="color:var(--text-secondary)">
                Recommendation <span style="color:var(--error-600)">*</span>
              </label>
              <select name="recommendation" id="recommendation" required
                class="block w-full rounded-lg border px-3.5 py-2.5 text-sm"
                style="background:var(--surface-1);border-color:var(--border-default);color:var(--text-primary)">
                <option value="">— Select —</option>
                <option value="accept" <%= review.recommendation === 'accept' ? 'selected' : '' %>>Accept</option>
                <option value="minor_revisions" <%= review.recommendation === 'minor_revisions' ? 'selected' : '' %>>Minor revisions</option>
                <option value="major_revisions" <%= review.recommendation === 'major_revisions' ? 'selected' : '' %>>Major revisions</option>
                <option value="reject" <%= review.recommendation === 'reject' ? 'selected' : '' %>>Reject</option>
              </select>
            </div>

            <div>
              <label for="review_text" class="block text-sm font-semibold mb-1" style="color:var(--text-secondary)">
                Additional notes <span class="font-normal text-xs" style="color:var(--text-tertiary)">(optional)</span>
              </label>
              <textarea name="review_text" id="review_text" rows="3"
                class="block w-full rounded-lg border px-3.5 py-2.5 text-sm"
                style="background:var(--surface-1);border-color:var(--border-default);color:var(--text-primary)"><%= review.review_text || '' %></textarea>
            </div>

            <% if (review.ai_assisted) { %>
              <div class="flex items-center gap-2 text-xs rounded-md px-3 py-2"
                   style="color:var(--info-700);background:var(--info-50);border:1px solid var(--info-100)">
                <svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                AI draft was used for this review.
              </div>
            <% } %>

            <div class="flex items-center justify-between pt-2 flex-wrap gap-2">
              <div class="flex gap-2">
                <button type="button" id="qualityCheckBtn" class="btn btn-secondary text-sm">Check quality</button>
                <button type="button" id="qualityLlmBtn" class="btn btn-secondary text-sm">AI quality check</button>
              </div>
              <button type="submit" id="submitBtn" class="btn btn-primary px-6" onclick="return confirmSubmit()">
                Submit review
              </button>
            </div>
            <div id="qualityResult" class="hidden p-3 rounded-md border text-xs"></div>
          </form>
        </section>
      </div>
    </div>
  </main>

  <!-- Decline modal -->
  <div id="declineModal" class="hidden confirm-overlay" role="dialog" aria-modal="true" aria-labelledby="declineModalTitle">
    <div class="confirm-box">
      <h2 id="declineModalTitle" class="font-display font-bold text-lg mb-1" style="color:var(--text-primary)">Decline review assignment</h2>
      <p class="text-sm mb-4" style="color:var(--text-secondary)">Please provide a reason. The editor will be notified.</p>
      <label for="declineReason" class="sr-only">Decline reason</label>
      <textarea id="declineReason" rows="3" placeholder="e.g., Outside my area of expertise, workload constraints…"
        class="w-full rounded-md border px-3 py-2 text-sm mb-4"
        style="background:var(--surface-1);border-color:var(--border-default);color:var(--text-primary)"></textarea>
      <div class="flex gap-3">
        <button id="declineSubmitBtn" class="btn btn-sm btn-danger">Decline</button>
        <button id="declineCancelBtn" class="btn btn-sm btn-secondary">Cancel</button>
      </div>
    </div>
  </div>

  <%- include('../partials/footer') %>

  <script>
    document.getElementById('aiDraftBtn').addEventListener('click', async () => {
      const btn = document.getElementById('aiDraftBtn');
      btn.disabled = true; btn.textContent = 'Generating…';
      try {
        const r = await fetch('/reviewer/papers/<%= paper.id %>/ai-draft');
        if (!r.ok) throw new Error(await r.text());
        const d = await r.json();
        if (d.summary) document.getElementById('summary').value = d.summary;
        if (d.strengths) document.getElementById('strengths').value = d.strengths;
        if (d.weaknesses) document.getElementById('weaknesses').value = d.weaknesses;
        if (d.novelty_score) { document.getElementById('novelty_score').value = d.novelty_score; document.getElementById('novelty_score_display').textContent = d.novelty_score; }
        if (d.clarity_score) { document.getElementById('clarity_score').value = d.clarity_score; document.getElementById('clarity_score_display').textContent = d.clarity_score; }
        if (d.significance_score) { document.getElementById('significance_score').value = d.significance_score; document.getElementById('significance_score_display').textContent = d.significance_score; }
        if (d.recommendation) document.getElementById('recommendation').value = d.recommendation;
        document.getElementById('ai_assisted').value = '1';
        showToast('AI draft inserted — please review and edit before submitting', 'info', 6000);
        btn.textContent = '✓ Draft inserted';
      } catch (e) {
        showToast('AI draft failed: ' + (e.message || 'Unknown error'), 'error');
        btn.textContent = 'Try again';
      } finally {
        btn.disabled = false;
      }
    });

    document.getElementById('qualityCheckBtn').addEventListener('click', async () => {
      const btn = document.getElementById('qualityCheckBtn');
      btn.disabled = true; btn.textContent = 'Checking…';
      try {
        const r = await fetch('/api/ai/review/<%= review.id %>/quality');
        const d = await r.json();
        const box = document.getElementById('qualityResult');
        box.classList.remove('hidden');
        const isOk = d.recommendation === 'acceptable';
        const isWarn = d.recommendation === 'needs_improvement';
        box.style.cssText = isOk
          ? 'background:var(--success-50);border-color:var(--success-200);color:var(--success-700)'
          : isWarn
          ? 'background:var(--warning-50);border-color:var(--warning-200);color:var(--warning-700)'
          : 'background:var(--error-50);border-color:var(--error-200);color:var(--error-700)';
        box.innerHTML = `<strong>Quality score: ${d.score}/100 — ${d.recommendation.replace('_', ' ')}</strong><br>${(d.issues || []).map(i => `• ${i}`).join('<br>') || 'No issues found.'}`;
      } catch { showToast('Quality check unavailable', 'warning'); }
      finally { btn.disabled = false; btn.textContent = 'Check quality'; }
    });

    let declineCleanup = null;
    function openDeclineModal() {
      const modal = document.getElementById('declineModal');
      const trigger = document.activeElement;
      modal.classList.remove('hidden');
      declineCleanup = window.trapFocus(modal, trigger);
      modal.addEventListener('keydown', function esc(e) {
        if (e.key === 'Escape') { closeDeclineModal(); modal.removeEventListener('keydown', esc); }
      });
    }
    function closeDeclineModal() {
      document.getElementById('declineModal').classList.add('hidden');
      if (declineCleanup) { declineCleanup(); declineCleanup = null; }
    }
    document.getElementById('declineCancelBtn').addEventListener('click', closeDeclineModal);
    document.getElementById('declineSubmitBtn').addEventListener('click', submitDecline);

    async function submitDecline() {
      const reason = document.getElementById('declineReason').value.trim();
      if (!reason) { showToast('Please provide a reason', 'warning'); return; }
      try {
        const r = await fetch('/reviewer/reviews/<%= review.id %>/decline', {
          method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ reason }),
        });
        const d = await r.json();
        if (r.ok) { showToast('Assignment declined', 'success'); setTimeout(() => location.href = '/reviewer', 1200); }
        else showToast(d.error || 'Error', 'error');
      } catch { showToast('Network error', 'error'); }
    }

    async function postMessage() {
      const input = document.getElementById('discussionInput');
      const msg = input.value.trim();
      if (!msg) return;
      try {
        const r = await fetch('/reviewer/papers/<%= paper.id %>/discussion', {
          method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ message: msg }),
        });
        const d = await r.json();
        if (r.ok) {
          input.value = '';
          const list = document.getElementById('discussionList');
          const el = document.createElement('div');
          el.className = 'rounded-md p-2.5 text-xs';
          el.style.cssText = 'background:var(--surface-1);border:1px solid var(--border-default)';
          el.innerHTML = `<div class="flex justify-between mb-1" style="color:var(--text-tertiary)"><span class="font-semibold" style="color:var(--text-secondary)">You</span><span>now</span></div><p style="color:var(--text-secondary)">${msg}</p>`;
          list.appendChild(el);
          list.scrollTop = list.scrollHeight;
          showToast('Message sent', 'success');
        } else showToast(d.error || 'Error', 'error');
      } catch { showToast('Network error', 'error'); }
    }
    document.getElementById('discussionInput').addEventListener('keypress', (e) => { if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); postMessage(); } });

    function confirmSubmit() {
      const rec = document.getElementById('recommendation').value;
      if (!rec) { showToast('Please select a recommendation', 'warning'); return false; }
      return true;
    }

    const escHtml = (v) => String(v || '').replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));

    // ── Review Assist ─────────────────────────────────────────────────────────
    let assistDraft = null;
    document.getElementById('reviewAssistToggle').addEventListener('click', () => {
      const card = document.getElementById('reviewAssistCard');
      card.classList.toggle('hidden');
    });

    document.getElementById('reviewAssistBtn').addEventListener('click', async () => {
      const notes = document.getElementById('roughNotes').value.trim();
      if (!notes) { showToast('Enter some rough notes first', 'warning'); return; }
      const btn = document.getElementById('reviewAssistBtn');
      btn.disabled = true; btn.textContent = 'Generating…';
      const resultBox = document.getElementById('reviewAssistResult');
      resultBox.classList.remove('hidden');
      resultBox.innerHTML = '<p style="color:var(--text-tertiary)">Structuring feedback…</p>';
      try {
        const r = await fetch('/api/ai/review-assist', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ roughNotes: notes, paperId: <%= paper.id %> }),
        });
        if (!r.ok) throw new Error(await r.text());
        assistDraft = await r.json();
        const confidence = assistDraft.confidence != null ? ' · ' + assistDraft.confidence + '% confidence' : '';
        resultBox.innerHTML =
          '<div class="font-semibold mb-1" style="color:var(--text-primary)">Summary</div>' +
          '<p style="color:var(--text-secondary)">' + escHtml(assistDraft.summary || '') + '</p>' +
          (assistDraft.strengths ? '<div class="font-semibold mt-2 mb-1" style="color:var(--success-700)">Strengths</div><p style="color:var(--text-secondary)">' + escHtml(assistDraft.strengths) + '</p>' : '') +
          (assistDraft.weaknesses ? '<div class="font-semibold mt-2 mb-1" style="color:var(--warning-700)">Weaknesses</div><p style="color:var(--text-secondary)">' + escHtml(assistDraft.weaknesses) + '</p>' : '') +
          '<p class="mt-2" style="color:var(--text-tertiary)">' + escHtml(confidence) + '</p>';
        document.getElementById('reviewAssistApplyBtn').classList.remove('hidden');
      } catch (e) {
        resultBox.innerHTML = '<p style="color:var(--error-700)">Could not generate feedback: ' + escHtml(e.message) + '</p>';
      } finally {
        btn.disabled = false; btn.textContent = 'Generate structured feedback';
      }
    });

    document.getElementById('reviewAssistApplyBtn').addEventListener('click', () => {
      if (!assistDraft) return;
      if (assistDraft.summary)   document.getElementById('summary').value   = assistDraft.summary;
      if (assistDraft.strengths) document.getElementById('strengths').value = assistDraft.strengths;
      if (assistDraft.weaknesses) document.getElementById('weaknesses').value = assistDraft.weaknesses;
      if (assistDraft.recommendation) document.getElementById('recommendation').value = assistDraft.recommendation;
      document.getElementById('ai_assisted').value = '1';
      showToast('Draft applied — review and edit before submitting', 'info', 5000);
      document.getElementById('reviewAssistCard').classList.add('hidden');
    });

    // ── Rubric Generator ──────────────────────────────────────────────────────
    document.getElementById('rubricBtn').addEventListener('click', async () => {
      const btn = document.getElementById('rubricBtn');
      const panel = document.getElementById('rubricPanel');
      btn.disabled = true; btn.textContent = 'Generating…';
      panel.classList.remove('hidden');
      panel.innerHTML = '<p style="color:var(--text-tertiary)">Generating rubric…</p>';
      try {
        const r = await fetch('/api/ai/paper/<%= paper.id %>/rubric');
        if (!r.ok) throw new Error(await r.text());
        const d = await r.json();
        const criteria = d.criteria || d.rubric || [];
        if (criteria.length) {
          panel.innerHTML = criteria.map(c =>
            '<div class="rounded-md p-2" style="background:var(--surface-0);border:1px solid var(--border-default)">' +
            '<div class="font-semibold mb-0.5" style="color:var(--text-primary)">' + escHtml(c.criterion || c.name || '') + '</div>' +
            '<div style="color:var(--text-secondary)">' + escHtml(c.description || c.guidance || '') + '</div>' +
            (c.weight ? '<div class="mt-0.5" style="color:var(--text-tertiary)">Weight: ' + escHtml(String(c.weight)) + '</div>' : '') +
            '</div>'
          ).join('');
        } else if (d.rubric && typeof d.rubric === 'string') {
          panel.innerHTML = '<p style="color:var(--text-secondary);white-space:pre-wrap">' + escHtml(d.rubric) + '</p>';
        } else {
          panel.innerHTML = '<p style="color:var(--text-tertiary)">No rubric generated.</p>';
        }
        btn.textContent = 'Regenerate';
      } catch (e) {
        panel.innerHTML = '<p style="color:var(--error-700)">Could not generate rubric.</p>';
        btn.textContent = 'Retry';
      } finally {
        btn.disabled = false;
      }
    });

    // ── LLM Quality Check ─────────────────────────────────────────────────────
    document.getElementById('qualityLlmBtn').addEventListener('click', async () => {
      const btn = document.getElementById('qualityLlmBtn');
      btn.disabled = true; btn.textContent = 'Checking…';
      const box = document.getElementById('qualityResult');
      box.classList.remove('hidden');
      box.style.cssText = 'background:var(--surface-1);border-color:var(--border-default);color:var(--text-secondary)';
      box.textContent = 'Running AI quality analysis…';
      try {
        const r = await fetch('/api/ai/review/<%= review.id %>/quality-llm');
        if (!r.ok) throw new Error(await r.text());
        const d = await r.json();
        const score = d.score != null ? d.score : '—';
        const verdict = (d.verdict || d.recommendation || '').replace(/_/g, ' ');
        const isGood = score >= 70 || verdict.includes('accept') || verdict.includes('good');
        const isWarn = !isGood && score >= 50;
        box.style.cssText = isGood
          ? 'background:var(--success-50);border-color:var(--success-200);color:var(--success-700)'
          : isWarn
          ? 'background:var(--warning-50);border-color:var(--warning-200);color:var(--warning-700)'
          : 'background:var(--error-50);border-color:var(--error-200);color:var(--error-700)';
        const issues = (d.issues || d.concerns || []).map(i => '• ' + escHtml(typeof i === 'string' ? i : i.message || String(i))).join('<br>');
        box.innerHTML = '<strong>AI quality — score: ' + score + '/100' + (verdict ? ' — ' + escHtml(verdict) : '') + '</strong>' +
          (d.summary ? '<br>' + escHtml(d.summary) : '') +
          (issues ? '<br>' + issues : '<br>No specific concerns raised.');
      } catch (e) {
        box.style.cssText = 'background:var(--error-50);border-color:var(--error-200);color:var(--error-700)';
        box.textContent = 'AI quality check unavailable.';
      } finally {
        btn.disabled = false; btn.textContent = 'AI quality check';
      }
    });
  </script>
</body>
</html>
