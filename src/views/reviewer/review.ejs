<!DOCTYPE html>
<html lang="en">
<head><%- include('../partials/head') %></head>
<body class="min-h-screen bg-slate-50 text-slate-900 flex flex-col">
  <%- include('../partials/nav') %>
  <main class="flex-1">
    <div class="max-w-7xl mx-auto px-6 py-8">
      <div class="flex items-center justify-between mb-4">
        <a href="/reviewer" class="text-sm text-indigo-600 hover:text-indigo-500 link-line">← Assignments</a>
        <% if (!review.review_date) { %>
          <button onclick="openDeclineModal()" class="text-sm text-red-600 hover:text-red-700 font-medium px-3 py-1.5 border border-red-200 rounded-md">Decline assignment</button>
        <% } %>
      </div>

      <% if (review.deadline) { %>
        <% const isOverdue = new Date(review.deadline) < new Date(); %>
        <div class="mb-4 p-3 rounded-lg border <%= isOverdue ? 'bg-red-50 border-red-200 text-red-700' : 'bg-amber-50 border-amber-200 text-amber-700' %> text-sm">
          <%= isOverdue ? '⚠ Review overdue.' : 'Review due:' %> <strong><%= new Date(review.deadline).toLocaleString() %></strong>
        </div>
      <% } %>

      <div class="grid lg:grid-cols-[0.38fr_0.62fr] gap-6">
        <aside class="space-y-4">
          <div class="card p-6">
            <p class="eyebrow text-indigo-700 mb-2">Double-blind manuscript</p>
            <h1 class="font-display text-2xl font-bold leading-tight"><%= paper.title %></h1>
            <p class="text-xs text-slate-400 mt-1 italic"><%= paper.authors %></p>
            <div class="mt-3 flex flex-wrap gap-2 text-xs text-slate-600">
              <span class="score-chip">Similarity <strong><%= (paper.similarity_score * 100).toFixed(0) %>%</strong></span>
              <span class="score-chip">AI signal <strong><%= (paper.ai_text_likelihood * 100).toFixed(0) %>%</strong></span>
            </div>
          </div>
          <div class="card p-6">
            <h2 class="font-semibold text-slate-800 mb-2">Abstract</h2>
            <p class="text-slate-700 text-sm leading-relaxed whitespace-pre-line"><%= paper.abstract %></p>
          </div>
          <div class="card p-4 bg-indigo-50 border-indigo-100">
            <p class="text-xs font-semibold text-indigo-700 mb-1">Review standards</p>
            <ul class="text-xs text-indigo-600 space-y-1">
              <li>• Be constructive, specific, and evidence-based</li>
              <li>• Score each dimension independently (1–5)</li>
              <li>• AI drafts are starting points — edit before submitting</li>
              <li>• If you have a conflict, use "Declare COI" on the dashboard</li>
            </ul>
          </div>

          <!-- Discussion thread -->
          <div class="card p-5">
            <h2 class="font-semibold text-slate-800 mb-3">Editor discussion</h2>
            <div id="discussionList" class="space-y-3 max-h-64 overflow-y-auto mb-3">
              <% if (!discussion || discussion.length === 0) { %>
                <p class="text-xs text-slate-400 italic">No messages yet.</p>
              <% } else { %>
                <% discussion.forEach(msg => { %>
                  <div class="rounded-md p-2.5 <%= msg.role === 'reviewer' ? 'bg-indigo-50 border border-indigo-100' : 'bg-slate-50 border border-slate-200' %>">
                    <div class="flex justify-between text-xs text-slate-500 mb-1">
                      <span class="font-semibold <%= msg.role === 'reviewer' ? 'text-indigo-700' : 'text-slate-700' %>"><%= msg.username %></span>
                      <span><%= new Date(msg.created_at).toLocaleDateString() %></span>
                    </div>
                    <p class="text-xs text-slate-700"><%= msg.message %></p>
                  </div>
                <% }) %>
              <% } %>
            </div>
            <div class="flex gap-2">
              <input type="text" id="discussionInput" placeholder="Message editor…" maxlength="500"
                class="flex-1 text-xs border border-slate-300 rounded-md px-2 py-1.5 focus:outline-none focus:border-indigo-500">
              <button onclick="postMessage()" class="bg-indigo-600 text-white text-xs px-3 py-1.5 rounded-md font-medium hover:bg-indigo-700">Send</button>
            </div>
          </div>
        </aside>

        <section>
          <div class="flex flex-wrap justify-between items-center gap-3 mb-4">
            <div>
              <p class="eyebrow text-indigo-700">Structured review</p>
              <h2 class="font-display text-3xl font-bold mt-1">Your assessment</h2>
            </div>
            <div class="flex gap-2">
              <button id="aiDraftBtn"
                class="text-sm bg-indigo-50 hover:bg-indigo-100 text-indigo-700 border border-indigo-200 px-3 py-2 rounded-md font-semibold transition"
                aria-label="Generate AI draft review">
                Generate AI draft
              </button>
            </div>
          </div>

          <form action="/reviewer/reviews/<%= review.id %>" method="post" class="card p-6 space-y-5" id="reviewForm">
            <input type="hidden" name="ai_assisted" id="ai_assisted" value="<%= review.ai_assisted ? '1' : '0' %>">

            <div>
              <label for="summary" class="block text-sm font-semibold text-slate-700">Summary <span class="text-red-500">*</span></label>
              <p class="text-xs text-slate-500 mb-1">Briefly summarize the paper and your overall assessment</p>
              <textarea name="summary" id="summary" rows="3" required
                class="mt-1 block w-full rounded-md border border-slate-300 px-3 py-2.5 focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 focus:outline-none"><%= review.summary || '' %></textarea>
            </div>

            <div class="grid md:grid-cols-2 gap-4">
              <div>
                <label for="strengths" class="block text-sm font-semibold text-slate-700">Strengths <span class="text-red-500">*</span></label>
                <textarea name="strengths" id="strengths" rows="4" required
                  class="mt-1 block w-full rounded-md border border-slate-300 px-3 py-2.5 focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 focus:outline-none"><%= review.strengths || '' %></textarea>
              </div>
              <div>
                <label for="weaknesses" class="block text-sm font-semibold text-slate-700">Weaknesses <span class="text-red-500">*</span></label>
                <textarea name="weaknesses" id="weaknesses" rows="4" required
                  class="mt-1 block w-full rounded-md border border-slate-300 px-3 py-2.5 focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 focus:outline-none"><%= review.weaknesses || '' %></textarea>
              </div>
            </div>

            <!-- Score sliders -->
            <div class="grid grid-cols-3 gap-4">
              <% [['novelty_score','Novelty'],['clarity_score','Clarity'],['significance_score','Significance']].forEach(([name, label]) => { %>
              <div>
                <label class="block text-sm font-semibold text-slate-700 mb-1"><%= label %> <span id="<%= name %>_display" class="text-indigo-600 font-bold"><%= review[name] || 3 %></span>/5</label>
                <input type="range" min="1" max="5" step="1" name="<%= name %>" id="<%= name %>"
                  value="<%= review[name] || 3 %>"
                  class="w-full accent-indigo-600"
                  oninput="document.getElementById('<%= name %>_display').textContent = this.value">
                <div class="flex justify-between text-xs text-slate-400 mt-0.5"><span>Poor</span><span>Excellent</span></div>
              </div>
              <% }) %>
            </div>

            <div>
              <label for="recommendation" class="block text-sm font-semibold text-slate-700">Recommendation <span class="text-red-500">*</span></label>
              <select name="recommendation" id="recommendation" required
                class="mt-1 block w-full rounded-md border border-slate-300 px-3 py-2.5 bg-white focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 focus:outline-none">
                <option value="">— Select —</option>
                <option value="accept" <%= review.recommendation === 'accept' ? 'selected' : '' %>>Accept</option>
                <option value="minor_revisions" <%= review.recommendation === 'minor_revisions' ? 'selected' : '' %>>Minor revisions</option>
                <option value="major_revisions" <%= review.recommendation === 'major_revisions' ? 'selected' : '' %>>Major revisions</option>
                <option value="reject" <%= review.recommendation === 'reject' ? 'selected' : '' %>>Reject</option>
              </select>
            </div>

            <div>
              <label for="review_text" class="block text-sm font-semibold text-slate-700">Additional notes <span class="text-slate-400 font-normal">(optional)</span></label>
              <textarea name="review_text" id="review_text" rows="3"
                class="mt-1 block w-full rounded-md border border-slate-300 px-3 py-2.5 focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 focus:outline-none"><%= review.review_text || '' %></textarea>
            </div>

            <% if (review.ai_assisted) { %>
              <div class="flex items-center gap-2 text-xs text-indigo-600 bg-indigo-50 border border-indigo-100 rounded-md px-3 py-2">
                <svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                AI draft was used for this review.
              </div>
            <% } %>

            <div class="flex items-center justify-between pt-2">
              <button type="button" id="qualityCheckBtn"
                class="text-sm text-slate-600 hover:text-slate-800 border border-slate-300 px-3 py-2 rounded-md font-medium transition">
                Check quality
              </button>
              <button type="submit" id="submitBtn"
                class="bg-slate-950 hover:bg-slate-800 text-white px-6 py-2.5 rounded-md font-semibold transition"
                onclick="return confirmSubmit()">
                Submit review
              </button>
            </div>
            <div id="qualityResult" class="hidden p-3 rounded-md border text-xs"></div>
          </form>
        </section>
      </div>
    </div>
  </main>

  <!-- Decline modal -->
  <div id="declineModal" class="hidden fixed inset-0 bg-black/50 z-50 flex items-center justify-center p-4">
    <div class="bg-white rounded-xl shadow-xl w-full max-w-md p-6">
      <h2 class="font-semibold text-lg mb-2">Decline review assignment</h2>
      <p class="text-sm text-slate-600 mb-4">Please provide a reason. The editor will be notified.</p>
      <textarea id="declineReason" rows="3" placeholder="e.g., Outside my area of expertise, workload constraints..."
        class="w-full border border-slate-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:border-red-400 mb-4"></textarea>
      <div class="flex gap-3">
        <button onclick="submitDecline()" class="bg-red-600 hover:bg-red-700 text-white px-4 py-2 rounded-md text-sm font-medium">Decline</button>
        <button onclick="document.getElementById('declineModal').classList.add('hidden')"
          class="px-4 py-2 border border-slate-300 rounded-md text-sm text-slate-700">Cancel</button>
      </div>
    </div>
  </div>

  <%- include('../partials/footer') %>

  <script>
    // AI draft
    document.getElementById('aiDraftBtn').addEventListener('click', async () => {
      const btn = document.getElementById('aiDraftBtn');
      btn.disabled = true; btn.textContent = 'Generating…';
      try {
        const r = await fetch('/reviewer/papers/<%= paper.id %>/ai-draft');
        if (!r.ok) throw new Error(await r.text());
        const d = await r.json();
        if (d.summary) document.getElementById('summary').value = d.summary;
        if (d.strengths) document.getElementById('strengths').value = d.strengths;
        if (d.weaknesses) document.getElementById('weaknesses').value = d.weaknesses;
        if (d.novelty_score) { document.getElementById('novelty_score').value = d.novelty_score; document.getElementById('novelty_score_display').textContent = d.novelty_score; }
        if (d.clarity_score) { document.getElementById('clarity_score').value = d.clarity_score; document.getElementById('clarity_score_display').textContent = d.clarity_score; }
        if (d.significance_score) { document.getElementById('significance_score').value = d.significance_score; document.getElementById('significance_score_display').textContent = d.significance_score; }
        if (d.recommendation) document.getElementById('recommendation').value = d.recommendation;
        document.getElementById('ai_assisted').value = '1';
        showToast('AI draft inserted — please review and edit before submitting', 'info', 6000);
        btn.textContent = '✓ Draft inserted';
      } catch (e) {
        showToast('AI draft failed: ' + (e.message || 'Unknown error'), 'error');
        btn.textContent = 'Try again';
      } finally {
        btn.disabled = false;
      }
    });

    // Quality check
    document.getElementById('qualityCheckBtn').addEventListener('click', async () => {
      const btn = document.getElementById('qualityCheckBtn');
      btn.disabled = true; btn.textContent = 'Checking…';
      try {
        const r = await fetch('/api/ai/review/<%= review.id %>/quality');
        const d = await r.json();
        const box = document.getElementById('qualityResult');
        box.classList.remove('hidden');
        const color = d.recommendation === 'acceptable' ? 'border-emerald-200 bg-emerald-50 text-emerald-700' : d.recommendation === 'needs_improvement' ? 'border-amber-200 bg-amber-50 text-amber-700' : 'border-red-200 bg-red-50 text-red-700';
        box.className = `p-3 rounded-md border text-xs ${color}`;
        box.innerHTML = `<strong>Quality score: ${d.score}/100 — ${d.recommendation.replace('_', ' ')}</strong><br>${(d.issues || []).map(i => `• ${i}`).join('<br>') || 'No issues found.'}`;
      } catch { showToast('Quality check unavailable', 'warning'); }
      finally { btn.disabled = false; btn.textContent = 'Check quality'; }
    });

    // Decline
    function openDeclineModal() { document.getElementById('declineModal').classList.remove('hidden'); }
    async function submitDecline() {
      const reason = document.getElementById('declineReason').value.trim();
      if (!reason) { showToast('Please provide a reason', 'warning'); return; }
      try {
        const r = await fetch('/reviewer/reviews/<%= review.id %>/decline', {
          method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ reason }),
        });
        const d = await r.json();
        if (r.ok) { showToast('Assignment declined', 'success'); setTimeout(() => location.href = '/reviewer', 1200); }
        else showToast(d.error || 'Error', 'error');
      } catch { showToast('Network error', 'error'); }
    }

    // Discussion
    async function postMessage() {
      const input = document.getElementById('discussionInput');
      const msg = input.value.trim();
      if (!msg) return;
      try {
        const r = await fetch('/reviewer/papers/<%= paper.id %>/discussion', {
          method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ message: msg }),
        });
        const d = await r.json();
        if (r.ok) {
          input.value = '';
          const list = document.getElementById('discussionList');
          const el = document.createElement('div');
          el.className = 'rounded-md p-2.5 bg-indigo-50 border border-indigo-100';
          el.innerHTML = `<div class="flex justify-between text-xs text-indigo-700 mb-1"><span class="font-semibold">You</span><span>now</span></div><p class="text-xs text-slate-700">${msg}</p>`;
          list.appendChild(el);
          list.scrollTop = list.scrollHeight;
          showToast('Message sent', 'success');
        } else showToast(d.error || 'Error', 'error');
      } catch { showToast('Network error', 'error'); }
    }
    document.getElementById('discussionInput').addEventListener('keypress', (e) => { if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); postMessage(); } });

    // Confirm before submit
    function confirmSubmit() {
      const rec = document.getElementById('recommendation').value;
      if (!rec) { showToast('Please select a recommendation', 'warning'); return false; }
      return true;
    }
  </script>
</body>
</html>
